# Memos（PostgreSQL）環境變數（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

# Memos
MEMOS_DRIVER=postgres
MEMOS_DSN=postgresql://${db_user}:${db_pass}@localhost:5432/memos?sslmode=disable
MEMOS_DATA=/var/opt/memos
MEMOS_PORT=5230

# （選用）公開網址（反向代理到域名後建議設定）
#MEMOS_INSTANCE_URL=https://memos.example.com

# PostgreSQL（同一個 Pod 內的 postgres 容器會使用）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=memos

