# Kener（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器（包含 App 與 Redis 容器）
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# Kener 必填
KENER_SECRET_KEY=${kener_secret_key}
ORIGIN=http://127.0.0.1:${host_port}

# 服務設定
NODE_ENV=production
PORT=3000

# Redis（同一 Pod 內的 redis 容器）
REDIS_URL=redis://127.0.0.1:6379

# 資料庫（預設使用 PostgreSQL；同一 Pod 內走 localhost 連線）
DATABASE_URL=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/kener

# PostgreSQL（同一 Pod 內的 postgres 容器會使用）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=kener

# （選用）改回 sqlite（檔案會寫入 /app/database）
#DATABASE_URL=sqlite://./database/kener.sqlite.db

# SMTP（預設不啟用；若要啟用請取消註解並填入）
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=username
#SMTP_PASS=password
#SMTP_SECURE=0
#SMTP_FROM_EMAIL=user@example.com
