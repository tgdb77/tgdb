# Gatus（TGDB 產生）
# 參考：
# - README / Docker：https://github.com/TwiN/gatus
#
# Gatus 主要設定放在 config/config.yaml。
# 這裡僅保留少量常用環境變數。

# 設定檔路徑（若指定為目錄，Gatus 會合併其下所有 yml/yaml）
GATUS_CONFIG_PATH=/config/config.yaml

# 日誌層級：DEBUG / INFO / WARN / ERROR / FATAL
GATUS_LOG_LEVEL=INFO

# 啟動後延遲幾秒才開始健康檢查（上游服務較慢啟動時可用）
GATUS_DELAY_START_SECONDS=0
