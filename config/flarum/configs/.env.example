# Flarum 環境變數（TGDB 產生）
#
# 參考：
# - Flarum 專案：https://github.com/flarum/flarum
# - 容器文件：https://github.com/crazy-max/docker-flarum
#
# 注意：
# - 變更後需重新啟動單元
# - 對外正式上線前，建議搭配 Nginx / HTTPS 反向代理

TZ=Asia/Taipei
PUID=${user_id}
PGID=${group_id}

# -----------------------------------------------------------------------------
# Flarum 基本設定
# -----------------------------------------------------------------------------
FLARUM_FORUM_TITLE=${forum_title}
FLARUM_BASE_URL=http://127.0.0.1:${host_port}

# 可選：偵錯 / 上傳等設定
#DEBUG=false
#PHP_MEMORY_LIMIT=512M
#UPLOAD_MAX_SIZE=50M

# -----------------------------------------------------------------------------
# 資料庫（Flarum -> MariaDB）
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=flarum
DB_USER=${db_user}
DB_PASSWORD=${db_pass}
DB_PREFIX=flarum_

# -----------------------------------------------------------------------------
# MariaDB 初始化（供 mariadb official image 使用）
# -----------------------------------------------------------------------------
MARIADB_AUTO_UPGRADE=1
MARIADB_INITDB_SKIP_TZINFO=1
MARIADB_DATABASE=flarum
MARIADB_USER=${db_user}
MARIADB_PASSWORD=${db_pass}
MARIADB_ROOT_PASSWORD=${mariadb_root_password}
