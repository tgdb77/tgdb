[Unit]
Description=headscale postgres
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/postgres:16.3-alpine
#AutoUpdate=registry
ContainerName=${container_name}-postgres
Label=app=headscale
Label=tgdb_db=postgres

Pod=${container_name}.pod

Volume=${instance_dir}/pgdata:/var/lib/postgresql/data

EnvironmentFile=${instance_dir}/.env

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
