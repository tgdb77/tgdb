# ============================================
# AnythingLLM — 設定檔
# ============================================
# 這是 TGDB 的精簡範本；更多可選環境變數請參考官方文件：
# https://docs.anythingllm.com/installation-docker/quickstart

# === 基本設定 ===
SERVER_PORT=3001
STORAGE_DIR=/app/server/storage
DISABLE_TELEMETRY=true
PASSWORDMINCHAR=12

# 建議保留隨機值，避免重啟後 session / 簽章失效
SIG_KEY=${sig_key}
SIG_SALT=${sig_salt}
JWT_SECRET=${jwt_secret}

# === LLM Provider 範例（預設留空，請依需求擇一啟用） ===
LLM_PROVIDER=

# OpenAI 範例
# OPEN_AI_KEY=
# OPEN_MODEL_PREF=gpt-4o

# Ollama 範例
# OLLAMA_BASE_PATH=http://host.docker.internal:11434
# OLLAMA_MODEL_PREF=llama3.1
# OLLAMA_MODEL_TOKEN_LIMIT=4096

# Embedding 預設可使用內建 native embedder；若你要改用外部服務再取消下列註解
# EMBEDDING_ENGINE=native
# EMBEDDING_MODEL_PREF=Xenova/all-MiniLM-L6-v2

# 若要搭配 Ollama embeddings：
# EMBEDDING_ENGINE=ollama
# EMBEDDING_BASE_PATH=http://host.docker.internal:11434
# EMBEDDING_MODEL_PREF=nomic-embed-text:latest
# EMBEDDING_MODEL_MAX_CHUNK_LENGTH=8192

# === 向量資料庫（預設可留空，AnythingLLM 會使用內建 LanceDB） ===
# VECTOR_DB=lancedb

# === 其他可選設定 ===
# AUTH_TOKEN=
# JWT_EXPIRY=30d
# WHISPER_PROVIDER=local
# TTS_PROVIDER=native
