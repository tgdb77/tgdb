# -----------------------------------------------------------------------------
# Nextcloud（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 目前預設只綁定本機回環；若要正式對外提供服務，建議搭配 Nginx 反向代理與 HTTPS

TZ=Asia/Taipei

# 首次安裝時建立的 Nextcloud 管理員帳號
NEXTCLOUD_ADMIN_USER=${admin_user}
NEXTCLOUD_ADMIN_PASSWORD=${admin_pass}
NEXTCLOUD_DATA_DIR=/var/www/html/data

# Nextcloud 資料庫（同一 Pod 內的 PostgreSQL）
POSTGRES_HOST=127.0.0.1
POSTGRES_DB=nextcloud
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# PostgreSQL 初始化（供 postgres:16-alpine entrypoint 使用）
POSTGRES_INITDB_ARGS=--encoding=UTF-8

# Redis 記憶體快取（同一 Pod 內的 Redis）
REDIS_HOST=127.0.0.1
REDIS_HOST_PASSWORD=${db_pass}

# 目前預設只保證 127.0.0.1 可用；若改用 localhost / 正式域名，請自行補上
NEXTCLOUD_TRUSTED_DOMAINS=127.0.0.1
OVERWRITECLIURL=http://127.0.0.1:${host_port}

# 反向代理 / HTTPS 啟用後再按需調整
# TRUSTED_PROXIES=127.0.0.1
# OVERWRITEHOST=cloud.example.com
# OVERWRITEPROTOCOL=https
