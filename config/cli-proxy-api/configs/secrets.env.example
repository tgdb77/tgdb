# CLIProxyAPI 金鑰備份（TGDB 自動產生）
#
# 注意：
# - CLIProxyAPI 會在首次啟動後把 config.yaml 的 remote-management.secret-key 轉成 bcrypt 雜湊並覆寫檔案。
# - 你仍然需要使用「明文管理金鑰」呼叫管理 API / 登入管理介面。
# - 請妥善保存本檔案（建議 chmod 600）。

CLI_PROXY_API_KEY=${api_key}
CLI_PROXY_MANAGEMENT_KEY=${management_key}

CLI_PROXY_HTTP_URL=http://127.0.0.1:${host_port}
CLI_PROXY_OPENAI_BASE_URL=http://127.0.0.1:${host_port}/v1
CLI_PROXY_MANAGEMENT_URL=http://127.0.0.1:${host_port}/management.html
CLI_PROXY_MANAGEMENT_API_BASE_URL=http://127.0.0.1:${host_port}/v0/management
