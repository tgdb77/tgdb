# FossFLOW 環境變數（TGDB 產生）
#
# 參考：
# - 專案首頁：https://github.com/stan-smith/FossFLOW
# - 官方 env 範本：https://github.com/stan-smith/FossFLOW/blob/master/.env.example
# - 官方 compose：https://github.com/stan-smith/FossFLOW/blob/master/compose.yml
#
# 注意：
# - 變更後需重新啟動單元
# - TGDB 預設會把 ${volume_dir} 掛到容器內的 /data/diagrams
# - 這份檔案會被 systemd/Quadlet 讀取；值內請避免空白

# 啟用伺服器端儲存（建議保留 true，方便多裝置存取）
ENABLE_SERVER_STORAGE=true

# Git 備份（選填；需依上游文件自行補齊相關 git 環境）
ENABLE_GIT_BACKUP=false

# 容器內資料路徑（通常不需修改）
STORAGE_PATH=/data/diagrams

# 後端儲存服務埠（容器內）
BACKEND_PORT=3001

# HTTP Basic Auth（選填；兩個都填才會啟用）
HTTP_AUTH_USER=
HTTP_AUTH_PASSWORD=
