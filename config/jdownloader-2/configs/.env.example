# -----------------------------------------------------------------------------
# JDownloader 2（jlesage/docker-jdownloader-2）環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案可能包含密碼或敏感設定，建議權限設為 600。
#
# 修改後需重啟服務才會生效：
# - systemctl --user restart ${container_name}.service

# jlesage 系列鏡像常用環境變數（保守預設；可依需求調整）
USER_ID=${user_id}
GROUP_ID=${user_id}
TZ=Asia/Taipei
ENABLE_CJK_FONT=1

# 若你會把 5800 透過 Nginx 對外公開，建議啟用 Web 登入保護
#WEB_AUTHENTICATION=1

# VNC 密碼（必填）
VNC_PASSWORD=${pass_word}

#KEEP_APP_RUNNING=1
#CLEAN_TMP_DIR=1
