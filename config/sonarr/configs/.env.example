# -----------------------------------------------------------------------------
# Sonarr（LinuxServer.io）環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - https://docs.linuxserver.io/images/docker-sonarr/
# - TRaSH Guides Docker 路徑規劃

PUID=${user_id}
PGID=${group_id}
TZ=Asia/Taipei
UMASK=002

# 建議在 Sonarr 內使用：
# - Root Folder：/data/media/tv
# - qBittorrent / completed：/data/torrents/tv
# - Usenet：/data/usenet/complete/tv
