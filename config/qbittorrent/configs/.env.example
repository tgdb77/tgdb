# -----------------------------------------------------------------------------
# qBittorrent（LinuxServer.io）環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案可能包含密碼或敏感設定，建議權限設為 600。

PUID=${user_id}
PGID=${user_id}
TZ=Asia/Taipei

# Web UI 埠（需與 Quadlet 的 PublishPort 對齊）
WEBUI_PORT=${host_port}

# BT 連線埠（需與 Quadlet 的 PublishPort 對齊）
TORRENTING_PORT=6881
