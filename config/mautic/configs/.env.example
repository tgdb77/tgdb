# -----------------------------------------------------------------------------
# Mautic 環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - 官方 Docker README：https://github.com/mautic/docker-mautic
# - 官方 basic compose：https://github.com/mautic/docker-mautic/blob/main/examples/basic/docker-compose.yml
# - 官方文件：https://docs.mautic.org/en/5.x/
#
# 注意：
# - 變更後需重新啟動單元
# - /config 與 /var/logs 由 TGDB instance_dir 管理
# - 媒體資料由 volume_dir/files 與 volume_dir/images 掛載

TZ=Asia/Taipei
DEBUG=false

# PHP 參數（官方 image 預設值）
PHP_INI_VALUE_DATE_TIMEZONE=Asia/Taipei
PHP_INI_VALUE_MEMORY_LIMIT=512M
PHP_INI_VALUE_UPLOAD_MAX_FILESIZE=512M
PHP_INI_VALUE_POST_MAX_FILESIZE=512M
PHP_INI_VALUE_MAX_EXECUTION_TIME=300

# MySQL（供 MySQL 容器初始化使用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=mautic
MYSQL_USER=${db_user}
MYSQL_PASSWORD=${db_pass}
MYSQL_ROOT_PASSWORD=${mysql_root_password}

# Mautic（供 web / cron / worker 使用）
MAUTIC_DB_HOST=127.0.0.1
MAUTIC_DB_PORT=3306
MAUTIC_DB_DATABASE=mautic
MAUTIC_DB_USER=${db_user}
MAUTIC_DB_PASSWORD=${db_pass}

DOCKER_MAUTIC_LOAD_TEST_DATA=false
DOCKER_MAUTIC_WORKERS_CONSUME_EMAIL=2
DOCKER_MAUTIC_WORKERS_CONSUME_HIT=2
DOCKER_MAUTIC_WORKERS_CONSUME_FAILED=2

# 官方 basic compose 使用 doctrine queue
MAUTIC_MESSENGER_DSN_EMAIL=doctrine://default
MAUTIC_MESSENGER_DSN_HIT=doctrine://default
