[Unit]
Description=Mautic（MySQL）
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/library/mysql:lts
#AutoUpdate=registry
ContainerName=${container_name}-mysql
Label=app=mautic
Label=tgdb_db=mysql

Pod=${container_name}.pod

EnvironmentFile=${instance_dir}/.env
Volume=${instance_dir}/mysql:/var/lib/mysql

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
