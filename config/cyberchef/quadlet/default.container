[Unit]
Description=CyberChef
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/gchq/cyberchef:10
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=cyberchef
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:80/tcp

EnvironmentFile=${instance_dir}/.env

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false

