# -----------------------------------------------------------------------------
# Homepage（gethomepage/homepage）環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案可能包含敏感資訊，建議權限設為 600。

# 反代到域名後，請把該域名加入 HOMEPAGE_ALLOWED_HOSTS（用逗號分隔）
HOMEPAGE_ALLOWED_HOSTS=127.0.0.1:${host_port},localhost:${host_port}

PUID=${user_id}
PGID=${user_id}
