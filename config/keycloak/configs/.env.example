# Keycloak（建議維持 start-dev 起步；正式上線請依官方文件調整為 start）

# ---- 管理員（bootstrap）----
# 新版 Keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=${admin_user}
KC_BOOTSTRAP_ADMIN_PASSWORD=${admin_pass}
# 舊版 Keycloak（相容）
KEYCLOAK_ADMIN=${admin_user}
KEYCLOAK_ADMIN_PASSWORD=${admin_pass}

# ---- Database（PostgreSQL）----
KC_DB=postgres
KC_DB_URL_HOST=127.0.0.1
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak
KC_DB_USERNAME=${db_user}
KC_DB_PASSWORD=${db_pass}

POSTGRES_DB=keycloak
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# ---- Optional ----
KC_HEALTH_ENABLED=true
KC_METRICS_ENABLED=true

# 反向代理/對外域名（按需使用；不設定也可跑）
#KC_HOSTNAME=https://sso.example.com
#KC_HOSTNAME_URL=https://sso.example.com
#KC_PROXY_HEADERS=xforwarded
#KC_HTTP_ENABLED=true
#KC_HOSTNAME_STRICT=true
#KC_HOSTNAME_STRICT_HTTPS=false