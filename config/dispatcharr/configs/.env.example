# Dispatcharr 環境變數（TGDB 產生）
#
# 參考：
# - 專案首頁：https://github.com/Dispatcharr/Dispatcharr
# - 官方 AIO Compose：https://github.com/Dispatcharr/Dispatcharr/blob/main/docker/docker-compose.aio.yml
# - 官方 Modular Compose：https://github.com/Dispatcharr/Dispatcharr/blob/main/docker/docker-compose.yml
#
# 注意：
# - 這裡採官方推薦的 AIO 單容器部署
# - 變更後需重新啟動單元
# - 正式對外前建議搭配 Nginx / HTTPS / 防火牆策略

# -----------------------------------------------------------------------------
# 部署模式與日誌
# -----------------------------------------------------------------------------
DISPATCHARR_ENV=aio
DISPATCHARR_PORT=9191
DISPATCHARR_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# 內建 Redis / Celery（AIO 模式）
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# 內建 PostgreSQL（AIO 模式）
# -----------------------------------------------------------------------------
POSTGRES_DB=dispatcharr
POSTGRES_USER=dispatch
POSTGRES_PASSWORD=${postgres_password}

# -----------------------------------------------------------------------------
# 其他常用選填設定
# -----------------------------------------------------------------------------
# 舊 CPU 相容模式（需要時再開）
#USE_LEGACY_NUMPY=true

# 行程優先權（負值需搭配 SYS_NICE）
#UWSGI_NICE_LEVEL=-5
#CELERY_NICE_LEVEL=5
