# -----------------------------------------------------------------------------
# Uptime Kuma 環境變數範本
# -----------------------------------------------------------------------------
# 上游文件：
# - 環境變數：https://github.com/louislam/uptime-kuma/wiki/Environment-Variables
# - 安裝說明：https://github.com/louislam/uptime-kuma
#
# 說明：
# 1. TGDB 預設把宿主機 127.0.0.1:${host_port} 映射到容器內 3001。
# 2. 目前使用容器內建的 `/app/data` 作為資料目錄，因此 DATA_DIR 維持該路徑。
# 3. 為避免容器內服務只綁 IPv6，這裡明確指定綁定 0.0.0.0。
# 4. 若你改成反向代理 / HTTPS，建議仍由 TGDB 的 Nginx/憑證層處理，先不要直接在
#    容器內啟用 SSL_KEY / SSL_CERT。

# 資料目錄（容器內路徑）
DATA_DIR=/app/data

# 監聽位址與埠（容器內）
UPTIME_KUMA_HOST=0.0.0.0
UPTIME_KUMA_PORT=3001

# 若要直接由容器提供 HTTPS，可自行取消註解並掛入憑證檔。
#UPTIME_KUMA_SSL_KEY=
#UPTIME_KUMA_SSL_CERT=
#UPTIME_KUMA_SSL_KEY_PASSPHRASE=

# 若要用 Cloudflare Tunnel，可填入 token。
#UPTIME_KUMA_CLOUDFLARED_TOKEN=

# 預設保留 iframe 與 websocket 的來源保護；若你非常確定需求，再自行打開。
#UPTIME_KUMA_DISABLE_FRAME_SAMEORIGIN=false
#UPTIME_KUMA_WS_ORIGIN_CHECK=cors-like

# 外部資料庫（2.x 起支援）；若不填，維持預設 SQLite。
#UPTIME_KUMA_DB_TYPE=
#UPTIME_KUMA_DB_HOSTNAME=
#UPTIME_KUMA_DB_PORT=
#UPTIME_KUMA_DB_SOCKET=
#UPTIME_KUMA_DB_NAME=
#UPTIME_KUMA_DB_USERNAME=
#UPTIME_KUMA_DB_PASSWORD=
#UPTIME_KUMA_DB_SSL=false
#UPTIME_KUMA_DB_CA=

# Docker Secret 友善寫法（若採 secrets 可改用 *_FILE）
#UPTIME_KUMA_DB_USERNAME_FILE=
#UPTIME_KUMA_DB_PASSWORD_FILE=
#UPTIME_KUMA_DB_CA_FILE=

# 僅開發 / 除錯用途；正式環境不建議調整。
#NODE_ENV=production
#SQL_LOG=0
#UPTIME_KUMA_HIDE_LOG=
