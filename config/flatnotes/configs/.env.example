# Flatnotes（TGDB 產生）
#
# 參考：
# - GitHub：https://github.com/dullage/flatnotes
# - Environment Variables：https://github.com/dullage/flatnotes/wiki/Environment-Variables
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# Docker image 內建預設會把 /data 當成筆記目錄
PUID=${user_id}
PGID=${group_id}

FLATNOTES_AUTH_TYPE=password
FLATNOTES_USERNAME=${admin_user}
FLATNOTES_PASSWORD=${admin_pass}
FLATNOTES_SECRET_KEY=${secret_key}

FLATNOTES_HOST=0.0.0.0
FLATNOTES_PORT=8080

# ---- 選填：首頁快速存取區 ----
#FLATNOTES_QUICK_ACCESS_TITLE=RECENTLY_MODIFIED
#FLATNOTES_QUICK_ACCESS_TERM=*
#FLATNOTES_QUICK_ACCESS_SORT=lastModified
#FLATNOTES_QUICK_ACCESS_LIMIT=4

# ---- 選填：2FA ----
# 若把 FLATNOTES_AUTH_TYPE 改成 totp，請補上這個 key。
#FLATNOTES_TOTP_KEY=
