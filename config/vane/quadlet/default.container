[Unit]
Description=Vane
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/itzcrazykns1337/vane:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=vane
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:3000

Volume=${instance_dir}/data:/home/vane/data

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
