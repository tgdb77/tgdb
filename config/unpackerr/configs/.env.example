# -----------------------------------------------------------------------------
# Unpackerr 環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - https://unpackerr.zip/docs/install/docker/
#
# 提醒：
# - 先把 URL / API key 填好再啟用
# - 路徑請與 Sonarr / Radarr / Lidarr / qBittorrent 保持相同容器視角
# - URL 請用 host.containers.internal 搭配 TGDB 的主機側埠

TZ=Asia/Taipei
UMASK=002

UN_LOG_FILE=/config/unpackerr.log
UN_LOG_LEVEL=info

UN_WEBSERVER_METRICS=true
UN_WEBSERVER_LISTEN_ADDR=0.0.0.0:5656

# 完成下載與解壓的根目錄（需與其他容器一致）
UN_DIRS_0_PATH=/data/torrents
UN_DIRS_1_PATH=/data/usenet

# Sonarr
UN_SONARR_0_URL=http://host.containers.internal:38989
UN_SONARR_0_API_KEY=

# Radarr
UN_RADARR_0_URL=http://host.containers.internal:37878
UN_RADARR_0_API_KEY=

# Lidarr
UN_LIDARR_0_URL=http://host.containers.internal:38686
UN_LIDARR_0_API_KEY=

# Bazarr（選填）
UN_BAZARR_0_URL=http://host.containers.internal:36767
UN_BAZARR_0_API_KEY=

# Whisparr（選填）
#UN_WHISPARR_0_URL=http://host.containers.internal:36969
#UN_WHISPARR_0_API_KEY=
