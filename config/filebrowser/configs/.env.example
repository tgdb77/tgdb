# FileBrowser Quantum 環境變數範本
#
# 檔案位置：${instance_dir}/.env
# 參考：
# - https://filebrowserquantum.com/en/docs/getting-started/docker/
# - https://filebrowserquantum.com/en/docs/reference/environment-variables/
#
# 注意：
# - 此檔案包含管理員密碼與加密金鑰，請維持 600 權限。
# - 變更後需重啟單元。

# 管理員密碼（必填）
FILEBROWSER_ADMIN_PASSWORD=${admin_password}

# JWT 簽章金鑰（建議保留隨機值）
FILEBROWSER_JWT_TOKEN_SECRET=${jwt_token_secret}

# TOTP/2FA 加密金鑰（建議保留隨機值）
FILEBROWSER_TOTP_SECRET=${totp_secret}

# 如需自訂資料庫位置，可取消註解後修改
#FILEBROWSER_DATABASE=/home/filebrowser/data/filebrowser.db
