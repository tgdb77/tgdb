# Bichon 環境變數（TGDB 產生）
#
# 參考：
# - 專案首頁：https://github.com/rustmailer/bichon
# - 官方 README：https://github.com/rustmailer/bichon/blob/main/README.md
# - 官方 env 範本：https://github.com/rustmailer/bichon/blob/main/env/bichon.env
#
# 注意：
# - 變更後需重新啟動單元
# - 正式對外前建議搭配 Nginx / HTTPS 反向代理
# - 郵件封存資料預設放在 volume_dir/bichon-data

# 日誌等級：trace / debug / info / warn / error
BICHON_LOG_LEVEL=info

# HTTP 服務埠（容器內）
BICHON_HTTP_PORT=15630

# 公開 URL（改成域名 / HTTPS 時請同步調整）
BICHON_PUBLIC_URL=http://127.0.0.1:${host_port}

# 日誌格式
BICHON_ANSI_LOGS=false
BICHON_JSON_LOGS=false
BICHON_LOG_TO_FILE=false
BICHON_MAX_SERVER_LOG_FILES=5

# 資料加密密碼（請妥善保存）
BICHON_ENCRYPT_PASSWORD=${encrypt_password}

# 持久化資料根目錄
BICHON_ROOT_DIR=/data/bichon-data

# Access Token 驗證（依需求再自行啟用）
BICHON_ENABLE_ACCESS_TOKEN=false

# 不指定時由程式預設綁定 0.0.0.0；Quadlet 仍只會對主機暴露 127.0.0.1
#BICHON_BIND_IP=

# 依官方 v0.1.4+ 行為，不設定時允許所有來源；正式環境建議填入精確來源
#BICHON_CORS_ORIGINS=http://127.0.0.1:${host_port}
BICHON_CORS_MAX_AGE=86400

BICHON_ENABLE_REST_HTTPS=false
BICHON_HTTP_COMPRESSION_ENABLED=true
