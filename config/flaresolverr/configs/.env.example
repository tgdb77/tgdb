# FlareSolverr 環境變數
#
# 檔案位置：${instance_dir}/.env
# 參考：https://github.com/FlareSolverr/FlareSolverr#environment-variables
#
# 注意：
# - 請勿加入空白
# - 變更後需重啟單元
# - 其他容器若要呼叫本服務，請用 http://host.containers.internal:${host_port}/v1

# -----------------------------------------------------------------------------
# 監聽設定（Docker/Podman 通常不需要改）
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8191

# -----------------------------------------------------------------------------
# 記錄
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_HTML=false

# -----------------------------------------------------------------------------
# 時區
# -----------------------------------------------------------------------------
TZ=Asia/Taipei

# -----------------------------------------------------------------------------
# 瀏覽器模式（只用於除錯）
# -----------------------------------------------------------------------------
HEADLESS=true

# -----------------------------------------------------------------------------
# CAPTCHA 求解（目前多數 solver 不可用；請以專案 issue 狀態為準）
# -----------------------------------------------------------------------------
CAPTCHA_SOLVER=none
