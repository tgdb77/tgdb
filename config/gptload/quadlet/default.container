[Unit]
Description=gpt-load
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/tbphp/gpt-load:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=gptload
#Network=tgdb.network
PublishPort=127.0.0.1:${host_port}:3001
EnvironmentFile=${instance_dir}/.env
Volume=${instance_dir}:/app/data

[Service]
Restart=on-failure
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
