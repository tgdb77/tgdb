# MeiliSearch（TGDB 產生）
#
# 參考：
# - Docker：https://www.meilisearch.com/docs/resources/self_hosting/getting_started/docker
# - Configuration：https://www.meilisearch.com/docs/resources/self_hosting/configuration/reference
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# 基本設定
MEILI_ENV=production
MEILI_HTTP_ADDR=0.0.0.0:7700
MEILI_MASTER_KEY=${master_key}

# Docker 工作目錄與持久化資料
MEILI_DB_PATH=/meili_data/data.ms
MEILI_DUMP_DIR=/meili_data/dumps
MEILI_SNAPSHOT_DIR=/meili_data/snapshots

# ---- 其他選填設定 ----
#MEILI_LOG_LEVEL=INFO
#MEILI_HTTP_PAYLOAD_SIZE_LIMIT=100 MB
#MEILI_MAX_INDEXING_MEMORY=2GiB
#MEILI_MAX_INDEXING_THREADS=2

# 啟用排程 snapshots（例如每 24 小時）時，可改用 Quadlet Exec 或額外 CLI 參數。
# 參考：--schedule-snapshot
