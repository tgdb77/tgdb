# -----------------------------------------------------------------------------
# Ollama（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - 本檔案會由 Quadlet 以 EnvironmentFile 載入。
# - 模型實體檔案預設位於 /root/.ollama（已由 volume_dir 掛載到主機）。

# API 監聽位址（容器內）
OLLAMA_HOST=0.0.0.0:11434

# 模型路徑（通常保持預設）
OLLAMA_MODELS=/root/.ollama/models

# 模型保活時間（可選）
# OLLAMA_KEEP_ALIVE=5m

# 並行/排隊（可選，依硬體調整）
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=1
# OLLAMA_MAX_QUEUE=512

# 允許跨來源呼叫（可選）
# 例：OLLAMA_ORIGINS=http://127.0.0.1:3366,https://ai.example.com
# OLLAMA_ORIGINS=
