# -----------------------------------------------------------------------------
# Homebox（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 資料預設寫入 /data（SQLite + 上傳檔案等）
# - 若要對外提供服務，建議搭配 Nginx 反向代理與 HTTPS

TZ=Asia/Taipei

# 基本日誌
HBOX_LOG_LEVEL=info
HBOX_LOG_FORMAT=text

# Web 上傳大小上限（MB）
HBOX_WEB_MAX_UPLOAD_SIZE=10

# 是否允許匿名裝置分析（建議關閉）
HBOX_OPTIONS_ALLOW_ANALYTICS=false
