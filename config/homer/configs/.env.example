# -----------------------------------------------------------------------------
# Homer 環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - 官方 GitHub：https://github.com/bastienwirtz/homer
# - 官方設定文件：https://github.com/bastienwirtz/homer/blob/main/docs/configuration.md
#
# 注意：
# - 變更後需重新啟動單元
# - INIT_ASSETS 在 TGDB 預設關閉，因為我們已直接產生 assets/config.yml

INIT_ASSETS=0
PORT=8080
IPV6_DISABLE=1

# 若要掛在子路徑（例如 /homer），可取消註解：
#SUBFOLDER=/homer
