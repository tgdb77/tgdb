# Healthchecks（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 若改用反向代理或 HTTPS，請同步更新 SITE_ROOT 與 ALLOWED_HOSTS

TZ=Asia/Taipei

SECRET_KEY=${secret_key}

# 正式環境務必關閉 DEBUG；Healthchecks 預設值為 True。
DEBUG=False

SITE_NAME=Healthchecks
SITE_ROOT=http://127.0.0.1:${host_port}
ALLOWED_HOSTS=127.0.0.1,localhost

# 保守預設：關閉公開註冊，只允許已建立的管理員登入。
REGISTRATION_OPEN=False

# 官方文件指出 DB 預設可用 sqlite；此處直接把資料庫放到掛載的 /data。
DB=sqlite
DB_NAME=/data/hc.sqlite

# SMTP 先保留空白；若要寄送通知郵件，請補齊以下欄位。
DEFAULT_FROM_EMAIL=healthchecks@localhost
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
