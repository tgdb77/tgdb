# -----------------------------------------------------------------------------
# Tdarr 環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - https://github.com/HaveAGitGat/Tdarr
# - https://docs.tdarr.io/
#
# 建議：
# - 共享影音全家桶時，把 volume_dir 指到同一個共享資料根目錄
# - 在 Tdarr 內掃描 /data/media，暫存目錄固定用 /temp

PUID=${user_id}
PGID=${group_id}
TZ=Asia/Taipei
UMASK_SET=002
