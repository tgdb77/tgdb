# -----------------------------------------------------------------------------
# Paperless-ngx（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - 本範本採官方 Docker（PostgreSQL + Redis + Gotenberg + Tika）部署模型。
# - 修改後需重啟服務才會生效（可用「更新版本」或 systemctl --user restart）。

# 基本設定
PAPERLESS_URL=http://127.0.0.1:${host_port}
PAPERLESS_SECRET_KEY=${secret_key}
PAPERLESS_TIME_ZONE=Asia/Taipei
PAPERLESS_OCR_LANGUAGES=eng
PAPERLESS_OCR_LANGUAGE=eng

# 資料庫（Paperless -> PostgreSQL）
PAPERLESS_DBENGINE=postgresql
PAPERLESS_DBHOST=127.0.0.1
PAPERLESS_DBPORT=5432
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=${user_name}
PAPERLESS_DBPASS=${pass_word}

# Redis（Paperless -> Redis broker）
PAPERLESS_REDIS=redis://127.0.0.1:6379

# 文件轉換/解析（官方建議搭配 Gotenberg + Tika）
PAPERLESS_TIKA_ENABLED=1
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://127.0.0.1:3000
PAPERLESS_TIKA_ENDPOINT=http://127.0.0.1:9998

# 容器內執行身分（rootless 部署建議保留）
USERMAP_UID=${user_id}
USERMAP_GID=${group_id}

# PostgreSQL 初始化
POSTGRES_DB=paperless
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}

# 可選：若你用反向代理 + HTTPS，請改成正式域名
# PAPERLESS_URL=https://paperless.example.com
