# Blinko（TGDB 產生）
#
# 參考：
# - GitHub：https://github.com/blinkospace/blinko
# - docker-compose.prod.yml：https://raw.githubusercontent.com/blinkospace/blinko/main/docker-compose.prod.yml
# - .env 模板：https://raw.githubusercontent.com/blinkospace/blinko/main/.env.tmpl
#
# 注意：
# - 變更後需重新啟動單元
# - 這份檔案會被 Blinko 與 PostgreSQL 容器共用

TZ=Asia/Taipei
NODE_ENV=production

# 外部存取網址（若改用域名 / HTTPS，請同步更新這兩行）
NEXTAUTH_URL=http://127.0.0.1:${host_port}
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:${host_port}

# Blinko 驗證密鑰
NEXTAUTH_SECRET=${nextauth_secret}

# PostgreSQL（Blinko -> PostgreSQL）
DATABASE_URL=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/postgres

# PostgreSQL 初始化
POSTGRES_DB=postgres
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
