# -----------------------------------------------------------------------------
# ArchiveBox（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 若要正式對外提供服務，建議搭配 Nginx 反向代理與 HTTPS

# 管理員帳密（首次 quick-init 時建立）
ADMIN_USERNAME=${admin_user}
ADMIN_PASSWORD=${admin_pass}

# 目前預設只提供本機回環存取；若改成正式域名，請同步修改這三項
LISTEN_HOST=127.0.0.1:${host_port}
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:${host_port},http://localhost:${host_port}

# 安全預設：ArchiveBox 所有頁面都需要登入
PUBLIC_INDEX=false
PUBLIC_SNAPSHOTS=false
PUBLIC_ADD_VIEW=false

# 啟用 Sonic 全文搜尋（Pod 內以 localhost:1491 連線）
SEARCH_BACKEND_ENGINE=sonic
SEARCH_BACKEND_HOST_NAME=127.0.0.1
SEARCH_BACKEND_PASSWORD=${search_password}

# 對齊 TGDB 建立的資料目錄權限
PUID=${user_id}
PGID=${group_id}
