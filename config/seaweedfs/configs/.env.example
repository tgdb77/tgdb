# -----------------------------------------------------------------------------
# SeaweedFS（S3 + PostgreSQL）設定範本
# -----------------------------------------------------------------------------
# 注意：此檔案包含密碼，建議權限設為 600。
#
# 用途：
# - 給 `default5.container`（PostgreSQL）初始化用
#
# SeaweedFS 自身（master/volume/filer/s3）主要透過：
# - `filer.toml`（PostgreSQL 連線資訊）
# - `s3.json`（S3 身分）
# - `security.toml`（JWT/CORS）
# 來設定；請先把範例複製到 instance_dir 再自行修改。

# 時區
TZ=Asia/Taipei

POSTGRES_DB=seaweedfs
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}

# 部署資訊（不影響 postgres official entrypoint；僅供提示/腳本使用）
SEAWEEDFS_FILER_PORT=${host_port}
SEAWEEDFS_S3_PORT=${s3_port}
SEAWEEDFS_BUCKET_NAME=${bucket_name}
SEAWEEDFS_JWT_KEY=${jwt_key}

# 建議使用 SCRAM（比 md5 更安全；並避免 trust）
# 注意：部分 entrypoint 會把 POSTGRES_INITDB_ARGS 視為「單一參數」處理；
# 因此建議只設定單一參數，避免空白造成 initdb 解析錯誤。
POSTGRES_INITDB_ARGS=--auth-host=scram-sha-256
