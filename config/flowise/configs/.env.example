# -----------------------------------------------------------------------------
# Flowise（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 資料預設寫入 /root/.flowise（已掛載到 ${instance_dir}/flowise）
# - 預設僅綁定 127.0.0.1:${host_port}，若要對外提供服務，建議用 Nginx 反向代理 + HTTPS

TZ=Asia/Taipei

# Flowise 服務埠（容器內）
PORT=3000

# 隱私：停用遙測
DISABLE_FLOWISE_TELEMETRY=true

# 資料庫（內建 PostgreSQL；同一個 Pod 內使用 127.0.0.1 連線）
DATABASE_TYPE=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=flowise
DATABASE_USER=${db_user}
DATABASE_PASSWORD=${db_pass}

# 是否使用 SSL 連 DB（同一台機器/同一個 Pod 通常不需要）
DATABASE_SSL=false

# SQLite 模式（若你想改用 sqlite，請自行調整 DATABASE_TYPE 與相關路徑）
# DATABASE_TYPE=sqlite
# DATABASE_PATH=/root/.flowise

# PostgreSQL（供 postgres official image 初始化）
POSTGRES_DB=flowise
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# 建議使用 SCRAM（比 md5 更安全；並避免 trust）
# 注意：在部分 entrypoint 實作中，POSTGRES_INITDB_ARGS 可能被視為「單一參數」處理；
# 因此這裡建議只設定單一參數，避免空白造成 initdb 解析錯誤。
POSTGRES_INITDB_ARGS=--auth-host=scram-sha-256

# 儲存與其他路徑（建議維持在 /root/.flowise，確保寫入落在掛載卷內）
STORAGE_TYPE=local
BLOB_STORAGE_PATH=/root/.flowise/storage
SECRETKEY_PATH=/root/.flowise
LOG_PATH=/root/.flowise/logs

# 若你使用反向代理到正式域名/HTTPS，請設定 APP_URL（例：https://flowise.example.com）
# APP_URL=

# 若你在反向代理之後需要正確取得客戶端 IP，可調整 TRUST_PROXY（預設為 true）
# TRUST_PROXY=true
