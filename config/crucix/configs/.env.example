# ============================================
# Crucix Intelligence Engine — 設定檔
# ============================================
# 請複製為 .env 後再填入你的金鑰。
# 多數來源金鑰為選填；未填時，對應資料源會自動降級或略過。
#
# 重要：不要把註解寫在值的同一行。
# Docker / Podman 的 env_file 會把行尾註解視為值的一部分。

# === OSINT 資料來源 API 金鑰 ===

# Federal Reserve Economic Data（免費：fred.stlouisfed.org/docs/api）
FRED_API_KEY=
# NASA FIRMS 火災資料（免費：firms.modaps.eosdis.nasa.gov/api）
FIRMS_MAP_KEY=
# Energy Information Administration（免費：api.eia.gov/register）
EIA_API_KEY=
# 海事 AIS 資料（aisstream.io）
AISSTREAM_API_KEY=
# Armed Conflict Location & Event Data（acleddata.com/user/register）
ACLED_EMAIL=
# OAuth2 password grant（官方註記 API keys 已於 2025 年 9 月棄用）
ACLED_PASSWORD=
# Cloudflare Radar 網路中斷 / 流量異常（免費：dash.cloudflare.com/profile/api-tokens，需 Account Analytics Read）
CLOUDFLARE_API_TOKEN=

# === 伺服器設定 ===

# Dashboard 服務埠
PORT=3117
# 自動刷新間隔（分鐘）
REFRESH_INTERVAL_MINUTES=15

# === LLM（選填） ===
# 啟用 AI 強化交易想法與 Telegram 警報。
# 可用 provider：anthropic | openai | gemini | codex | openrouter | minimax | mistral | ollama | grok
LLM_PROVIDER=
# codex 不需要（使用 ~/.codex/auth.json）；ollama 若走本機也不需要
LLM_API_KEY=
# 可選覆寫模型。各 provider 預設值請參考官方 README。
LLM_MODEL=
# Ollama Base URL（只有不是預設 http://localhost:11434 時才需要）
OLLAMA_BASE_URL=

# === Telegram 警報（選填，需要 LLM） ===
# Bot 由 @BotFather 建立；Chat ID 可透過 @userinfobot 取得
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
