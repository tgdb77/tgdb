# Activepieces（TGDB 產生）
#
# 參考：
# - Docker Compose：https://www.activepieces.com/docs/install/options/docker-compose
# - Environment Variables：https://www.activepieces.com/docs/install/configuration/environment-variables
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器（包含 Activepieces / PostgreSQL / Redis 容器）
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# Activepieces 基本設定
AP_ENVIRONMENT=prod
AP_ENGINE_EXECUTABLE_PATH=dist/packages/engine/main.js
AP_FRONTEND_URL=http://127.0.0.1:${host_port}
AP_DB_TYPE=POSTGRES
AP_EXECUTION_MODE=UNSANDBOXED
AP_CONTAINER_TYPE=WORKER_AND_APP

# 加密 / JWT
# - AP_ENCRYPTION_KEY：官方要求 32 字元 hex（16 bytes）
# - AP_JWT_SECRET：官方文件示例使用 openssl rand -hex 32（64 字元）
AP_ENCRYPTION_KEY=${ap_encryption_key}
AP_JWT_SECRET=${ap_jwt_secret}

# PostgreSQL
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_HOST=127.0.0.1
AP_POSTGRES_PORT=5432
AP_POSTGRES_USERNAME=${db_user}
AP_POSTGRES_PASSWORD=${db_pass}

# Redis
AP_REDIS_TYPE=STANDALONE
AP_REDIS_HOST=127.0.0.1
AP_REDIS_PORT=6379
AP_REDIS_DB=0

# 保守預設
AP_QUEUE_UI_ENABLED=false
AP_TELEMETRY_ENABLED=false
AP_TRIGGER_DEFAULT_POLL_INTERVAL=5
AP_FLOW_TIMEOUT_SECONDS=600
AP_WEBHOOK_TIMEOUT_SECONDS=30

# PostgreSQL 容器初始化（同一份 .env 給 DB 容器使用）
POSTGRES_DB=activepieces
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
