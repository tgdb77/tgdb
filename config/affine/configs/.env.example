# AFFiNE 環境變數（自架）
#
# 檔案位置：${instance_dir}/.env
# 上游範本：.docker/selfhost/.env.example（toeverything/AFFiNE）
#
# 注意：
# - 反代到域名後，建議補上 AFFINE_SERVER_HOST / AFFINE_SERVER_EXTERNAL_URL
# - 設定完成後請重啟單元

# 服務埠（容器內）
PORT=3010

# Redis（同 Pod 內可用 localhost）
REDIS_SERVER_HOST=localhost

# PostgreSQL
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=affine
POSTGRES_INITDB_ARGS=--data-checksums

# AFFiNE 連線字串（同 Pod 內可用 localhost）
DATABASE_URL=postgresql://${db_user}:${db_pass}@localhost:5432/affine

# 預設關閉 indexer（較省資源）；若你需要全文索引可改為 true
AFFINE_INDEXER_ENABLED=false

# 對外連結（選填：反代到域名後建議設定）
#AFFINE_SERVER_HTTPS=true
#AFFINE_SERVER_HOST=affine.example.com
#AFFINE_SERVER_EXTERNAL_URL=https://affine.example.com

