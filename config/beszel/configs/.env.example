# -----------------------------------------------------------------------------
# Beszel Hub 環境變數範本
# -----------------------------------------------------------------------------
# 上游文件：
# - Hub 安裝：https://beszel.dev/guide/hub-installation
# - 環境變數：https://beszel.dev/guide/environment-variables
#
# 說明：
# 1. TGDB 預設把宿主機 127.0.0.1:${host_port} 映射到容器內 8090。
# 2. APP_URL 主要用於通知信件、連結產生，以及反向代理 / 子路徑情境。
# 3. 其餘項目先保留官方常見選項，預設採保守值；需要時再取消註解。

# 建議至少保留為目前實際入口位址；若之後改成域名 / HTTPS，請同步改這裡。
APP_URL=http://127.0.0.1:${host_port}

# 允許 Hub 檢查新版本並在介面提示。
CHECK_UPDATES=true

# 是否允許在 Web UI 查看容器 inspect / logs 等詳細資訊。
CONTAINER_DETAILS=true

# 是否讓所有使用者都能看到所有系統。
#SHARE_ALL_SYSTEMS=false

# 自訂 Content-Security-Policy 標頭；通常留空即可。
#CSP=

# 若改用 OAuth / OIDC 並想停用密碼登入，可改成 true。
#DISABLE_PASSWORD_AUTH=false

# 若使用 OAuth / OIDC，是否允許自動建立使用者。
#USER_CREATION=false

# 自動建立第一個使用者（首次初始化輔助用）。
#USER_EMAIL=
#USER_PASSWORD=

# 若已正確設定 SMTP，可改成 true 或 superusers 以啟用 OTP MFA。
#MFA_OTP=false

# 若你有自建前置驗證，可信任標頭可填入使用者 email 所在 header 名稱。
#TRUSTED_AUTH_HEADER=

# 僅測試用途：自動登入指定帳號，等同繞過一般登入流程，不建議正式使用。
#AUTO_LOGIN=
