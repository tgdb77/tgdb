# -----------------------------------------------------------------------------
# Langflow（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 目前採單容器 + 持久化 SQLite，資料會保存在 LANGFLOW_CONFIG_DIR

TZ=Asia/Taipei

LANGFLOW_HOST=0.0.0.0
LANGFLOW_PORT=7860
LANGFLOW_CONFIG_DIR=/app/langflow
LANGFLOW_SAVE_DB_IN_CONFIG_DIR=true

# 保守安全預設：停用自動登入，固定 superuser 與 secret key
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_SUPERUSER=${superuser}
LANGFLOW_SUPERUSER_PASSWORD=${superuser_password}
LANGFLOW_SECRET_KEY=${secret_key}
LANGFLOW_ENABLE_SUPERUSER_CLI=false

# 容器內不要自動開瀏覽器，也不要回傳匿名遙測
LANGFLOW_OPEN_BROWSER=false
DO_NOT_TRACK=true
