# PhotoPrism 環境變數
#
# 檔案位置：${instance_dir}/.env
# 官方文件：
# - Docker Compose：https://docs.photoprism.app/getting-started/docker-compose/
# - Config Options：https://docs.photoprism.app/getting-started/config-options/
# - Databases：https://docs.photoprism.app/getting-started/advanced/databases/
#
# 注意：
# - 變更後需重新啟動單元
# - originals / import 由 volume_dir 掛載；storage / database 由 TGDB instance_dir 管理

TZ=Asia/Taipei

# -----------------------------------------------------------------------------
# PhotoPrism 基本設定
# -----------------------------------------------------------------------------
PHOTOPRISM_ADMIN_USER=${admin_user}
PHOTOPRISM_ADMIN_PASSWORD=${admin_pass}
PHOTOPRISM_AUTH_MODE=password
PHOTOPRISM_SITE_URL=http://127.0.0.1:${host_port}/
PHOTOPRISM_DISABLE_TLS=true
PHOTOPRISM_DEFAULT_TLS=false
PHOTOPRISM_DEFAULT_LOCALE=zh-tw
PHOTOPRISM_HTTP_COMPRESSION=gzip

PHOTOPRISM_ORIGINALS_PATH=/photoprism/originals
PHOTOPRISM_IMPORT_PATH=/photoprism/import
PHOTOPRISM_STORAGE_PATH=/photoprism/storage

# -----------------------------------------------------------------------------
# MariaDB（PhotoPrism -> MariaDB）
# -----------------------------------------------------------------------------
PHOTOPRISM_DATABASE_DRIVER=mysql
PHOTOPRISM_DATABASE_SERVER=127.0.0.1:3306
PHOTOPRISM_DATABASE_NAME=photoprism
PHOTOPRISM_DATABASE_USER=${db_user}
PHOTOPRISM_DATABASE_PASSWORD=${db_pass}

# -----------------------------------------------------------------------------
# MariaDB 初始化（供 mariadb official image 使用）
# -----------------------------------------------------------------------------
MARIADB_AUTO_UPGRADE=1
MARIADB_INITDB_SKIP_TZINFO=1
MARIADB_DATABASE=photoprism
MARIADB_USER=${db_user}
MARIADB_PASSWORD=${db_pass}
MARIADB_ROOT_PASSWORD=${mariadb_root_password}

# -----------------------------------------------------------------------------
# 其他常用選填設定
# -----------------------------------------------------------------------------
#PHOTOPRISM_READONLY=false
#PHOTOPRISM_UPLOAD_NSFW=true
#PHOTOPRISM_DETECT_NSFW=false
#PHOTOPRISM_WORKERS=2
