# Infisical 環境變數（最小範本）
# 參考：
# - https://infisical.com/docs/self-hosting/deployment-options/docker-compose

# 對外網址（反代到 HTTPS 後請務必改為 https://...）
SITE_URL=http://127.0.0.1:${host_port}

# Infisical 需要的加密/驗證密鑰
ENCRYPTION_KEY=${encryption_key}
AUTH_SECRET=${auth_secret}

# PostgreSQL（供 postgres image 初始化）
POSTGRES_DB=infisical
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# Infisical 連線（同 pod 內可用 localhost）
DB_CONNECTION_URI=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/infisical
REDIS_URL=redis://127.0.0.1:6379

#（可選）SMTP（要啟用邀請/通知等功能請依上游文件設定）
#SMTP_HOST=
#SMTP_PORT=
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=

TZ=Asia/Taipei

