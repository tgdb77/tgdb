# -----------------------------------------------------------------------------
# slskd（slskd/slskd）環境變數範本
# -----------------------------------------------------------------------------
# 官方文件：
# - Docker：https://github.com/slskd/slskd/blob/master/docs/docker.md
# - 設定：https://github.com/slskd/slskd/blob/master/docs/config.md
# - 反代：https://github.com/slskd/slskd/blob/master/docs/reverse_proxy.md
#
# 注意：
# - 此檔案會由 systemd 讀取（EnvironmentFile），不會直接「掛載」到容器檔案系統。
# - slskd 的 YAML 設定檔會放在應用資料夾：/app/slskd.yml（宿主機對應 ${instance_dir}/app/slskd.yml）。
# - 修改後請重啟單元（依你的容器名稱調整）：
#   systemctl --user restart ${container_name}.container

# 時區
TZ=Asia/Taipei

# Web UI 認證（強烈建議使用強密碼；預設帳密是 slskd/slskd）
SLSKD_USERNAME=${web_user}
SLSKD_PASSWORD=${web_pass}

# Soulseek 帳號（必填）
SLSKD_SLSK_USERNAME=${slsk_user}
SLSKD_SLSK_PASSWORD=${slsk_pass}

# Soulseek 連入埠（需與 Quadlet PublishPort 一致）
SLSKD_SLSK_LISTEN_PORT=${listen_port}

# 建議由反向代理提供 HTTPS；若要啟用 slskd 內建自簽 HTTPS，可改成 false 並自行映射 5031
SLSKD_NO_HTTPS=true

# 是否允許從 Web UI 讀寫 slskd.yml（不建議公網暴露時啟用）
SLSKD_REMOTE_CONFIGURATION=false

# 是否允許從 Web UI 刪除 downloads/incomplete 檔案（安全風險較高，預設關閉）
SLSKD_REMOTE_FILE_MANAGEMENT=false

# 共享資料夾（以 ; 分隔多個，路徑需為容器內的絕對路徑；你需自行在 Quadlet 加 Volume 掛載）
#SLSKD_SHARED_DIR=/music;/ebooks
