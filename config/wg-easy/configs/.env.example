# wg-easy 環境變數
#
# 檔案位置：${instance_dir}/.env
# 官方文件：
# - Repo：https://github.com/wg-easy/wg-easy
# - Podman（nftables）：https://wg-easy.github.io/wg-easy/v15.0/examples/tutorials/podman-nft/
# - Optional Config：https://wg-easy.github.io/wg-easy/v15.1/advanced/config/optional-config/
# - Unattended Setup：https://wg-easy.github.io/wg-easy/v15.1/advanced/config/unattended-setup/
#
# 注意：
# - 變更後需重新啟動單元
# - 這裡先以 rootful + 本機 Web UI + 公開 UDP/51820 類型部署

TZ=Asia/Taipei

# -----------------------------------------------------------------------------
# Web UI / 基本設定
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=51821
INSECURE=true
DISABLE_IPV6=true

# -----------------------------------------------------------------------------
# Unattended Setup（首次初始化）
# -----------------------------------------------------------------------------
INIT_ENABLED=true
INIT_USERNAME=${init_user}
INIT_PASSWORD=${init_password}
INIT_HOST=${wg_host}
INIT_PORT=${wg_port}
INIT_DNS=1.1.1.1,1.0.0.1

# -----------------------------------------------------------------------------
# 其他常用選填設定
# -----------------------------------------------------------------------------
#LANG=zh
#WG_DEVICE=eth0
#WG_PERSISTENT_KEEPALIVE=25
#UI_TRAFFIC_STATS=true
#INIT_ALLOWED_IPS=0.0.0.0/0
