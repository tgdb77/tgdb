# Mailpit 環境變數
#
# 檔案位置：${instance_dir}/.env
# 參考：https://mailpit.axllent.org/docs/
#
# 注意：
# - 變更後需重啟單元
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器

# 持久化 SQLite 資料庫
MP_DATABASE=/data/mailpit.db

# 容器內監聽位址；通常不需要修改
MP_UI_BIND_ADDR=0.0.0.0:8025
MP_SMTP_BIND_ADDR=0.0.0.0:1025

# UI 顯示名稱
MP_LABEL=${container_name}

# 最多保留郵件數量
MP_MAX_MESSAGES=500

# 依時間自動清理郵件（範例：7d、48h）
#MP_MAX_AGE=7d

# 若要啟用 POP3，請先取消註解並同步在 Quadlet 加上對應的 PublishPort
#MP_POP3_BIND_ADDR=0.0.0.0:1110
