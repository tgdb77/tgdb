# -----------------------------------------------------------------------------
# Pydio Cells（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 預設只綁定本機回環；正式對外建議搭配 Nginx 反向代理與 HTTPS
# - 首次開啟 Web 介面時，請在安裝精靈使用下方 MySQL 連線資訊

TZ=Asia/Taipei

# Pydio Cells 服務監聽設定
CELLS_WORKING_DIR=/var/cells
CELLS_DATA=/data
CELLS_BIND=0.0.0.0:8080
CELLS_NO_TLS=1
CELLS_EXTERNAL=http://127.0.0.1:${host_port}

# Pydio Cells MySQL 連線資訊（同一 Pod 內）
PYDIO_DB_HOST=127.0.0.1
PYDIO_DB_PORT=3306
PYDIO_DB_NAME=cells
PYDIO_DB_USER=${db_user}
PYDIO_DB_PASSWORD=${db_pass}

# MySQL 初始化
MYSQL_ROOT_PASSWORD=${db_pass}
MYSQL_DATABASE=cells
