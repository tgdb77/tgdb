# SerpBear（TGDB 產生）
#
# 參考：
# - GitHub：https://github.com/towfiqi/serpbear
# - Docker Compose：https://raw.githubusercontent.com/towfiqi/serpbear/main/docker-compose.yml
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

USER=${admin_user}
PASSWORD=${admin_pass}
SECRET=${secret_key}
APIKEY=${api_key}
SESSION_DURATION=24
NEXT_PUBLIC_APP_URL=http://127.0.0.1:${host_port}

# Google Search Console（選填）
# SEARCH_CONSOLE_CLIENT_EMAIL=
# SEARCH_CONSOLE_PRIVATE_KEY=
