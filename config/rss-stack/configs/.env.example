# FreshRSS + RSSHub（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# === FreshRSS ===
# FreshRSS Docker 官方建議：設定排程（每 N 分鐘更新一次）
CRON_MIN=*/20

# （選用）若你有反代與 HTTPS，且遇到 URL/跳轉不正確，請依官方文件設定：
# - 反代 header（Host / X-Forwarded-Proto / X-Forwarded-For）
# - 或使用自訂 config（例如 config.custom.php）

# === RSSHub ===
NODE_ENV=production
PORT=1200

# （選用）CORS（若你確定需要再開）
# ALLOW_ORIGIN=

# （選用）Redis 快取（未配置則使用記憶體快取）
# CACHE_TYPE=redis
# REDIS_URL=redis://127.0.0.1:6379

