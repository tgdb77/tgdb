# Fider（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# 對外網址（反向代理/換域名時務必同步更新）
BASE_URL=http://127.0.0.1:${host_port}

# ---- PostgreSQL（同一個 Pod 內的 postgres 容器會使用）----
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=fider

# ---- 應用 DB 連線 ----
DATABASE_URL=postgres://${db_user}:${db_pass}@127.0.0.1:5432/fider?sslmode=disable

# 祕鑰（必填；部署時會由 TGDB 提示輸入/產生）
JWT_SECRET=${jwt_secret}

# ---- E-mail（必填）----測試用正式需註解
EMAIL_NOREPLY=noreply@example.com
EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_ENABLE_STARTTLS=false

# 改用你自己的 SMTP，請改成：
#EMAIL_SMTP_HOST=smtp.example.com
#EMAIL_SMTP_PORT=587
#EMAIL_SMTP_USERNAME=user@example.com
#EMAIL_SMTP_PASSWORD=your_password
#EMAIL_SMTP_ENABLE_STARTTLS=true

# 或改用 Mailgun / AWS SES（擇一即可；三選一）：
#EMAIL_MAILGUN_API=key-yourkeygoeshere
#EMAIL_MAILGUN_DOMAIN=yourdomain.com
#EMAIL_MAILGUN_REGION=US
#
#EMAIL_AWSSES_REGION=us-east-1
#EMAIL_AWSSES_ACCESS_KEY_ID=youraccesskeygoeshere
#EMAIL_AWSSES_SECRET_ACCESS_KEY=yoursecretkeygoeshere
