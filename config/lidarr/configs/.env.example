# -----------------------------------------------------------------------------
# Lidarr（LinuxServer.io）環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - https://docs.linuxserver.io/images/docker-lidarr/
# - TRaSH Guides Docker 路徑規劃

PUID=${user_id}
PGID=${group_id}
TZ=Asia/Taipei
UMASK=002

# 建議在 Lidarr 內使用：
# - Root Folder：/data/media/music
# - qBittorrent / completed：/data/torrents/music
# - Usenet：/data/usenet/complete/music
