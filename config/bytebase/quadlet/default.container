[Unit]
Description=Bytebase
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/bytebase/bytebase:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=bytebase
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:8080/tcp

Volume=${instance_dir}/data:/var/opt/bytebase

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
