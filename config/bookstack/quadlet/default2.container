[Unit]
Description=BookStack（MariaDB）
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/library/mariadb:11
#AutoUpdate=registry
ContainerName=${container_name}-mariadb
Label=app=bookstack
Label=tgdb_db=mariadb

Pod=${container_name}.pod

EnvironmentFile=${instance_dir}/.env

Volume=${instance_dir}/mysql:/var/lib/mysql

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
