# BookStack（TGDB 產生）
#
# 參考：
# - 官方安裝文件：https://www.bookstackapp.com/docs/admin/installation/
# - 官方命令文件：https://www.bookstackapp.com/docs/admin/commands/
# - LinuxServer 容器文件：https://docs.linuxserver.io/images/docker-bookstack/
#
# 注意：
# - 變更後需重新啟動單元
# - 若改變 APP_URL，依容器文件需另外執行 URL 更新命令

TZ=Asia/Taipei
PUID=${user_id}
PGID=${group_id}

# BookStack 核心設定
APP_URL=http://127.0.0.1:${host_port}
APP_KEY=

# 資料庫（BookStack -> MariaDB）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bookstackapp
DB_USERNAME=${db_user}
DB_PASSWORD=${db_pass}

# 若要啟用郵件/Webhook 非同步工作，可改成 database
#QUEUE_CONNECTION=database

# MariaDB 初始化
MARIADB_DATABASE=bookstackapp
MARIADB_USER=${db_user}
MARIADB_PASSWORD=${db_pass}
MARIADB_ROOT_PASSWORD=${mariadb_root_password}

# 其他選填設定（依官方文件按需補）
#APP_LANG=zh_TW
#MAIL_HOST=
#MAIL_PORT=587
#MAIL_USERNAME=
#MAIL_PASSWORD=
#MAIL_ENCRYPTION=tls
