# Apache Answer（TGDB 產生）
#
# 參考：
# - Installation：https://answer.apache.org/docs/installation
# - Environment Variables：https://answer.apache.org/docs/env
# - Download / Releases：https://answer.apache.org/download
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

AUTO_INSTALL=false
INSTALL_PORT=80

# PostgreSQL
DB_TYPE=postgres
DB_USERNAME=${db_user}
DB_PASSWORD=${db_pass}
DB_HOST=127.0.0.1:5432
DB_NAME=answer

# PostgreSQL official image 初始化
POSTGRES_DB=answer
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# 站台基本資訊
LANGUAGE=en-US

# 外部內容顯示策略
EXTERNAL_CONTENT_DISPLAY=ask_before_display

# ---- 其他選填設定 ----
#LOG_LEVEL=INFO
#LOG_PATH=/data/logs

# 若之後改用 MySQL，可改成：
#DB_TYPE=mysql
#DB_USERNAME=
#DB_PASSWORD=
#DB_HOST=127.0.0.1:3306
#DB_NAME=answer
