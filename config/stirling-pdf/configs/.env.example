# -----------------------------------------------------------------------------
# Stirling-PDF 環境變數範本
# -----------------------------------------------------------------------------
# 說明：
# - Stirling-PDF 本身可不使用 .env 直接啟動；此檔案提供常用項目範本
# - 修改後需重啟容器/單元才會生效
# - 注意：此檔案可能包含敏感設定，建議權限設為 600。
#
# 參考文件：
# - https://docs.stirlingpdf.com/
# -----------------------------------------------------------------------------

TZ=Asia/Taipei

# 是否啟用登入（建議：對外反代時請開啟）
SECURITY_ENABLELOGIN=true

# 若你要用域名/反向代理，建議補上根 URL（依你的實際網址調整）
# - 例：https://pdf.example.com
# - 反代後務必設定此值，否則部分連結/回呼可能不正確
#SYSTEM_ROOTURI=
