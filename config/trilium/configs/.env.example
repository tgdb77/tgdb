# -----------------------------------------------------------------------------
# Trilium（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - Trilium Docker 會將資料保存在 TRILIUM_DATA_DIR 指定的目錄

TZ=Asia/Taipei

# 官方 Docker image 預設的資料目錄
TRILIUM_DATA_DIR=/home/node/trilium-data

# 官方建議：若資料目錄擁有者需要對齊，可指定 UID/GID
USER_UID=${user_id}
USER_GID=${group_id}
