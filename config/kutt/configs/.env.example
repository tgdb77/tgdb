# Kutt（PostgreSQL + Redis）環境變數（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

# 必填：JWT_SECRET（用於簽發登入 token）
JWT_SECRET=${jwt_secret}

# 服務埠（容器內）
PORT=3000

# 顯示名稱與預設網域
SITE_NAME=Kutt
DEFAULT_DOMAIN=127.0.0.1:${host_port}

# 反代在 Nginx/Cloudflare 後面時通常要啟用；本機測試可保持 true
TRUST_PROXY=true

# PostgreSQL
DB_CLIENT=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=kutt
DB_USER=${db_user}
DB_PASSWORD=${db_pass}
DB_SSL=false

# Redis（快取 / Rate limit）
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=${db_pass}
REDIS_DB=0

# PostgreSQL（同一個 Pod 內的 postgres 容器會使用）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=kutt

# （選用）郵件功能（不啟用也能使用，但註冊/重設密碼等功能可能受限）
MAIL_ENABLED=false
#MAIL_HOST=
#MAIL_PORT=587
#MAIL_SECURE=true
#MAIL_USER=
#MAIL_PASSWORD=
#MAIL_FROM=

