# OpenSpeedTest（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# ---- 進階選項（大多數情境不需要）----
#
# 允許修改容器內的預設埠（3000/3001）；通常不建議，TGDB 只需要改 PublishPort 即可。
#CHANGE_CONTAINER_PORTS=True
#HTTP_PORT=3000
#HTTPS_PORT=3001
#
# 調整容器內執行使用者（依映像支援狀況）
#SET_USER=101
#
# 僅允許特定網域發送 CORS（以分號分隔；不要有空白）
#ALLOW_ONLY=domain1.com;domain2.com
#
# UI 顯示的伺服器名稱
#SET_SERVER_NAME=HOME-NAS
#
# Let's Encrypt（需公開可連線的網域與 80/443；rootless 通常無法綁 80/443，請自行評估 rootful 或反向代理）
#ENABLE_LETSENCRYPT=True
#DOMAIN_NAME=speedtest.example.com

