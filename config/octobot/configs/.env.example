# OctoBot 環境變數
#
# 檔案位置：${instance_dir}/.env
# 參考：https://www.octobot.cloud/en/guides/octobot-developers-environment/environment-variables
#
# 注意：
# - 請勿加入空白
# - 變更後需重啟單元

# -----------------------------------------------------------------------------
# Web 介面
# -----------------------------------------------------------------------------
# 覆寫預設監聽位址（預設 127.0.0.1）。若使用容器對外發布埠，建議設為 0.0.0.0。
WEB_ADDRESS=0.0.0.0
# 覆寫預設 Web 埠（預設 5001）。通常不需要改。
WEB_PORT=5001

# -----------------------------------------------------------------------------
# 時區（僅部分映像會使用）
# -----------------------------------------------------------------------------
TZ=Asia/Taipei

# -----------------------------------------------------------------------------
# Tentacles 下載（選填）
# -----------------------------------------------------------------------------
# 覆寫 tentacles 套件安裝用的 tag（例如 latest）。
#TENTACLES_URL_TAG=

# -----------------------------------------------------------------------------
# 交易所連線（選填）
# -----------------------------------------------------------------------------
#DEFAULT_REQUEST_TIMEOUT=20000
#ENABLE_CCXT_VERBOSE=False
#ENABLE_CCXT_RATE_LIMIT=True

