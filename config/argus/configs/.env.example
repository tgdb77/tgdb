# Argus 環境變數（可選）
#
# 檔案位置：${instance_dir}/.env
# 文件：https://github.com/release-argus/Argus（README：Command-line arguments）
#
# 注意：
# - 檔案權限建議維持 600，避免密碼外洩
# - 設定完成後請重啟單元

# 日誌
#ARGUS_LOG_LEVEL=INFO
#ARGUS_LOG_TIMESTAMPS=1

# Web UI Basic Auth（預設啟用）
ARGUS_WEB_BASIC_AUTH_USERNAME=${user_name}
ARGUS_WEB_BASIC_AUTH_PASSWORD=${pass_word}
