# Chatwoot（Docker / Quadlet）
# 提醒：此檔案會被寫入 instance 的 ${instance_dir}/.env（請自行保管）。

RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker

# 服務對外網址（⚠️ 若要對外公開，務必改成 https://你的域名）
FRONTEND_URL=http://127.0.0.1:${host_port}

# Rails 必填
SECRET_KEY_BASE=${secret_key_base}

# 第一次註冊管理員（建議：註冊完成後改回 false）
ENABLE_ACCOUNT_SIGNUP=false

# --- PostgreSQL ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=${db_user}
POSTGRES_PASSWORD=${db_pass}

# 給 PostgreSQL 容器用（同一份 .env）
POSTGRES_DB=chatwoot
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=${redis_pass}
REDIS_URL=redis://:${redis_pass}@127.0.0.1:6379

# --- 自動初始化（部署後）---
CHATWOOT_AUTO_PREPARE_DB=1
CHATWOOT_AUTO_PREPARE_DB_FORCE=0
CHATWOOT_AUTO_PREPARE_DB_TIMEOUT=180

# --- 郵件（按需設定）---
#MAILER_SENDER_EMAIL=Chatwoot <chatwoot@example.com>
#SMTP_ADDRESS=
#SMTP_PORT=
#SMTP_USERNAME=
#SMTP_PASSWORD=
#SMTP_DOMAIN=
#SMTP_AUTHENTICATION=plain
#SMTP_ENABLE_STARTTLS_AUTO=true
