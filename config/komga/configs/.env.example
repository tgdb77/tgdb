# Komga（TGDB 產生）
#
# 參考：
# - Docker：https://komga.org/docs/installation/docker
# - Configuration：https://komga.org/docs/installation/configuration
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# 若遇到記憶體不足（OutOfMemoryException），可依官方文件調整：
#JAVA_TOOL_OPTIONS=-Xmx2g

# 若之後要改埠號 / 子路徑 / 反向代理，可依官方 configuration 方式補上：
#SERVER_PORT=25600
#SERVER_SERVLET_CONTEXT_PATH=/komga
