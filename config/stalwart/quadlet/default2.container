[Unit]
Description=snappymail
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/djmaze/snappymail:latest
#AutoUpdate=registry
ContainerName=${container_name}-snappymail
Label=app=stalwart

Pod=${container_name}.pod

Volume=${instance_dir}/snappymail:/var/lib/snappymail
EnvironmentFile=${instance_dir}/.env

[Service]
Restart=on-failure
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
