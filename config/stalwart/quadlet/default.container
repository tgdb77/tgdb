[Unit]
Description=stalwart
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/stalwartlabs/stalwart:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=stalwart

Pod=${container_name}.pod

Volume=${instance_dir}/stalwart:/opt/stalwart
EnvironmentFile=${instance_dir}/.env

[Service]
Restart=on-failure
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
