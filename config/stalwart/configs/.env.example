# -----------------------------------------------------------------------------
# Stalwart Mail Server 環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案包含管理員密碼，建議權限設為 600。

TZ=Asia/Taipei

# 初次啟動會使用此密碼建立 fallback-admin（帳號固定為 admin）
# 若已產生 config.toml，後續修改密碼請以 Stalwart 管理介面/CLI 或直接修改設定為準。
STALWART_ADMIN_PASSWORD=${STALWART_ADMIN_PASSWORD}

# SnappyMail Webmail
# 管理介面帳號固定為 admin
# 管理密碼由 SnappyMail 自動產生，會寫入：admin_password.txt
