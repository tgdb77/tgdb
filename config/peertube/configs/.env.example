# PeerTube（官方 Docker）範本
# 參考：
# - 官方 Docker 安裝指引：https://docs.joinpeertube.org/install/docker
# - 官方 production compose：https://github.com/Chocobozzz/PeerTube/blob/master/support/docker/production/docker-compose.yml
# - 官方環境變數對照：https://github.com/Chocobozzz/PeerTube/blob/master/support/docker/production/config/custom-environment-variables.yaml
#
# 說明：
# - 此檔案同時提供 PeerTube、PostgreSQL、Redis 三個容器共用。
# - 預設以保守、安全為主：註冊關閉、聯絡表單關閉、SMTP 先保留本機占位設定。

TZ=Asia/Taipei

# --- PeerTube 站點基本設定 ---
PEERTUBE_INSTANCE_NAME="${site_name}"
PEERTUBE_WEBSERVER_HOSTNAME=${app_domain}
PEERTUBE_WEBSERVER_PORT=443
PEERTUBE_WEBSERVER_HTTPS=true
PEERTUBE_TRUST_PROXY=["127.0.0.1","loopback"]
PEERTUBE_SECRET=${peertube_secret}
PEERTUBE_ADMIN_EMAIL=${admin_email}
PT_INITIAL_ROOT_PASSWORD=${admin_pass}

# 安全預設：先關閉註冊與聯絡表單；待你完成 HTTPS / SMTP 後再自行開啟。
PEERTUBE_SIGNUP_ENABLED=false
PEERTUBE_CONTACT_FORM_ENABLED=false

# 預設先不啟用直播（RTMP 1935）；若要啟用請同步調整 Pod 對外埠。
PEERTUBE_LIVE_ENABLED=false
PEERTUBE_LIVE_RTMP_ENABLED=false

# --- PostgreSQL（PeerTube 連線） ---
PEERTUBE_DB_HOSTNAME=127.0.0.1
PEERTUBE_DB_PORT=5432
PEERTUBE_DB_NAME=peertube
PEERTUBE_DB_USERNAME=${db_user}
PEERTUBE_DB_PASSWORD=${db_pass}
PEERTUBE_DB_SSL=false
POSTGRES_DB=peertube
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# --- Redis ---
PEERTUBE_REDIS_HOSTNAME=127.0.0.1
PEERTUBE_REDIS_PORT=6379
PEERTUBE_REDIS_AUTH=${redis_pass}
REDIS_PASSWORD=${redis_pass}

# --- SMTP ---
# 預設僅放保守占位值。若要寄送通知、密碼重設或開放註冊，請改成你自己的 SMTP。
PEERTUBE_SMTP_HOSTNAME=127.0.0.1
PEERTUBE_SMTP_PORT=25
PEERTUBE_SMTP_USERNAME=
PEERTUBE_SMTP_PASSWORD=
PEERTUBE_SMTP_TLS=false
PEERTUBE_SMTP_DISABLE_STARTTLS=true
PEERTUBE_SMTP_FROM=noreply@${app_domain}

# 常見可自行加開的項目（預設不主動啟用）：
#PEERTUBE_TRANSCODING_ENABLED=true
#PEERTUBE_OBJECT_STORAGE_ENABLED=false
