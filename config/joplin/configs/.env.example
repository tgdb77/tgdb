# Joplin Server（PostgreSQL）環境變數（TGDB 產生）
#
# 參考：
# - https://github.com/laurent22/joplin
# - 官方 docker-compose.server.yml
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題
# - 若之後改用域名 / HTTPS / 子路徑，請同步修改 APP_BASE_URL

# Joplin Server
APP_PORT=22300
APP_BASE_URL=http://127.0.0.1:${host_port}
DB_CLIENT=pg
# 注意：Joplin 在 Docker 內會將 localhost/127.0.0.1 改寫成 host.docker.internal，
# TGDB 已在 Quadlet 內把 host.docker.internal 固定映射到 127.0.0.1，
# 讓它能連回同 Pod 內的 PostgreSQL。
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DATABASE=joplin
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# PostgreSQL（供 postgres official image 初始化）
POSTGRES_DB=joplin

# （選用）若要啟用郵件通知，再自行填入以下設定
#MAILER_ENABLED=1
#MAILER_HOST=smtp.example.com
#MAILER_PORT=587
#MAILER_SECURITY=starttls
#MAILER_AUTH_USER=
#MAILER_AUTH_PASSWORD=
#MAILER_NOREPLY_NAME=Joplin
#MAILER_NOREPLY_EMAIL=noreply@example.com
