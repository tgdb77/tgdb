# -----------------------------------------------------------------------------
# Open WebUI 環境變數範本
# -----------------------------------------------------------------------------
# 上游參考：
# - 官方 env 範本：
#   https://github.com/open-webui/open-webui/blob/main/.env.example
# - 環境變數總覽：
#   https://docs.openwebui.com/reference/env-configuration/
#
# 說明：
# 1. TGDB 預設把宿主機 127.0.0.1:${host_port} 映射到容器內 8080。
# 2. 若你要讓 Open WebUI 連到宿主機上的 Ollama，容器內請使用
#    host.containers.internal，不要填 127.0.0.1。
# 3. WEBUI_SECRET_KEY 建議固定，避免重建容器後 session / token 失效。

# 容器內連到宿主機 Ollama 的預設位址。
#OLLAMA_BASE_URL=http://host.containers.internal:11434

#RAG 向量搜尋根據需求開啟
ENABLE_RAG_WEB_SEARCH=false
RAG_EMBEDDING_ENGINE=
OFFLINE_MODE=true

# 若你要接 OpenAI 相容 API，可取消註解後填入。
#OPENAI_API_BASE_URL=
#OPENAI_API_KEY=

# 啟用 WebUI 登入驗證；上游預設為 true。
WEBUI_AUTH=true

# 固定 WebUI 密鑰，避免重建容器後登入狀態與 token 失效。
WEBUI_SECRET_KEY=${webui_secret_key}

# 首次啟動若要用環境變數直接建立管理員，可取消註解。
#WEBUI_ADMIN_EMAIL=
#WEBUI_ADMIN_PASSWORD=
#WEBUI_ADMIN_NAME=Admin

# 若你要完全停用匿名分析 / 遙測，維持以下設定即可。
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# 只有在你需要前端跨來源存取時才需要改；一般本機 / 反代情境可先不設。
#CORS_ALLOW_ORIGIN=*
