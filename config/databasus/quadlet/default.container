[Unit]
Description=Databasus
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/databasus/databasus:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=databasus
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:4005/tcp

EnvironmentFile=${instance_dir}/.env

Volume=${instance_dir}/data:/databasus-data

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
