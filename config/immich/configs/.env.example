# =============================================================================
# IMMICH 環境變數設定
# =============================================================================

# 必須設定的變數
# TGDB 部署預設會自動填入以下路徑
UPLOAD_LOCATION=/usr/src/app/upload
DB_DATA_LOCATION=/var/lib/postgresql/data

# 資料庫設定
DB_DATABASE_NAME=immich
DB_USERNAME=${user_name}
DB_PASSWORD=${pass_word}
DB_HOSTNAME=localhost
DB_PORT=5432

# Redis 設定
REDIS_PASSWORD=${pass_word}
REDIS_HOSTNAME=localhost
REDIS_PORT=6379

# JWT 安全金鑰（請修改為隨機字串）
JWT_SECRET=${jwt_secret}

# 外部存取設定
IMMICH_EXTERNAL_URL=http://localhost:${host_port}
HTTP_PORT=2283

# 時區設定
TZ=Asia/Taipei

# 兼容 postgres 映像常用環境變數（讓 DB_* 與 POSTGRES_* 都能同時使用）
POSTGRES_DB=immich
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}

# =============================================================================
# 可選設定
# =============================================================================

# 自訂儲存位置（可選）
# THUMB_LOCATION=/path/to/thumbs
# ENCODED_VIDEO_LOCATION=/path/to/encoded-video
# PROFILE_LOCATION=/path/to/profile
# BACKUP_LOCATION=/path/to/backups

# 外部資料庫設定（如果使用外部 PostgreSQL）
# DB_HOSTNAME=your_postgres_host
# DB_PORT=5432
# DB_URL='postgresql://immich:your_password@your_host:5432/immich'

# Redis 設定（如果使用外部 Redis）
# REDIS_HOSTNAME=your_redis_host
# REDIS_PORT=6379
# REDIS_DB_INDEX=0

# =============================================================================
# 硬體加速相關環境變數
# =============================================================================

# NVIDIA GPU 設定（多 GPU 設定）
# MACHINE_LEARNING_DEVICE_IDS=0,1
# MACHINE_LEARNING_WORKERS=2

# ARM NN 設定（可選，提升效能但可能略降低精度）
# MACHINE_LEARNING_ANN_FP16_TURBO=true

# RKNN 設定（適用於 Rockchip SoC 如 RK3576, RK3588）
# MACHINE_LEARNING_RKNN_THREADS=3

# =============================================================================
# 效能調校（可選）
# =============================================================================

# 並行處理執行緒數（根據您的 CPU 核心數調整）
IMMICH_JOB_MAIN_THREAD_COUNT=1
IMMICH_JOB_SIDE_CONVERSION_THREAD_COUNT=1
IMMICH_JOB_METADATA_THREAD_COUNT=1
IMMICH_JOB_NEW_MEDIA_THREAD_COUNT=1
IMMICH_JOB_OBJECT_TAGGING_THREAD_COUNT=1
IMMICH_JOB_FACE_DETECTION_THREAD_COUNT=1
IMMICH_JOB_THUMBNAIL_THREAD_COUNT=1

# 功能開關
IMMICH_FEATURE_EXTERNAL_EDITOR_ENABLED=false
