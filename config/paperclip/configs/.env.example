# Paperclip 環境變數（TGDB 產生）
#
# 參考：
# - 官方文件：https://paperclip.ing/docs/
# - Docker 說明：https://github.com/paperclipai/paperclip/blob/master/doc/DOCKER.md
#
# 注意：
# - 變更後需重新啟動單元
# - 預設僅綁定 127.0.0.1；正式對外建議搭配 Nginx / HTTPS 反向代理
# - 這裡採官方 quickstart 類型的單容器部署，資料會持久化到 /paperclip

TZ=Asia/Taipei
HOST=0.0.0.0
PORT=3100
SERVE_UI=true

# -----------------------------------------------------------------------------
# Paperclip 基本設定
# -----------------------------------------------------------------------------
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_PUBLIC_URL=http://127.0.0.1:${host_port}
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
BETTER_AUTH_SECRET=${better_auth_secret}

# 讓容器內 node 使用與目前使用者相同的 UID / GID，避免寫入卷權限混亂
USER_UID=${user_id}
USER_GID=${group_id}

# -----------------------------------------------------------------------------
# LLM / 供應商設定（依需求自行填寫）
# -----------------------------------------------------------------------------
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#OPENROUTER_API_KEY=
#GOOGLE_GENERATIVE_AI_API_KEY=
#XAI_API_KEY=
#MISTRAL_API_KEY=

# 若你要使用 OpenCode / Sandbox 相關能力，可再依官方文件補上額外設定
#OPENCODE_ALLOW_ALL_MODELS=true
