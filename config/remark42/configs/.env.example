# -----------------------------------------------------------------------------
# Remark42（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 若要正式對外提供服務，請將 REMARK_URL 改成實際 HTTPS 網址

TIME_ZONE=Asia/Taipei

# Remark42 對外網址
REMARK_URL=http://127.0.0.1:${host_port}

# 站點識別字，前端嵌入時的 site_id 需與此值一致
SITE=${site_id}

# 驗證/Session 用密鑰
SECRET=${secret}

# 保守起點：先允許匿名登入，方便完成最小可用部署
AUTH_ANON=true

# 資料預設保存在 /srv/var；已由 TGDB 掛載到實例目錄
STORE_BOLT_PATH=/srv/var

# 正式環境建議維持 false
DEBUG=false

# 若要嵌入與 Remark42 不同的網域，請依官方文件調整：
# ALLOWED_HOSTS="'self',https://example.com"
# AUTH_SAME_SITE=none
#
# 若要改用 Email/OAuth，請依官方文件補齊對應參數，例如：
# AUTH_EMAIL_ENABLE=true
# AUTH_GITHUB_CID=
# AUTH_GITHUB_CSEC=
