# -----------------------------------------------------------------------------
# Odoo（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# Odoo 官方 entrypoint 會用這組資料連同一 Pod 內的 PostgreSQL
HOST=127.0.0.1
PORT=5432
USER=${db_user}
PASSWORD=${db_pass}

# PostgreSQL 初始化（官方文件建議保留預設資料庫 postgres）
POSTGRES_DB=postgres
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
PGDATA=/var/lib/postgresql/data/pgdata
