[Unit]
Description=RedisInsight
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/redis/redisinsight:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=dbdmin

PublishPort=127.0.0.1:${host_port}:5540/tcp

Network=tgdb.network

User=0
EnvironmentFile=${instance_dir}/.env
Volume=${instance_dir}/data:/data

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
