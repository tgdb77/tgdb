# Hemmelig（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei
NODE_ENV=production

# 資料庫（預設使用 SQLite；檔案會寫到 instance_dir/database）
DATABASE_URL=file:/app/database/hemmelig.db

# Better Auth（必填；部署時會由 TGDB 提示輸入/產生）
BETTER_AUTH_SECRET=${auth_secret}

# 對外網址（反向代理/換域名時務必同步更新）
BETTER_AUTH_URL=http://127.0.0.1:${host_port}
HEMMELIG_BASE_URL=http://127.0.0.1:${host_port}

# 是否允許使用者註冊（預設 true；建議完成初始化後在 UI 內視需求關閉）
#HEMMELIG_ALLOW_REGISTRATION=true

# 文字上限（KB；預設 1024）
#HEMMELIG_MAX_TEXT_SIZE=1024

# 檔案上限（MB；預設 200）
#HEMMELIG_FILE_SIZE_LIMIT=200

