# -----------------------------------------------------------------------------
# Donetick（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - Donetick 會讀取 /config/selfhosted.yaml 作為自託管設定檔。
# - 目前預設使用 SQLite，資料庫檔案保存於 ${instance_dir}/data/donetick.db。

# 啟用自託管模式
DT_ENV=selfhosted

# SQLite 資料庫位置（容器內路徑）
DT_SQLITE_PATH=/donetick-data/donetick.db

# 時區
TZ=Asia/Taipei
