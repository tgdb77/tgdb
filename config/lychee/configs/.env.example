# Lychee（TGDB 產生）
#
# 參考：
# - 官方 compose：https://raw.githubusercontent.com/LycheeOrg/Lychee/master/docker-compose.yaml
# - 官方 repo：https://github.com/LycheeOrg/Lychee
#
# 注意：
# - 此整合已對齊 Lychee 主倉庫官方 compose 路線
# - 變更後需重新啟動單元

PUID=${user_id}
PGID=${group_id}
PHP_TZ=Asia/Taipei
TIMEZONE=Asia/Taipei

APP_NAME=Lychee
APP_ENV=production
APP_DEBUG=false
APP_URL=http://127.0.0.1:${host_port}
APP_KEY=

# 資料庫（Lychee -> MariaDB）
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lychee
DB_USERNAME=${db_user}
DB_PASSWORD=${db_pass}
DB_ROOT_PASSWORD=${db_root_password}

# 給 MariaDB 容器使用
MYSQL_DATABASE=lychee
MYSQL_USER=${db_user}
MYSQL_PASSWORD=${db_pass}
MYSQL_ROOT_PASSWORD=${db_root_password}

# Redis（快取 / queue）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
