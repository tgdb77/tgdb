# Jenkins（TGDB 產生）
#
# 參考：
# - 官方 Docker README：https://github.com/jenkinsci/docker
# - Jenkins Docker 安裝文件：https://www.jenkins.io/doc/book/installing/docker/
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# ---- 常用選項（預設可留空）----
# Jenkins 啟動參數（例如子路徑：--prefix=/jenkins）
#JENKINS_OPTS=

# Jenkins JVM 參數（建議優先用這個，而不是 JAVA_OPTS）
#JENKINS_JAVA_OPTS=

# 其他 Java 工具通用 JVM 參數
#JAVA_OPTS=

# 若你需要啟用 inbound agent TCP，請自行取消註解並與 Quadlet 內的第二條 PublishPort 保持一致。
#JENKINS_SLAVE_AGENT_PORT=${agent_port}

# 若你需要保留 /usr/share/jenkins/ref/init.groovy.d 的預設內容，可考慮啟用：
#PRE_CLEAR_INIT_GROOVY_D=true
