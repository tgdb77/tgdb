# -----------------------------------------------------------------------------
# ChangeDetection.io 環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案可能包含敏感設定，建議權限設為 600。
#
# 修改後需重啟服務才會生效：
# - systemctl --user restart <name>.service（多單元時請改用「更新並重啟」或逐一重啟）

TZ=Asia/Taipei

# 主服務
PORT=5000
LOGGER_LEVEL=INFO
PLAYWRIGHT_DRIVER_URL=ws://127.0.0.1:3000
HIDE_REFERER=true
FETCH_WORKERS=10

# 瀏覽器容器（sockpuppetbrowser / Playwright）
SCREEN_WIDTH=1920
SCREEN_HEIGHT=1024
MAX_CONCURRENT_CHROME_PROCESSES=10
