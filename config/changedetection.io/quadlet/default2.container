[Unit]
Description=browser-sockpuppet-chrome
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/dgtlmoon/sockpuppetbrowser:latest
#AutoUpdate=registry
ContainerName=${container_name}-browser
Label=app=changedetection.io

Pod=${container_name}.pod

AddCapability=SYS_ADMIN
EnvironmentFile=${instance_dir}/.env

[Service]
Restart=on-failure
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
