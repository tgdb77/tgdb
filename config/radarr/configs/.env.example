# -----------------------------------------------------------------------------
# Radarr（LinuxServer.io）環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - https://docs.linuxserver.io/images/docker-radarr/
# - TRaSH Guides Docker 路徑規劃

PUID=${user_id}
PGID=${group_id}
TZ=Asia/Taipei
UMASK=002

# 建議在 Radarr 內使用：
# - Root Folder：/data/media/movies
# - qBittorrent / completed：/data/torrents/movies
# - Usenet：/data/usenet/complete/movies
