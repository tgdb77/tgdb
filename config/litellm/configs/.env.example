# LiteLLM（TGDB 產生）
# 參考：
# - https://docs.litellm.ai/docs/proxy/deploy
# - https://docs.litellm.ai/docs/proxy/quick_start
#
# 本範本使用官方 Docker image + config.yaml 模式。
# 你可以把 API Key 放在這裡，再於 config.yaml 用 os.environ/ENV_NAME 讀取。

LITELLM_LOG=INFO

# TGDB 自動產生的管理金鑰（供 Proxy 與 /ui 管理面板使用）
LITELLM_MASTER_KEY=${master_key}

# PostgreSQL（同一個 Pod 內的 postgres 容器）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=litellm
DATABASE_URL=postgres://${db_user}:${db_pass}@127.0.0.1:5432/litellm

# 若你使用 OpenAI，可取消註解並填入：
#OPENAI_API_KEY=

# 若你使用 Anthropic，可取消註解並填入：
#ANTHROPIC_API_KEY=
