# -----------------------------------------------------------------------------
# MongoDB（共享資料庫）設定範本
# -----------------------------------------------------------------------------
# 參考：
# - 官方 Docker Hub：https://hub.docker.com/_/mongo
# - 官方 repo：https://github.com/docker-library/mongo
#
# 注意：
# - 此檔案包含密碼，建議權限設為 600。
# - 官方 image 說明：root 帳號 / 密碼只會在資料目錄首次初始化時生效。
#
# 使用情境（Headscale / Tailscale 內網跨機共用）：
# - 在「資料庫主機」部署 mongo app（預設只綁 127.0.0.1）
# - 透過「Headscale → Tailnet 服務埠轉發」把 TCP/<db_port> 轉發出去
# - 其他機器上的服務用 mongodb://<user>:<pass>@<host>:<port>/admin?authSource=admin 連入

MONGO_INITDB_ROOT_USERNAME=${MONGO_INITDB_ROOT_USERNAME}
MONGO_INITDB_ROOT_PASSWORD=${MONGO_INITDB_ROOT_PASSWORD}

# 若你有 init scripts 需要預設資料庫名，可自行取消註解：
#MONGO_INITDB_DATABASE=app
