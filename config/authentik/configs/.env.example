# -----------------------------------------------------------------------------
# 基礎配置
# -----------------------------------------------------------------------------
# 必需：Authentik 金鑰（請產生一個新的）
AUTHENTIK_SECRET_KEY=${secret_key}
# 版本標籤（可選，預設使用 latest）
AUTHENTIK_TAG=2025.10.3
# -----------------------------------------------------------------------------
# 連接埠配置
# -----------------------------------------------------------------------------
# HTTP 連接埠（可選，預設 9000）
AUTHENTIK_HTTP_PORT=9000
# HTTPS 連接埠（可選，預設 9443）
AUTHENTIK_HTTPS_PORT=9443
# HTTP 連接埠綁定位址（可選，預設 0.0.0.0）
AUTHENTIK_HTTP_HOST=0.0.0.0
# -----------------------------------------------------------------------------
# 資料庫配置 - PostgreSQL
# -----------------------------------------------------------------------------
# 資料庫主機
AUTHENTIK_POSTGRESQL__HOST=localhost
# 資料庫連接埠
AUTHENTIK_POSTGRESQL__PORT=5432
# 資料庫使用者名稱
AUTHENTIK_POSTGRESQL__USER=${user_name}
# 資料庫密碼
AUTHENTIK_POSTGRESQL__PASSWORD=${pass_word}
# 資料庫名稱
AUTHENTIK_POSTGRESQL__NAME=authentik
# 資料庫連線池大小（可選，預設 40）
AUTHENTIK_POSTGRESQL__POOL_SIZE=40
# 資料庫 SSL 模式（可選，預設 prefer）
AUTHENTIK_POSTGRESQL__SSLMODE=prefer
# -----------------------------------------------------------------------------
# 郵件配置
# -----------------------------------------------------------------------------
# 郵件伺服器主機
# AUTHENTIK_EMAIL__HOST=smtp.gmail.com
# 郵件伺服器連接埠
# AUTHENTIK_EMAIL__PORT=587
# 郵件使用者名稱
# AUTHENTIK_EMAIL__USERNAME=your-email@gmail.com
# 郵件密碼
# AUTHENTIK_EMAIL__PASSWORD=your-app-password
# 郵件寄件人
# AUTHENTIK_EMAIL__FROM=authentik@your-domain.com
# 使用 TLS
# AUTHENTIK_EMAIL__USE_TLS=true
# 使用 SSL
# AUTHENTIK_EMAIL__USE_SSL=false
# 郵件超時時間（秒）
# AUTHENTIK_EMAIL__TIMEOUT=30
# -----------------------------------------------------------------------------
# 安全性配置
# -----------------------------------------------------------------------------
# 預設令牌持續時間（秒）
AUTHENTIK_DEFAULT_TOKEN_DURATION=86400
# 錯誤回報設定
AUTHENTIK_ERROR_REPORTING__ENABLED=false
# 錯誤回報環境
AUTHENTIK_ERROR_REPORTING__ENVIRONMENT=production
# 藍圖配置
AUTHENTIK_BLUEPRINTS__INSECURE_API=false
# -----------------------------------------------------------------------------
# 日誌配置
# -----------------------------------------------------------------------------
# 日誌等級（debug, info, warning, error）
AUTHENTIK_LOG_LEVEL=info
# JSON 格式日誌
AUTHENTIK_LOG_JSON=false
# 控制台日誌顏色
AUTHENTIK_LOG_COLOR=true
# 顯示請求 ID
AUTHENTIK_LOG_SHOW_REQUEST_ID=true
# -----------------------------------------------------------------------------
# 效能配置
# -----------------------------------------------------------------------------
# 啟用效能監控
AUTHENTIK_PERFORMANCE__ENABLED=true
# 傳送效能數據
AUTHENTIK_PERFORMANCE__SEND_ANONYMOUS_USAGE_STATS=false

# -----------------------------------------------------------------------------
# PostgreSQL 初始化（供 postgres:16-alpine entrypoint 使用）
# -----------------------------------------------------------------------------
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}
POSTGRES_DB=authentik
# -----------------------------------------------------------------------------
# Prometheus 監控（可選）
# -----------------------------------------------------------------------------
# 啟用 Prometheus 端點
# AUTHENTIK_METRICS__ENABLED=true
# Prometheus 端口
# AUTHENTIK_METRICS__PORT=9300
# Prometheus 綁定位址
# AUTHENTIK_METRICS__HOST=0.0.0.0
# -----------------------------------------------------------------------------
# 物件儲存配置（可選，用於檔案儲存）
# -----------------------------------------------------------------------------
# S3 儲存設定範例
# AUTHENTIK_S3__ACCESS_KEY=your-access-key
# AUTHENTIK_S3__SECRET_KEY=your-secret-key
# AUTHENTIK_S3__BUCKET=authentik-files
# AUTHENTIK_S3__ENDPOINT=https://s3.amazonaws.com
# AUTHENTIK_S3__REGION=us-east-1
# Azure 儲存設定範例
# AUTHENTIK_AZURE__ACCOUNT_NAME=your-account-name
# AUTHENTIK_AZURE__ACCOUNT_KEY=your-account-key
# AUTHENTIK_AZURE__CONTAINER_NAME=authentik-files
# -----------------------------------------------------------------------------
# 外部資料庫配置（可選，用於進階設定）
# -----------------------------------------------------------------------------
# 外部資料庫主機
# AUTHENTIK_EXTERNAL_DB__HOST=external-db-host
# 外部資料庫連接埠
# AUTHENTIK_EXTERNAL_DB__PORT=3306
# 外部資料庫使用者名稱
# AUTHENTIK_EXTERNAL_DB__USER=external-user
# 外部資料庫密碼
# AUTHENTIK_EXTERNAL_DB__PASSWORD=external-password
# 外部資料庫名稱
# AUTHENTIK_EXTERNAL_DB__NAME=external_db
# -----------------------------------------------------------------------------
# 遠端調試（僅開發環境使用）
# -----------------------------------------------------------------------------
# 啟用遠端偵錯
# AUTHENTIK_REMOTE_DEBUG__ENABLED=false
# 遠端偵錯連接埠
# AUTHENTIK_REMOTE_DEBUG__PORT=7337
# 遠端偵錯主機
# AUTHENTIK_REMOTE_DEBUG__HOST=0.0.0.0
# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------
# 停用嵌入式 outpost（如果使用外部 outpost）
# AUTHENTIK_EMBEDDED_OUTPOSTS__ENABLED=true
# 禁用伺服器-side 主題
# AUTHENTIK_DISABLE_STARTUP_ANALYTICS=false
# 停用更新檢查
# AUTHENTIK_DISABLE_UPDATE_CHECK=false
# 信任代理頭（用於反向代理）
# AUTHENTIK_SET_X_FORWARDED_HEADERS
# 頭部固定金鑰（用於安全）
# AUTHENTIK_HEADER_FIX_KEY=your-header-fix-key
