# -----------------------------------------------------------------------------
# Web-Check（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 預設不需要任何設定即可執行；以下多數值都屬於可選項

TZ=Asia/Taipei

# Web-Check 服務連接埠（容器內）
PORT=3000

# API 行為設定（全部可選）
# API_ENABLE_RATE_LIMIT=true
# API_TIMEOUT_LIMIT=10000
# API_CORS_ORIGIN=example.com
# DISABLE_GUI=false
# REACT_APP_API_ENDPOINT=/api

# 若容器內 Chromium 路徑需自訂時再填
# CHROME_PATH=/usr/bin/chromium

# 可選 API Keys（僅在需要對應進階檢查時再填）
# GOOGLE_CLOUD_API_KEY=
# REACT_APP_SHODAN_API_KEY=
# REACT_APP_WHO_API_KEY=
# SECURITY_TRAILS_API_KEY=
# CLOUDMERSIVE_API_KEY=
# TRANCO_USERNAME=
# TRANCO_API_KEY=
# URL_SCAN_API_KEY=
# BUILT_WITH_API_KEY=
# TORRENT_IP_API_KEY=
