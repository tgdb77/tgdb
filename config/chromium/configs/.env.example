# -----------------------------------------------------------------------------
# Chromium（jlesage/docker-chromium）環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案可能包含密碼或敏感設定，建議權限設為 600。
#
# 修改後需重啟服務才會生效：
# - systemctl --user restart ${container_name}.service

# 基本
USER_ID=${user_id}
GROUP_ID=${user_id}
TZ=Asia/Taipei
#SUP_GROUP_IDS=44,109
#UMASK=0022

# 中文顯示
ENABLE_CJK_FONT=1
LANG=zh_TW.UTF-8

# 行為/除錯
#KEEP_APP_RUNNING=1
#CONTAINER_DEBUG=1
#APP_NICENESS=0
#INSTALL_PACKAGES=curl tzdata
#PACKAGES_MIRROR=

# 顯示/外觀
#DISPLAY_WIDTH=1920
#DISPLAY_HEIGHT=1080
#DARK_MODE=1

# Web 功能（noVNC）
#WEB_AUDIO=1
#WEB_FILE_MANAGER=1
#WEB_FILE_MANAGER_ALLOWED_PATHS=AUTO
#WEB_FILE_MANAGER_DENIED_PATHS=
#WEB_NOTIFICATION=1  # 需要 HTTPS（SECURE_CONNECTION=1）

# 安全性（注意：WEB_AUTHENTICATION 需要 HTTPS）
#SECURE_CONNECTION=1
#SECURE_CONNECTION_VNC_METHOD=SSL
#SECURE_CONNECTION_CERTS_CHECK_INTERVAL=60
#WEB_AUTHENTICATION=1
#WEB_AUTHENTICATION_USERNAME=admin
#WEB_AUTHENTICATION_PASSWORD=${pass_word}
#WEB_AUTHENTICATION_TOKEN_VALIDITY_TIME=24
#WEB_LOCALHOST_ONLY=1
#VNC_LOCALHOST_ONLY=1
# VNC 密碼（必填）
VNC_PASSWORD=${pass_word}

# Chromium 專用：以「應用模式」開啟指定網站（無網址列/分頁）
#CHROMIUM_APP_URL=https://example.com
