# -----------------------------------------------------------------------------
# Mumble（Murmur）環境變數範本（mumblevoip/mumble-server）
# -----------------------------------------------------------------------------
# 注意：此檔案包含管理員密碼，建議權限設為 600。

PUID=${user_id}
PGID=${user_id}
TZ=Asia/Taipei

# SuperUser（管理員）密碼：部署時可自訂；直接按 Enter 會使用隨機密碼
MUMBLE_SUPERUSER_PASSWORD=${MUMBLE_SUPERUSER_PASSWORD}

# 伺服器加入密碼：使用者進入伺服器會被要求輸入
MUMBLE_CONFIG_SERVERPASSWORD=${MUMBLE_CONFIG_SERVERPASSWORD}

# （選填）歡迎訊息（可含空白；如需換行請參考上游文件）
#MUMBLE_CONFIG_WELCOMETEXT=歡迎使用 Mumble
