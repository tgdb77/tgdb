worker_processes 1;

events {
  worker_connections 1024;
}

http {
  include /etc/nginx/mime.types;
  default_type application/octet-stream;
  sendfile on;

  map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
  }

  map $http_accept $lemmy_actor_backend {
    default http://127.0.0.1:1234;
    "~*application/activity\+json" http://127.0.0.1:8537;
    "~*application/ld\+json" http://127.0.0.1:8537;
  }

  server {
    listen 8536;
    server_name ${app_domain};

    client_max_body_size 100M;

    location /pictrs/ {
      include /etc/nginx/proxy_params;
      proxy_pass http://127.0.0.1:8080;
    }

    location ~ ^/(api|feeds|nodeinfo|\.well-known) {
      include /etc/nginx/proxy_params;
      proxy_pass http://127.0.0.1:8537;
    }

    location ~ ^/(u|c|post|comment|private_message|inbox|outbox) {
      include /etc/nginx/proxy_params;
      proxy_pass $lemmy_actor_backend;
    }

    location / {
      include /etc/nginx/proxy_params;
      proxy_pass http://127.0.0.1:1234;
    }
  }
}
