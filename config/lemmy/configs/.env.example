# Lemmy（官方 Docker / TGDB Pod 版）共用環境變數
# 參考：
# - 官方 Docker 安裝：https://join-lemmy.org/docs/administration/install_docker.html
# - 官方 compose：https://raw.githubusercontent.com/LemmyNet/lemmy-docs/main/assets/docker-compose.yml
#
# 說明：
# - Lemmy 本體主要讀取 ${instance_dir}/lemmy.hjson
# - 此檔案主要提供 PostgreSQL、Lemmy UI 與 pict-rs 使用

TZ=Asia/Taipei
RUST_LOG=warn

# --- PostgreSQL ---
POSTGRES_DB=lemmy
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# --- Lemmy UI ---
# TGDB 版改用 Pod 內 localhost 通訊，因此 internal host 指向後端 8537。
LEMMY_UI_LEMMY_INTERNAL_HOST=127.0.0.1:8537
LEMMY_UI_LEMMY_EXTERNAL_HOST=${app_domain}
LEMMY_UI_HTTPS=true

# --- pict-rs ---
PICTRS__SERVER__API_KEY=${pictrs_api_key}
RUST_BACKTRACE=full

# 若你要調整媒體轉碼策略，可自行取消註解：
#PICTRS__MEDIA__VIDEO__VIDEO_CODEC=vp9
#PICTRS__MEDIA__ANIMATION__MAX_WIDTH=256
#PICTRS__MEDIA__ANIMATION__MAX_HEIGHT=256
#PICTRS__MEDIA__ANIMATION__MAX_FRAME_COUNT=400
