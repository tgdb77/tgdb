# Manyfold 環境變數
#
# 檔案位置：${instance_dir}/.env
# 文件：
# - Docker：https://manyfold.app/get-started/docker
# - 參數說明：https://manyfold.app/sysadmin/configuration.html
#
# 注意：設定完成後請重啟單元

# ----------------------------
# 必填（Manyfold 0.69.0+）
# ----------------------------

# Manyfold 執行的使用者/群組 ID（預設跟隨目前執行 TGDB 的使用者）
PUID=${user_id}
PGID=${group_id}

# 站台 cookie 簽名金鑰（長隨機字串；更換會讓所有登入狀態失效）
SECRET_KEY_BASE=${secret_key_base}

# Redis（同 Pod 內可用 localhost）
REDIS_URL=redis://localhost:6379/1

# ----------------------------
# 資料庫（PostgreSQL）
# 可改用 DATABASE_URL 取代下列 DATABASE_* 參數
# ----------------------------
DATABASE_ADAPTER=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=manyfold
DATABASE_USER=${db_user}
DATABASE_PASSWORD=${db_pass}

# PostgreSQL（供 postgres image 初始化）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=manyfold

# ----------------------------
# 常用選項（選填）
# ----------------------------

# 多人模式（建議對外公開時啟用）
#MULTIUSER=enabled

# 若你有反代到域名，且需要寄信/SSO/OIDC/Federation，請設定公開訪問資訊
#PUBLIC_HOSTNAME=manyfold.example.com
#PUBLIC_PORT=3214
#HTTPS_ONLY=enabled

# 若要掛在子路徑（例如 https://example.com/manyfold），可設定：
#RAILS_RELATIVE_URL_ROOT=/manyfold
