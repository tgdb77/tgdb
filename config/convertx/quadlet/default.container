[Unit]
Description=convertx
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/c4illin/convertx:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=convertx
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:3000/tcp

EnvironmentFile=${instance_dir}/.env
Volume=${instance_dir}/data:/app/data

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
