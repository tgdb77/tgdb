# -----------------------------------------------------------------------------
# ConvertX（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 預設採保守安全設定；如需放寬請自行評估風險後再調整

TZ=Asia/Taipei

# 建議固定 JWT secret，避免重啟後工作階段失效
JWT_SECRET=${jwt_secret}

# 保守安全預設
ACCOUNT_REGISTRATION=false
HTTP_ALLOWED=false
ALLOW_UNAUTHENTICATED=false
UNAUTHENTICATED_USER_SHARING=false
HIDE_HISTORY=false

# 每 24 小時清一次過舊檔案；設 0 可停用
AUTO_DELETE_EVERY_N_HOURS=24

# 其餘可選項（按需再開）
# WEBROOT=/convert
# FFMPEG_ARGS=
# FFMPEG_OUTPUT_ARGS=
# LANGUAGE=en
# MAX_CONVERT_PROCESS=0
