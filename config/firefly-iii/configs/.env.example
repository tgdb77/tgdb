# Firefly III（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei
APP_ENV=production

# 反代到域名後請改成 https://你的域名
APP_URL=http://127.0.0.1:${host_port}

# Firefly III 官方建議（反向代理情境）
TRUSTED_PROXIES=**

# Firefly III 必要密鑰（由 TGDB 產生）
APP_KEY=${app_key}
STATIC_CRON_TOKEN=${static_cron_token}

# Firefly III 資料庫連線（同一 Pod 內的 PostgreSQL）
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=firefly
DB_USERNAME=${db_user}
DB_PASSWORD=${db_pass}

# PostgreSQL 容器初始化（同一 Pod 內的 db 容器會使用）
POSTGRES_DB=firefly
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
