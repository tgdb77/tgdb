# -----------------------------------------------------------------------------
# EMQX 單節點設定範本
# -----------------------------------------------------------------------------
# 參考：
# - https://docs.emqx.com/en/emqx/latest/deploy/install-docker.html
# - https://hub.docker.com/r/emqx/emqx
#
# 注意：
# - Dashboard 初始帳號固定為 admin
# - Dashboard 預設密碼只在「第一次初始化 admin 紀錄」時生效
# - 單節點持久化需要固定節點名稱；此處使用固定容器名稱作為 host part

# 固定節點名稱，避免容器重建後資料目錄對不上
EMQX_NODE__NAME=emqx@${container_name}

# Erlang Cookie（單節點也建議固定）
EMQX_NODE__COOKIE=${emqx_node_cookie}

# Dashboard 初始管理密碼（admin）
EMQX_DASHBOARD__DEFAULT_PASSWORD=${dashboard_password}
