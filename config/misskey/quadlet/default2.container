[Unit]
Description=Misskey PostgreSQL
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/postgres:18-alpine
ContainerName=${container_name}-postgres
Label=app=misskey
Label=tgdb_db=postgres

Pod=${container_name}.pod

Volume=${instance_dir}/pgdata:/var/lib/postgresql
EnvironmentFile=${instance_dir}/.env

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
