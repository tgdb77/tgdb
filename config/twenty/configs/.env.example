TZ=Asia/Taipei

NODE_PORT=3000

# 對外訪問 URL（若你用 Nginx 反代/HTTPS，請改成 https://你的域名）
SERVER_URL=http://127.0.0.1:${host_port}

# App Secret（自動產生，請勿外流）
APP_SECRET=${app_secret}

# PostgreSQL（供 twenty 與 postgres 容器使用）
PG_DATABASE_USER=${db_user}
PG_DATABASE_PASSWORD=${db_pass}
PG_DATABASE_URL=postgres://${db_user}:${db_pass}@127.0.0.1:5432/default

# Redis
REDIS_URL=redis://127.0.0.1:6379

# 儲存（預設使用本機儲存）
STORAGE_TYPE=local
# STORAGE_S3_REGION=
# STORAGE_S3_NAME=
# STORAGE_S3_ENDPOINT=

# 進階選項（通常不需要改；worker 會在 Quadlet 內強制關閉 migrations/cron）
# DISABLE_DB_MIGRATIONS=
# DISABLE_CRON_JOBS_REGISTRATION=
