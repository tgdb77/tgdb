# WordPress（PHP-FPM 全配，TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器（包含 App 與 DB 容器）
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# WordPress：資料庫設定（MySQL）
WORDPRESS_DB_HOST=127.0.0.1:3306
WORDPRESS_DB_USER=${db_user}
WORDPRESS_DB_PASSWORD=${db_pass}
WORDPRESS_DB_NAME=wordpress

# MySQL（同一 Pod 內的 mysql 容器會使用）
MYSQL_ROOT_PASSWORD=${mysql_root_password}
MYSQL_DATABASE=wordpress
MYSQL_USER=${db_user}
MYSQL_PASSWORD=${db_pass}

# （選用）WordPress 除錯
# WORDPRESS_DEBUG=0

