# Hoppscotch（TGDB 產生）
# 參考：
# - https://docs.hoppscotch.io/documentation/self-host/community-edition/install-and-build
# - https://github.com/hoppscotch/hoppscotch/blob/main/docker-compose.deploy.yml
#
# 本範本採 AIO 映像 + PostgreSQL，並預設啟用官方子路徑模式。

# ---- PostgreSQL ----
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=hoppscotch
DATABASE_URL=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/hoppscotch

# 子路徑模式下，AIO 會直接監聽此埠（官方預設為 80）
HOPP_AIO_ALTERNATE_PORT=${host_port}

# ---- 基本安全設定 ----
DATA_ENCRYPTION_KEY=${data_encryption_key}

# ---- AIO / Frontend / Admin / Backend 位址（子路徑模式）----
ENABLE_SUBPATH_BASED_ACCESS=true
VITE_BASE_URL=http://127.0.0.1:${host_port}
VITE_SHORTCODE_BASE_URL=http://127.0.0.1:${host_port}
VITE_ADMIN_URL=http://127.0.0.1:${host_port}/admin

VITE_BACKEND_GQL_URL=http://127.0.0.1:${host_port}/backend/graphql
VITE_BACKEND_WS_URL=ws://127.0.0.1:${host_port}/backend/graphql
VITE_BACKEND_API_URL=http://127.0.0.1:${host_port}/backend/v1

WHITELISTED_ORIGINS=http://127.0.0.1:${host_port}

# ---- 可選：SMTP / OAuth / SSO 等進階設定 ----
# 官方文件建議依需求再補：
#MAILER_USE_CUSTOM_CONFIGS=false
#MAILER_SMTP_URL=
#MAILER_ADDRESS_FROM=
