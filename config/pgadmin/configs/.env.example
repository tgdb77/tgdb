# -----------------------------------------------------------------------------
# pgAdmin 4（PostgreSQL Web 管理）設定範本
# -----------------------------------------------------------------------------
# 注意：此檔案包含密碼，建議權限設為 600。
#
# 建議使用方式（最穩、最小暴露面）：
# - pgAdmin 對外僅綁 127.0.0.1（透過 SSH / VS Code 埠轉發存取）
# - pgAdmin 與 PostgreSQL 容器同在 tgdb.network 時，可直接用「容器名稱:5432」連線
#
# 例：ssh -L 8080:127.0.0.1:<pgadmin_host_port> user@db-host
# 然後在瀏覽器開：http://127.0.0.1:8080

PGADMIN_DEFAULT_EMAIL=${email}
PGADMIN_DEFAULT_PASSWORD=${pass_word}

# 防止容器內啟動 postfix（通常不需要寄信功能）
PGADMIN_DISABLE_POSTFIX=true
