# Formbricks（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

######################################################## REQUIRED ########################################################

# 用於管理介面顯示與登入流程的 URL（反向代理/HTTPS/換域名時務必同步更新）
WEBAPP_URL=http://127.0.0.1:${host_port}
NEXTAUTH_URL=http://127.0.0.1:${host_port}

# PostgreSQL
DATABASE_URL=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/formbricks?schema=public
POSTGRES_DB=formbricks
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# NextAuth
NEXTAUTH_SECRET=${nextauth_secret}

# Encryption Key（用於 2FA 與 Link Surveys 的一次性 URL）
ENCRYPTION_KEY=${encryption_key}

# Cron jobs（API Secret）
CRON_SECRET=${cron_secret}

# Redis/Valkey（快取、Rate Limiting、Audit Logging）
REDIS_URL=redis://127.0.0.1:6379

######################################################## OPTIONAL ########################################################

# Log level（debug, info, warn, error, fatal）
#LOG_LEVEL=info

# ---- Enterprise Edition ----
#ENTERPRISE_LICENSE_KEY=

# ---- Email configuration ----
#MAIL_FROM=noreply@example.com
#MAIL_FROM_NAME=Formbricks
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=user@example.com
#SMTP_PASSWORD=your_password
#SMTP_AUTHENTICATED=1
#SMTP_SECURE_ENABLED=0
#SMTP_REJECT_UNAUTHORIZED_TLS=0

# ---- App configuration ----
# 預設自託管常見做法：關閉 Email Verification 與 Password Reset（避免未設定 SMTP 導致卡住）
EMAIL_VERIFICATION_DISABLED=1
PASSWORD_RESET_DISABLED=1

#EMAIL_AUTH_DISABLED=
#INVITE_DISABLED=
#PUBLIC_URL=
#ASSET_PREFIX_URL=

# ---- Storage (S3 compatible) ----
# 若未設定，檔案上傳/圖片相關功能會被停用。
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
#S3_REGION=
#S3_BUCKET_NAME=
#S3_ENDPOINT_URL=
#S3_FORCE_PATH_STYLE=0

