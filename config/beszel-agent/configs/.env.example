# -----------------------------------------------------------------------------
# Beszel Agent 環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案包含密碼/金鑰，建議權限設為 600。
#
# 提醒：
# - KEY/TOKEN 可能包含空白，因此此處使用雙引號包住，讓 systemd EnvironmentFile 可正確解析。

LISTEN=${host_port}

KEY=${KEY}
TOKEN=${TOKEN}
HUB_URL=${HUB_URL}

# 持久化 agent fingerprint / 未來資料庫；需搭配 Quadlet 的 /var/lib/beszel-agent 掛載。
DATA_DIR=/var/lib/beszel-agent

# Podman / Docker API：Quadlet 已將 rootful Podman socket 掛到 /var/run/docker.sock。
DOCKER_HOST=unix:///var/run/docker.sock

# systemd 服務監控：留空代表不限制；如需只監控特定服務，可改成 beszel*,podman*,nginx* 等。
#SERVICE_PATTERNS=

# S.M.A.R.T.：留空代表讓 smartctl 自動掃描；必要時可手動指定，例如：/dev/nvme0:nvme,/dev/sda:sat
#SMART_DEVICES=/dev/nvme0:nvme,/dev/sda:sat
SMART_INTERVAL=1h

# 額外磁碟若容易被喚醒，可設定快取避免頻繁讀取，例如 5m 或 1h。
#DISK_USAGE_CACHE=5m

# GPU：預設自動偵測；必要時可指定 nvml,nvidia-smi,amd_sysfs,rocm-smi,intel_gpu_top 等。
#GPU_COLLECTOR=
#INTEL_GPU_DEVICE=card0

# 除錯時可改成 debug，查看磁碟分割、diskstats、systemd / socket 錯誤等細節。
LOG_LEVEL=info
