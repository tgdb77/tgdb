# Semaphore UI（TGDB 產生）
# 參考：
# - Docker 安裝：https://semaphoreui.com/docs/admin-guide/installation/docker
# - 設定文件：https://semaphoreui.com/docs/admin-guide/configuration
# - Nginx 反代：https://semaphoreui.com/docs/admin-guide/reverse-proxy/nginx

# Web UI
SEMAPHORE_PORT=3000
SEMAPHORE_INTERFACE=0.0.0.0

# 資料庫：SQLite（官方 v2.16+ 支援）
# 註：官方 Docker 範例使用 SEMAPHORE_DB 指定 SQLite 路徑；
# 設定文件則列出 sqlite 對應 SEMAPHORE_DB_HOST。
# 為兼容兩種文件寫法，這裡兩者都寫入同一路徑。
SEMAPHORE_DB_DIALECT=sqlite
SEMAPHORE_DB=/var/lib/semaphore/semaphore.sqlite
SEMAPHORE_DB_HOST=/var/lib/semaphore/semaphore.sqlite

# 工作目錄 / 暫存 / repo / secrets
SEMAPHORE_TMP_PATH=/tmp/semaphore
SEMAPHORE_PLAYBOOK_PATH=/tmp/semaphore/

# 首次啟動初始化管理員（僅新資料庫時生效）
SEMAPHORE_ADMIN=${admin_user}
SEMAPHORE_ADMIN_PASSWORD=${admin_password}
SEMAPHORE_ADMIN_NAME=${admin_name}
SEMAPHORE_ADMIN_EMAIL=${admin_email}

# 安全金鑰（TGDB 自動產生）
SEMAPHORE_ACCESS_KEY_ENCRYPTION=${access_key_encryption}
SEMAPHORE_COOKIE_HASH=${cookie_hash}
SEMAPHORE_COOKIE_ENCRYPTION=${cookie_encryption}

# （選用）若你透過 Nginx 子路徑提供服務，例如 /semaphore，可改成：
#SEMAPHORE_WEB_ROOT=/semaphore

# （選用）如果你有額外 Python 套件需求，可建立 requirements.txt 並掛到 /etc/semaphore/requirements.txt
