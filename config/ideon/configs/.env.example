# Ideon 環境變數（TGDB 產生）
#
# 參考：
# - 專案首頁：https://github.com/3xpyth0n/ideon
# - 官方 Compose：https://github.com/3xpyth0n/ideon/blob/main/docker-compose.yml
# - 官方 env 範本：https://github.com/3xpyth0n/ideon/blob/main/env.example
#
# 注意：
# - 變更後需重新啟動單元
# - APP_URL 會影響邀請連結與 SSO 回呼
# - 對外正式上線前，建議搭配 Nginx / HTTPS 反向代理

# -----------------------------------------------------------------------------
# Ideon App
# -----------------------------------------------------------------------------
APP_PORT=3000
APP_URL=http://127.0.0.1:${host_port}
TIMEZONE=Asia/Taipei
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=error
SECRET_KEY=${secret_key}

# Docker entrypoint 會依這兩個值調整 appuser UID/GID，避免資料目錄權限混亂
PUID=${user_id}
PGID=${group_id}

# -----------------------------------------------------------------------------
# PostgreSQL（Ideon -> PostgreSQL）
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ideon
DB_USER=${db_user}
DB_PASS=${db_pass}

# -----------------------------------------------------------------------------
# PostgreSQL 初始化（供 postgres:18-alpine entrypoint 使用）
# -----------------------------------------------------------------------------
POSTGRES_DB=ideon
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
PGDATA=/var/lib/postgresql/data/pgdata

# -----------------------------------------------------------------------------
# 其他選填設定
# -----------------------------------------------------------------------------
# SMTP_FROM_EMAIL=
# SMTP_FROM_NAME=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_PORT=
# SMTP_USE_TLS=true
# GIT_ALLOWED_HOSTS=
# SHELL_MAX_SESSIONS=2
