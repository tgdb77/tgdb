# -----------------------------------------------------------------------------
# Docmost（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - 預設使用本地檔案儲存，附件會寫入 ${instance_dir}/storage。
# - 若你改用反向代理 / HTTPS 網域，請同步更新 APP_URL。

TZ=Asia/Taipei

# 應用基本設定
APP_URL=http://localhost:${host_port}
PORT=3000
APP_SECRET=${app_secret}
JWT_TOKEN_EXPIRES_IN=30d

# 資料庫 / Redis
DATABASE_URL=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/docmost?schema=public
REDIS_URL=redis://127.0.0.1:6379

# PostgreSQL 初始化（postgres official image 使用）
POSTGRES_DB=docmost
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# 儲存
STORAGE_DRIVER=local

# S3 driver（需要時再填）
#AWS_S3_ACCESS_KEY_ID=
#AWS_S3_SECRET_ACCESS_KEY=
#AWS_S3_REGION=
#AWS_S3_BUCKET=
#AWS_S3_ENDPOINT=
#AWS_S3_FORCE_PATH_STYLE=

# 上傳限制
FILE_UPLOAD_SIZE_LIMIT=50mb
FILE_IMPORT_SIZE_LIMIT=200mb

# 郵件（邀請新成員前請先補齊）
MAIL_DRIVER=smtp
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=Docmost
SMTP_HOST=127.0.0.1
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_IGNORETLS=false

# Postmark（需要時再填）
#POSTMARK_TOKEN=

# Draw.io / Telemetry / Debug
#DRAWIO_URL=https://embed.diagrams.net
DISABLE_TELEMETRY=false
DEBUG_MODE=false
DEBUG_DB=false
LOG_HTTP=false
