# Stash 環境變數（可選）
#
# 檔案位置：${instance_dir}/.env
# 文件：https://docs.stashapp.cc/installation/docker/
#
# 注意：
# - STASH_PORT 是容器內埠號（需與 Quadlet PublishPort 的右側一致）
# - 設定完成後請重啟單元

# 容器內資料路徑（通常不需要改）
STASH_STASH=/data/
STASH_GENERATED=/generated/
STASH_METADATA=/metadata/
STASH_CACHE=/cache/

# 容器內服務埠（預設 9999）
STASH_PORT=9999

