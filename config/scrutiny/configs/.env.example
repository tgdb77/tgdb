# Scrutiny（TGDB 產生）
#
# 參考：
# - GitHub / README：https://github.com/AnalogJ/scrutiny
# - 裝置疑難排解：https://github.com/AnalogJ/scrutiny/blob/master/docs/TROUBLESHOOTING_DEVICE_COLLECTOR.md
# - InfluxDB 疑難排解：https://github.com/AnalogJ/scrutiny/blob/master/docs/TROUBLESHOOTING_INFLUXDB.md
#
# 注意：
# - 變更後需重新啟動單元
# - 官方 omnibus image 不強制需要額外 env；此檔先保留 TGDB 常用與可選設定

TZ=Asia/Taipei
DEBUG=false

# Collector 排程（可選）
# 官方預設：每天午夜一次（0 0 * * *）
# 若要覆寫，可取消註解並自行設定；因為 systemd EnvironmentFile 對空白敏感，建議加上雙引號。
#COLLECTOR_CRON_SCHEDULE="0 0 * * *"

# 日誌檔（可選）
#SCRUTINY_LOG_FILE=/tmp/web.log
#COLLECTOR_LOG_FILE=/tmp/collector.log
