# Pocket ID（TGDB 產生）
# 參考：
# - 安裝文件：https://pocket-id.org/docs/setup/installation/
# - 反向代理：https://pocket-id.org/docs/setup/reverse-proxy/
# - 環境變數：https://pocket-id.org/docs/setup/configuration/
#
# 本範本預設部署在本機回環埠，對外請搭配 TGDB Nginx / HTTPS。

# 對外公開網址（務必與實際瀏覽器訪問網址一致）
APP_URL=https://${fqdn}

# 若放在 Nginx / Caddy / Traefik 後方，請保持 true
TRUST_PROXY=true

# Pocket ID 核心加密金鑰（TGDB 自動產生）
ENCRYPTION_KEY=${encryption_key}

# 同一容器內使用 SQLite（官方最小部署方式）
DB_CONNECTION_STRING=file:/app/data/pocket-id.db

# 容器程序執行身分（便於 rootless/rootful 寫入掛載目錄）
PUID=${user_id}
PGID=${group_id}

# （選用）若你的 OIDC client / 內網服務無法解析 APP_URL，可補內部位址：
#INTERNAL_APP_URL=http://host.containers.internal:${host_port}

# （選用）若你要改用 PostgreSQL，可依官方文件改成：
#DB_CONNECTION_STRING=postgresql://pocketid:請改成你的密碼@127.0.0.1:5432/pocketid
