# OpenCode Server（web 模式）

# Basic auth（建議必填；帳號預設 opencode）
OPENCODE_SERVER_USERNAME=${server_user}
OPENCODE_SERVER_PASSWORD=${server_pass}

# 持久化：把 OpenCode 的 config/data/state 固定到掛載目錄
OPENCODE_CONFIG_DIR=/opencode/config
XDG_CONFIG_HOME=/opencode/config
XDG_DATA_HOME=/opencode/data
XDG_STATE_HOME=/opencode/state

# 可選：你常用的模型供應商 API key（按需自行填）
#OPENAI_API_KEY=
#ANTHROPIC_API_KEY=
#GEMINI_API_KEY=

# 可選：指定 OpenCode config 檔（例如 /opencode/config/opencode.json）
#OPENCODE_CONFIG=
