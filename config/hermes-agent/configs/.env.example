# Hermes Agent 環境變數（TGDB 產生）
#
# 參考：
# - 官方範例：https://github.com/NousResearch/hermes-agent/blob/main/.env.example
# - 官方設定文件：https://hermes-agent.nousresearch.com/docs/user-guide/configuration/
#
# 建議先完成部署後的初始化：
#   podman exec -it ${container_name}-gateway hermes setup
#
# Gateway API（TGDB 預設啟用）
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=${API_SERVER_KEY}

# 若需要讓瀏覽器前端直接連 Hermes API，再依官方文件改成精準 allowlist：
#API_SERVER_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
#
# 依你使用的模型供應商，取消註解並填入對應金鑰：

# OpenRouter
#OPENROUTER_API_KEY=

# Anthropic
#ANTHROPIC_API_KEY=

# OpenAI / Codex / 相容端點
#OPENAI_API_KEY=

# Google AI Studio / Gemini
#GOOGLE_API_KEY=
#GEMINI_API_KEY=

# Nous Portal
#NOUS_API_KEY=

# 本機或自架 OpenAI 相容端點（選用）
#OPENAI_BASE_URL=
