# Sub2API（TGDB 產生）
#
# 參考：
# - Repo / 部署文件：https://github.com/Wei-Shaw/sub2api
# - 官方 .env.example：https://raw.githubusercontent.com/Wei-Shaw/sub2api/main/deploy/.env.example
# - 官方 docker-compose.local.yml：https://raw.githubusercontent.com/Wei-Shaw/sub2api/main/deploy/docker-compose.local.yml
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器（包含 Sub2API / PostgreSQL / Redis 容器）
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# 基本設定
AUTO_SETUP=true
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard

# PostgreSQL（官方 compose 使用 postgres service）
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USER=${db_user}
DATABASE_PASSWORD=${db_pass}
DATABASE_DBNAME=sub2api
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=256
DATABASE_MAX_IDLE_CONNS=128
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# PostgreSQL official image 初始化
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=sub2api

# Redis（官方 compose 使用 redis service）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=${redis_password}
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# 管理員帳號（首次啟動自動建立）
ADMIN_EMAIL=${admin_email}
ADMIN_PASSWORD=${admin_pass}

# 安全金鑰（官方強烈建議固定）
JWT_SECRET=${jwt_secret}
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=${totp_encryption_key}

# 日誌 / 檔案
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=true

# 選填：內建監控與更新
OPS_ENABLED=true
UPDATE_PROXY_URL=

# 選填：若有自訂 config.yaml，可自行掛載並在主容器補 CONFIG_FILE 路徑
#CONFIG_FILE=/app/data/config.yaml
