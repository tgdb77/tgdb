# RustFS（TGDB 產生）
# 參考：
# - README：https://github.com/rustfs/rustfs
# - Docker：https://docs.rustfs.com/installation/docker/
#
# 說明：
# - 預設僅綁定 127.0.0.1 的 Console 與 S3 API，較安全。
# - 這裡先用單一 volume_dir 掛到 /data，並讓 RustFS 在該目錄下建立 rustfs0~rustfs3 子目錄。
# - 若你要改成多磁碟 / 多路徑部署，請同時修改 RUSTFS_VOLUMES 與 Quadlet 的 Volume 掛載。

# S3 / Console 監聽位址（容器內）
RUSTFS_ADDRESS=:9000
RUSTFS_CONSOLE_ENABLE=true
RUSTFS_CONSOLE_ADDRESS=:9001

# S3 帳密
RUSTFS_ACCESS_KEY=${access_key}
RUSTFS_SECRET_KEY=${secret_key}

# 單機預設資料位置（同一個 volume_dir 內建立 4 個資料子目錄）
RUSTFS_VOLUMES=/data/rustfs{0...3}

# 將觀測/執行日誌寫到掛載的 logs 目錄
RUSTFS_OBS_LOG_DIRECTORY=/logs

# 需要對外提供正式網址時，可依官方文件補上外部位址
# 例如：https://s3.example.com 或 https://console.example.com
#RUSTFS_EXTERNAL_ADDRESS=
