# -----------------------------------------------------------------------------
# Kan（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 預設只綁定本機回環；正式對外建議搭配 Nginx 反向代理與 HTTPS
# - 如果改成正式網域，請同步更新 NEXT_PUBLIC_BASE_URL 與 BETTER_AUTH_TRUSTED_ORIGINS

TZ=Asia/Taipei

# 基本設定
NEXT_PUBLIC_KAN_ENV=production
NEXT_PUBLIC_BASE_URL=http://127.0.0.1:${host_port}
BETTER_AUTH_SECRET=${better_auth_secret}
KAN_ADMIN_API_KEY=${kan_admin_api_key}
NEXT_PUBLIC_USE_STANDALONE_OUTPUT=true
LOG_LEVEL=info

# 預設啟用公開註冊；首次建立帳號後可改為 true
NEXT_PUBLIC_DISABLE_SIGN_UP=false
NEXT_PUBLIC_ALLOW_CREDENTIALS=true
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:${host_port}
#BETTER_AUTH_ALLOWED_DOMAINS=

# 資料庫（同一 Pod 內的 PostgreSQL）
POSTGRES_URL=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/kan
POSTGRES_DB=kan
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# Redis（預設不啟用；需要外部 Redis 時再填）
#REDIS_URL=

# Email / 通知（需要時再填）
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true
EMAIL_FROM=
EMAIL_UNSUBSCRIBE_SECRET=${email_unsubscribe_secret}
NOVU_API_KEY=
DISCORD_WEBHOOK_URL=

# API / 上傳限制
NEXT_API_BODY_SIZE_LIMIT=10mb

# S3 storage（需要時再填）
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_REGION=
#S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
S3_AVATAR_UPLOAD_LIMIT=5242880
NEXT_PUBLIC_STORAGE_URL=http://127.0.0.1:${host_port}
#NEXT_PUBLIC_AVATAR_BUCKET_NAME=
#NEXT_PUBLIC_ATTACHMENTS_BUCKET_NAME=
#NEXT_PUBLIC_STORAGE_DOMAIN=
NEXT_PUBLIC_USE_VIRTUAL_HOSTED_URLS=false

# OAuth / Trello（需要時再填）
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#TRELLO_APP_API_KEY=
#TRELLO_APP_SECRET=

# Stripe（需要時再填）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_LEGACY=
STRIPE_TEAM_PLAN_MONTHLY_PRICE_ID=
STRIPE_TEAM_PLAN_YEARLY_PRICE_ID=
STRIPE_PRO_PLAN_MONTHLY_PRICE_ID=
STRIPE_PRO_PLAN_YEARLY_PRICE_ID=

# Analytics / Partner（需要時再填）
#NEXT_PUBLIC_UMAMI_ID=
#NEXT_PUBLIC_POSTHOG_KEY=
#NEXT_PUBLIC_POSTHOG_HOST=
#NEXT_PUBLIC_PARTNER_NAME=
#PARTNER_CLIENT_ID=
#PARTNER_CLIENT_SECRET=
#PARTNER_REDIRECT_URL=
#PARTNER_TOKEN_URL=
#PARTNER_OAUTH_LICENSE_URL=
#PARTNER_LICENSE_API_URL=
#PARTNER_API_KEY=
#PARTNER_API_KEY_HEADER=
#PARTNER_SIGNATURE_HEADER=
#PARTNER_TIMESTAMP_HEADER=
#AXIOM_TOKEN=
#AXIOM_DATASET=
