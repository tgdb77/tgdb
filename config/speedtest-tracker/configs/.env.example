# Speedtest Tracker（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

PUID=${user_id}
PGID=${group_id}
TZ=Asia/Taipei

# Laravel APP_KEY（必填）
# - 部署時會由 TGDB 自動產生並寫入（留空即可）
APP_KEY=

# 你實際訪問的 URL（反向代理/換埠時務必同步更新）
APP_URL=http://127.0.0.1:${host_port}

# ---- PostgreSQL（預設；同一個 Pod 內的 postgres 容器會使用）----
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=speedtest_tracker

# ---- 應用 DB 連線資訊 ----
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=speedtest_tracker
DB_USERNAME=${db_user}
DB_PASSWORD=${db_pass}

# 若要改回 sqlite（資料放在 /config）：
#DB_CONNECTION=sqlite

# ---- 測速排程 ----
# SPEEDTEST_SCHEDULE 需使用 cron 格式（含空白），不建議直接寫在這份 .env。
# 建議做法：
# 1) 先啟動後在 Web UI 內設定排程（較不容易出錯）
# 2) 或改在 Quadlet 內加入：
#    Environment="SPEEDTEST_SCHEDULE=0 */6 * * *"

# 只測特定 servers（逗號分隔；例如：1234,5678）
#SPEEDTEST_SERVERS=

# UI 顯示用時區（可選）
#DISPLAY_TIMEZONE=Asia/Taipei

# 自動清理舊結果（天數；0=不清理）
#PRUNE_RESULTS_OLDER_THAN=0
