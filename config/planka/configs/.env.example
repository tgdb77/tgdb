# Planka（TGDB 產生）
#
# 參考：
# - GitHub：https://github.com/plankanban/planka
# - docker-compose.yml：https://raw.githubusercontent.com/plankanban/planka/master/docker-compose.yml
#
# 注意：
# - 變更後需重新啟動單元
# - 這份檔案會被 Planka 與 PostgreSQL / Redis 容器共用

TZ=Asia/Taipei

# 核心設定
BASE_URL=http://127.0.0.1:${host_port}
TRUST_PROXY=true
SECRET_KEY=${secret_key}

# 首次初始化管理員（建立完成後可視需求移除）
DEFAULT_ADMIN_EMAIL=${admin_email}
DEFAULT_ADMIN_PASSWORD=${admin_password}
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_USERNAME=admin

# 資料庫（Planka -> PostgreSQL）
DATABASE_URL=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/planka

# Redis（快取 / queue）
REDIS_URL=redis://127.0.0.1:6379

# PostgreSQL 初始化
POSTGRES_DB=planka
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# 外掛 / 郵件 / 身份提供者（選填）
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_NAME=
#SMTP_USERNAME=
#SMTP_PASSWORD=
#SMTP_SECURE=true
#SMTP_FROM=
#OIDC_ISSUER=
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#LDAP_URL=
#LDAP_BIND_DN=
#LDAP_PASSWORD=
