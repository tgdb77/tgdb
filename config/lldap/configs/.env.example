# LLDAP（TGDB 產生）
#
# 參考：
# - GitHub：https://github.com/lldap/lldap
# - 官方 Docker 設定模板：https://raw.githubusercontent.com/lldap/lldap/main/lldap_config.docker_template.toml
# - GHCR 套件頁：https://github.com/orgs/lldap/packages/container/package/lldap
#
# 注意：
# - 變更後需重新啟動單元
# - 這份範本採官方建議的最小 Docker / Podman 環境變數路線

TZ=Asia/Taipei

# Web / HTTP
LLDAP_HTTP_HOST=0.0.0.0
LLDAP_HTTP_PORT=17170
LLDAP_HTTP_URL=http://127.0.0.1:${host_port}

# LDAP
LLDAP_LDAP_HOST=0.0.0.0
LLDAP_LDAP_PORT=${ldap_port}
LLDAP_LDAP_BASE_DN=${base_dn}
LLDAP_LDAP_USER_DN=admin
LLDAP_LDAP_USER_PASS=${admin_password}

# JWT / session secret
LLDAP_JWT_SECRET=${jwt_secret}

# 若未來要改用外部資料庫，可依官方文件補上：
#LLDAP_DATABASE_URL=postgres://user:pass@127.0.0.1:5432/lldap
# 或：
#LLDAP_DATABASE_URL=mysql://user:pass@127.0.0.1:3306/lldap
