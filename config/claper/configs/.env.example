# Claper（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei
NODE_ENV=production

# 對外網址（反向代理/換域名時務必同步更新）
BASE_URL=http://127.0.0.1:${host_port}

# Cookie（HTTP/HTTPS）
#SAME_SITE_COOKIE=Lax
#SECURE_COOKIE=false

# ---- PostgreSQL（同一個 Pod 內的 postgres 容器會使用）----
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=claper

# ---- 應用 DB 連線 ----
DATABASE_URL=postgres://${db_user}:${db_pass}@127.0.0.1:5432/claper

# 祕鑰（必填）
# - TGDB 會在部署時提示輸入；可直接按 Enter 由 TGDB 自動產生
SECRET_KEY_BASE=${secret_key_base}

# ---- 上傳/儲存 ----
PRESENTATION_STORAGE=local
PRESENTATION_STORAGE_DIR=/app/uploads
#MAX_FILE_SIZE_MB=15

# ---- S3（可選；PRESENTATION_STORAGE=s3 時使用）----
#S3_ACCESS_KEY_ID=xxx
#S3_SECRET_ACCESS_KEY=xxx
#S3_REGION=ap-northeast-1
#S3_BUCKET=xxx
#S3_SCHEME=https://
#S3_HOST=www.example.com
#S3_PORT=443
#S3_PUBLIC_URL=https://www.example.com

# ---- Mail（預設不啟用 SMTP）----
MAIL_TRANSPORT=local
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Claper
#SMTP_RELAY=smtp.example.com
#SMTP_USERNAME=johndoe@example.com
#SMTP_PASSWORD=xxx
#SMTP_PORT=465
#ENABLE_MAILBOX_ROUTE=false
#MAILBOX_USER=admin
#MAILBOX_PASSWORD=admin

# ---- Claper ----
ENABLE_ACCOUNT_CREATION=true
#EMAIL_CONFIRMATION=true
#ALLOW_UNLINK_EXTERNAL_PROVIDER=false
#LOGOUT_REDIRECT_URL=https://example.com
#LANGUAGES=en,fr,es,it,nl,de

# ---- OIDC（可選）----
#OIDC_PROVIDER_NAME=OpenID
#OIDC_ISSUER=https://my-idp.example/application/o/claper/
#OIDC_CLIENT_ID=XXX
#OIDC_CLIENT_SECRET=XXX
#OIDC_SCOPES=openid,email,profile
#OIDC_LOGO_URL=
#OIDC_PROPERTY_MAPPINGS=roles:custom_attributes.roles,organization:custom_attributes.organization
#OIDC_AUTO_REDIRECT_LOGIN=true

