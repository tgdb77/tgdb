# Opengist（TGDB 產生）
# 參考：
# - Docker 安裝：https://opengist.io/docs/installation/docker.html
# - 設定總覽：https://opengist.io/docs/configuration/cheat-sheet.html
# - Admin 面板：https://opengist.io/docs/configuration/admin-panel.html
#
# 注意：
# - 首次註冊的使用者會成為管理員
# - TGDB 預設只把 HTTP / SSH 綁到 127.0.0.1；如需對外提供服務，建議搭配 Nginx / HTTPS
# - 變更後請重新啟動單元

# 讓容器內檔案由目前使用者持有
UID=${user_id}
GID=${group_id}

# 公開存取網址（請依實際反向代理 / 網域調整）
OG_EXTERNAL_URL=http://127.0.0.1:${host_port}

# Opengist 資料根目錄（TGDB 會把 ${instance_dir}/data 掛到 /opengist）
OG_OPENGIST_HOME=/opengist

# 固定 secret，避免重啟後 session / MFA 相關資料失效
OG_SECRET_KEY=${opengist_secret_key}

# HTTP 服務
OG_HTTP_HOST=0.0.0.0
OG_HTTP_PORT=6157
OG_HTTP_GIT_ENABLED=true

# SSH Git 服務
# 若不需要 Git over SSH，可把 OG_SSH_GIT_ENABLED 改成 false，並註解 Quadlet 的第二條 PublishPort
OG_SSH_GIT_ENABLED=true
OG_SSH_HOST=0.0.0.0
OG_SSH_PORT=${ssh_port}
# 若 SSH 使用不同網域，再自行取消註解並調整
#OG_SSH_EXTERNAL_DOMAIN=git.example.com

# 資料庫：預設使用 SQLite（資料位於 /opengist）
# 若改用 PostgreSQL / MySQL，請依官方文件調整 OG_DB_URI
#OG_DB_URI=opengist.db

# 其餘設定請參考官方 cheat sheet：
# https://opengist.io/docs/configuration/cheat-sheet.html
