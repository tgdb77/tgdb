# Penpot 環境變數
# 說明：
# - 建議只透過 Nginx HTTPS 反向代理對外提供服務（避免直接曝露 HTTP）
# - PENPOT_PUBLIC_URI 需與實際對外網址一致（含協定與埠號）
#
# 參考：
# - https://help.penpot.app/technical-guide/getting-started/docker/

###############################################################################
# 基本
###############################################################################

# 對外網址（local_only 預設）
PENPOT_PUBLIC_URI=http://127.0.0.1:${host_port}

# 旗標（保守預設：適用於 HTTP/localhost；若要上線到網際網路請改用 HTTPS 並移除 disable-*）
# - disable-registration：關閉註冊（需用 CLI 建立初始使用者）
# - enable-prepl-server：啟用後才能在 backend 容器內執行 manage.py create-profile
PENPOT_FLAGS=disable-registration disable-email-verification disable-secure-session-cookies enable-prepl-server

# 必填：密鑰（已由 TGDB 自動產生）
PENPOT_SECRET_KEY=${secret_key}

# 上傳大小限制（單位 bytes；約 350MB）
PENPOT_HTTP_SERVER_MAX_BODY=367001600
PENPOT_HTTP_SERVER_MAX_MULTIPART_BODY_SIZE=367001600

# 遙測（可自行改為 true 以支援專案）
PENPOT_TELEMETRY_ENABLED=false
PENPOT_TELEMETRY_REFERER=tgdb

###############################################################################
# 資料庫（PostgreSQL）
###############################################################################

# Postgres 容器初始化
POSTGRES_DB=penpot
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}
POSTGRES_INITDB_ARGS=--data-checksums

# Backend 連線資訊
PENPOT_DATABASE_URI=postgresql://127.0.0.1:5432/penpot
PENPOT_DATABASE_USERNAME=${user_name}
PENPOT_DATABASE_PASSWORD=${pass_word}

###############################################################################
# 快取（Valkey/Redis 相容）
###############################################################################

PENPOT_REDIS_URI=redis://127.0.0.1:6379/0

###############################################################################
# 檔案/資產儲存
###############################################################################

PENPOT_OBJECTS_STORAGE_BACKEND=fs
PENPOT_OBJECTS_STORAGE_FS_DIRECTORY=/opt/data/assets

###############################################################################
# SMTP（未預設啟用；若需要寄信/邀請，請自行設定並移除 disable-email-verification）
###############################################################################

#PENPOT_SMTP_DEFAULT_FROM=Penpot <no-reply@example.com>
#PENPOT_SMTP_DEFAULT_REPLY_TO=Support <support@example.com>
#PENPOT_SMTP_HOST=smtp.example.com
#PENPOT_SMTP_PORT=587
#PENPOT_SMTP_USERNAME=
#PENPOT_SMTP_PASSWORD=
#PENPOT_SMTP_TLS=true
#PENPOT_SMTP_SSL=false

###############################################################################
# 外部 PostgreSQL / 外部 Valkey（進階；不建議新手）
###############################################################################

# 若你想把資料庫獨立出去（例如使用 TGDB 的 postgresql 應用，或外部 DB），請改用外部 DB 連線資訊，
# 並自行移除/停用本 App 的 -postgres 單元（或改用另一份「不含 DB」的部署）。
#
#PENPOT_DATABASE_URI=postgresql://db.example.com:5432/penpot
#PENPOT_DATABASE_USERNAME=penpot
#PENPOT_DATABASE_PASSWORD=change_me
#
# 同理，若使用外部 Valkey/Redis：
#PENPOT_REDIS_URI=redis://redis.example.com:6379/0
