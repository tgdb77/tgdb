# MySpeed（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei
NODE_ENV=production

# HTTP 服務埠（容器內）
SERVER_PORT=5216

# HTTPS 服務埠（容器內；需 data/certs/cert.pem + key.pem 才會啟用）
#HTTPS_PORT=5217

# ---- 資料庫（預設 sqlite；資料放在 /myspeed/data）----
#DB_TYPE=mysql
#DB_HOST=myspeed-db
#DB_NAME=myspeed
#DB_USER=myspeed
#DB_PASS=change_me

# ---- 其他行為 ----
# 讓 MySpeed 在啟動後立刻跑一次測速（預設會依排程執行）
#RUN_TEST_ON_STARTUP=true
#
# 預覽模式（僅顯示，不允許修改設定）
#PREVIEW_MODE=true
#PREVIEW_MESSAGE=This_instance_is_in_preview_mode

