# LangBot（langbot-app/LangBot）環境變數範本
# - 官方文件：
#   - Docker：https://docs.langbot.app/en/deploy/langbot/docker
#   - 反向代理 / SSL：https://docs.langbot.app/en/workshop/production/proxy-and-ssl
#
# 注意：
# - LangBot 的主要設定檔在 ${instance_dir}/data/config.yaml（例如：api.webhook_prefix / bot / model 等）。
# - 此檔案會由 systemd 讀取（EnvironmentFile），不會直接「掛載」到容器檔案系統。
# - 修改後請重啟單元（依你的容器名稱調整）：
#   systemctl --user restart ${container_name}.pod ${container_name}.container ${container_name}-plugin-runtime.container

# 時區
TZ=Asia/Taipei

# Plugin Runtime 控制連線位址（同一個 Pod 內用 127.0.0.1 即可）
PLUGIN__RUNTIME_WS_URL=ws://127.0.0.1:5400/control/ws
