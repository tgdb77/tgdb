# Ghostfolio / PostgreSQL（同一個 .env 供兩個容器共用）
#
# 注意：
# - 此檔案會由 systemd 讀取（EnvironmentFile），不會直接「掛載」到容器檔案系統。
# - 修改後請重啟單元：
#   systemctl --user restart ${container_name}.container ${container_name}-postgres.container
#
# 參數說明以官方文件為準：
# https://github.com/ghostfolio/ghostfolio

NODE_ENV=production

TZ=Asia/Taipei

# Ghostfolio required
ACCESS_TOKEN_SALT=${access_token_salt}
JWT_SECRET_KEY=${jwt_secret_key}

# Ghostfolio 服務埠（容器內）
PORT=3333
HOST=0.0.0.0

# PostgreSQL
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}

# Ghostfolio 連線字串（因為使用 Pod，容器間可透過 localhost 連線）
DATABASE_URL=postgresql://${user_name}:${pass_word}@127.0.0.1:5432/ghostfolio-db?connect_timeout=300&sslmode=prefer

# Redis（官方 docker-compose.yml 會使用 Redis）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=${pass_word}
