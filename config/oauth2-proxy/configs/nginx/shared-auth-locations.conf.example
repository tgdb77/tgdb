# Nginx shared auth 片段：把這些區塊併入你既有的 `server {}` 站點設定。
# 適用情境：你已經有自己的反向代理站點，只想補上 oauth2-proxy / Pocket ID 驗證。
# 這份範本假設同一個 oauth2-proxy instance 會被多個 `*.${cookie_parent_domain}` 子網域共用。
#
# shared auth 的意思：
# - `/oauth2/*` 一律交給同一個 oauth2-proxy
# - 真正的應用流量仍走你自己的 `proxy_pass`
# - 使用者登入後，session Cookie 以 `.${cookie_parent_domain}` 在多個子網域共用
#
# 注意：
# - 你仍需在既有 `location /`（或對應路徑）中加入 `auth_request` 與 `error_page`
# - 既有站點原本的 `proxy_pass` 仍應指向該站自己的實際上游
# - 多網域情境下，`X-Auth-Request-Redirect` 請保留完整 URL（官方文件亦有特別提醒）

location /oauth2/ {
    # 交給共用的 oauth2-proxy instance
    proxy_pass http://127.0.0.1:${host_port};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Uri $request_uri;
    proxy_set_header X-Auth-Request-Redirect $scheme://$host$request_uri;
    proxy_http_version 1.1;
}

location = /oauth2/auth {
    # auth_request 子請求只做驗證，不送 body
    proxy_pass http://127.0.0.1:${host_port};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-Uri $request_uri;
    proxy_set_header Content-Length "";
    proxy_pass_request_body off;
    proxy_http_version 1.1;
}

# 下面這段需合併到你原本的受保護 location（例如 `location / { ... }`）：
#
# shared auth 的關鍵在於：這段仍留在每個站自己的 `server {}` 裡，
# 但它查詢的是同一個 oauth2-proxy。
#
# auth_request /oauth2/auth;
# error_page 401 =403 /oauth2/sign_in;
#
# auth_request_set $user  $upstream_http_x_auth_request_user;
# auth_request_set $email $upstream_http_x_auth_request_email;
# proxy_set_header X-User  $user;
# proxy_set_header X-Email $email;
#
# 請把你原本站點裡的 proxy_pass 保持指向「實際應用上游」。
# 範例：
# proxy_pass http://host.containers.internal:8088;
