# oauth2-proxy（TGDB 產生）
# 目標：搭配 Nginx `auth_request` 與 Pocket ID（OIDC）保護同一主網域底下的多個子網域
#
# 參考：
# - OAuth2 Proxy Nginx auth_request：
#   https://oauth2-proxy.github.io/oauth2-proxy/configuration/integration/
# - OAuth2 Proxy 設定總覽：
#   https://oauth2-proxy.github.io/oauth2-proxy/configuration/overview/
# - Pocket ID Proxy Services：
#   https://pocket-id.org/docs/guides/proxy-services
# - Pocket ID Healthchecks 範例（含 PKCE / scope / reverse_proxy 參考）：
#   https://pocket-id.org/docs/client-examples/healthchecks

# --- 基本 ---
OAUTH2_PROXY_HTTP_ADDRESS=0.0.0.0:4180
OAUTH2_PROXY_PROVIDER=oidc
OAUTH2_PROXY_OIDC_ISSUER_URL=${issuer_url}
OAUTH2_PROXY_CLIENT_ID=${client_id}
OAUTH2_PROXY_CLIENT_SECRET=${client_secret}

# Pocket ID 建議搭配 PKCE（S256）
OAUTH2_PROXY_CODE_CHALLENGE_METHOD=S256
OAUTH2_PROXY_SCOPE=openid email profile groups

# OAuth callback：
# - oauth2-proxy 官方文件指出，未自訂 redirect_url 時，會預設使用
#   `https://<目前請求的 Host>/oauth2/callback`
# - 因此單一 oauth2-proxy 可配合同一個 OIDC Client + 多個子網域 callback 使用
# - 請在 Pocket ID 的同一個 OIDC Client 中加入所有要保護的 callback URL，
#   例如：https://app1.${cookie_parent_domain}/oauth2/callback
#   例如：https://app2.${cookie_parent_domain}/oauth2/callback
#OAUTH2_PROXY_REDIRECT_URL=https://auth.${cookie_parent_domain}/oauth2/callback

# --- Cookie / Session ---
# oauth2-proxy 文件指出 cookie_secret 可用 seed string（也可 base64）。
# 由於這裡要讓多個子網域共用登入狀態，不能使用 `__Host-` 前綴，
# 改用 `__Secure-` 並明確指定 Cookie Domain。
OAUTH2_PROXY_COOKIE_SECRET=${cookie_secret}
OAUTH2_PROXY_COOKIE_NAME=__Secure-oauth2-proxy
OAUTH2_PROXY_COOKIE_SECURE=true
OAUTH2_PROXY_COOKIE_SAMESITE=lax
OAUTH2_PROXY_COOKIE_EXPIRE=0
OAUTH2_PROXY_COOKIE_DOMAINS=.${cookie_parent_domain}

# --- 驗證控制 ---
OAUTH2_PROXY_EMAIL_DOMAINS=*
OAUTH2_PROXY_REVERSE_PROXY=true
OAUTH2_PROXY_SET_XAUTHREQUEST=true
OAUTH2_PROXY_WHITELIST_DOMAINS=.${cookie_parent_domain}

# Pocket ID 官方範例有啟用這項，避免因 email_verified 缺失而拒絕登入。
# 若你的 Pocket ID 聲明一定會帶 verified email，可改回 false。
OAUTH2_PROXY_INSECURE_OIDC_ALLOW_UNVERIFIED_EMAIL=true

# 本範本採 Nginx auth_request 模式，不讓 oauth2-proxy 自己代理業務流量。
# 因此這裡用 static://202 作為 auth-only upstream。
OAUTH2_PROXY_UPSTREAMS=static://202

# （選用）若你只想允許特定群組，可依實際 claim/群組名調整：
#OAUTH2_PROXY_ALLOWED_GROUPS=admins

# （選用）若你想把 callback 固定在 oauth2 子網域，可改走集中式 auth host，
# 並改填上方 OAUTH2_PROXY_REDIRECT_URL；但此時需同步調整 Nginx 路由設計。

# （選用）若你在 /ping、/healthz 之類路由不想登入，可按需放行：
#OAUTH2_PROXY_SKIP_AUTH_ROUTES=GET=^/ping$,GET=^/healthz$

# （選用）若你要將 Bearer Token / Authorization 往後端傳：
#OAUTH2_PROXY_PASS_ACCESS_TOKEN=true
#OAUTH2_PROXY_SET_AUTHORIZATION_HEADER=true
