// ----------------------------------------------------------------------------
// Grafana Alloy 設定檔（TGDB 產生）
// ----------------------------------------------------------------------------
// 說明：
// - 本範本預設會收集「宿主機日誌」並送到 Loki
// - 若你不想收集日誌，請把下方 loki.source.* 區塊註解或移除
//
// 重要提醒（安全/權限）：
// - 讀取宿主機 /var/log 與 journald 通常需要 rootful（或至少宿主機上有對應讀取權限）
// - 不建議把 Loki/Alloy 直接曝露到公網；請用內網（Tailscale）或防火牆白名單保護

logging {
  level  = "info"
  format = "logfmt"
}

// 將收集到的 logs 寫入 Loki
// - 若 Loki 與 Alloy 在同一台主機，且 Loki 有對外發布 3100，可用 host.containers.internal（預設值）
// - 若跨主機，請改成 Tailscale/內網 IP（並確保 Loki 3100 僅在內網可達）
loki.write "local" {
  endpoint {
    // 注意：TGDB 只讓你輸入位址（hostname/IP，可含 :port），此處會自動補上固定 API path
    url = "http://${loki_host}/loki/api/v1/push"
  }
}

// ----------------------------------------------------------------------------
// 收集：journald（systemd journal）
// ----------------------------------------------------------------------------
// 注意：要讀 journald 通常需要：
// - rootful 部署
// - Quadlet 掛載 /run/log/journal（及視情況掛載 /var/log/journal）

loki.relabel "journal" {
  forward_to = []

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }
}

loki.source.journal "read" {
  forward_to    = [loki.write.local.receiver]
  relabel_rules = loki.relabel.journal.rules
  labels        = {job = "journal"}
}

// ----------------------------------------------------------------------------
// 收集：/var/log 檔案（含常見 syslog/messages 與 *.log）
// ----------------------------------------------------------------------------
loki.source.file "varlog" {
  targets = [
    {__path__ = "/var/log/syslog", job = "varlog"},
    {__path__ = "/var/log/messages", job = "varlog"},
    {__path__ = "/var/log/*.log", job = "varlog"},
    {__path__ = "/var/log/*/*.log", job = "varlog"},
  ]

  forward_to = [loki.write.local.receiver]

  // 檔案 globbing（建議啟用；當檔案新增/消失會自動更新 targets）
  file_match {
    enabled     = true
    sync_period = "10s"
  }
}

// ----------------------------------------------------------------------------
// 收集：宿主機 Metrics（等同 node_exporter）→ 寫入 Prometheus（remote_write）
// ----------------------------------------------------------------------------
// 說明：
// - 使用 prometheus.exporter.unix（內建 node_exporter）取代獨立的 node-exporter 容器
// - 需要容器掛載 /proc、/sys、/ 到 /host/*（TGDB 的 alloy Quadlet 範本已加上）
// - Prometheus 需要啟用 remote_write receiver（Prometheus 啟動參數加入：--web.enable-remote-write-receiver）
// - Prometheus 位址建議（只填 hostname/IP，可含 :port；API path 會由範本補上）：
//   - 同機（容器→宿主機）：host.containers.internal:9090
//   - 跨機：改成你的 Tailscale/內網位址（並搭配防火牆白名單）

prometheus.exporter.unix "node" {
  procfs_path = "/host/proc"
  sysfs_path  = "/host/sys"
  rootfs_path = "/host"

  // 額外輸出 exporter 自身的資訊（方便對齊 node-exporter 與除錯）
  include_exporter_metrics = true

  // 明確啟用常用 collectors（避免不同版本/預設集合差異導致缺少 CPU/Network 等指標）
  enable_collectors = [
    "cpu",
    "diskstats",
    "filesystem",
    "loadavg",
    "meminfo",
    "netclass",
    "netdev",
    "stat",
    "time",
    "uname",
  ]

  // Network 相關指標
  netdev {
    address_info = true
  }

  // 對齊 node-exporter 容器範本的排除規則（避免把容器內的 pseudo fs 一起算進去）
  filesystem {
    mount_points_exclude = "^/(sys|proc|dev|host|etc)($|/)"
  }
}

// 標準化 instance/job label，方便沿用常見 Node Exporter Dashboard
discovery.relabel "node" {
  targets = prometheus.exporter.unix.node.targets

  rule {
    target_label = "instance"
    replacement  = "${node_instance}"
  }

  rule {
    target_label = "job"
    replacement  = "node"
  }
}

prometheus.scrape "node" {
  scrape_interval = "15s"
  targets    = discovery.relabel.node.output
  forward_to = [prometheus.remote_write.local_prom.receiver]
}

prometheus.remote_write "local_prom" {
  endpoint {
    // 注意：TGDB 只讓你輸入位址（hostname/IP，可含 :port），此處會自動補上固定 API path
    url = "http://${prom_host}/api/v1/write"
  }
}

// ----------------------------------------------------------------------------
// 參考：
// - https://grafana.com/docs/alloy/latest/reference/components/loki/loki.source.journal/
// - https://grafana.com/docs/alloy/latest/reference/components/loki/loki.source.file/
// - https://grafana.com/docs/alloy/latest/reference/components/loki/loki.write/
// - https://grafana.com/docs/alloy/latest/reference/components/prometheus/prometheus.exporter.unix/
// - https://grafana.com/docs/alloy/latest/reference/components/prometheus/prometheus.scrape/
// - https://grafana.com/docs/alloy/latest/reference/components/prometheus/prometheus.remote_write/
