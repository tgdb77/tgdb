[Unit]
Description=grav
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/getgrav/grav:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=grav
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:80/tcp

Volume=${instance_dir}/html:/var/www/html
EnvironmentFile=${instance_dir}/.env

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
