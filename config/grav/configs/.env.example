# -----------------------------------------------------------------------------
# Grav（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 若要正式對外提供服務，建議搭配 Nginx 反向代理與 HTTPS

# 空資料目錄時自動安裝 Grav
GRAV_SETUP=true

# 版本通道：stable 或 beta
GRAV_CHANNEL=stable

# 啟用 Grav 排程器
GRAV_SCHEDULER=true

# TGDB 預設使用 bind mount，啟動時順手修正權限較穩定
FIX_PERMISSIONS=true
