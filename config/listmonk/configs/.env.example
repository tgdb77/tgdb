# -----------------------------------------------------------------------------
# listmonk（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - 這份檔案會被 systemd/Quadlet 讀取並注入容器。
# - 主容器會在每次啟動時自動執行 install(idempotent) / upgrade / run。

TZ=Asia/Taipei

# listmonk Web
LISTMONK_app__address=0.0.0.0:9000

# PostgreSQL（listmonk 本體使用）
LISTMONK_db__host=127.0.0.1
LISTMONK_db__port=5432
LISTMONK_db__user=${db_user}
LISTMONK_db__password=${db_pass}
LISTMONK_db__database=listmonk
LISTMONK_db__ssl_mode=disable
LISTMONK_db__max_open=25
LISTMONK_db__max_idle=25
LISTMONK_db__max_lifetime=300s

# PostgreSQL（postgres official image 初始化）
POSTGRES_DB=listmonk
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# 若你想在首次啟動時自動建立 Super Admin，可先取消註解再部署。
#LISTMONK_ADMIN_USER=admin
#LISTMONK_ADMIN_PASSWORD=

# 其他常見設定請依需求到管理介面或官方文件調整，例如：
# - SMTP / Bounce 設定
# - 上傳媒體路徑（建議 /listmonk/uploads）
# - 公開網址 / 反向代理 / HTTPS
