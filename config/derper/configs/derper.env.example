# derper 環境變數範本（由 TGDB 生成到 instance_dir/derper.env）
#
# 注意：
# - DERP_CERT_MODE=manual 會讀取 DERP_CERT_DIR 內的 ${DERP_DOMAIN}.crt/.key
# - 本計畫預設停用 http-port（DERP_HTTP_PORT=-1）

DERP_DOMAIN=derp.<root_domain>
DERP_CERT_MODE=manual
DERP_CERT_DIR=/app/certs

# derper 監聽（容器內）
DERP_ADDR=:443
DERP_STUN=true
DERP_STUN_PORT=3478
DERP_HTTP_PORT=-1

# 防止被他人濫用（建議啟用）
# Headscale 官方建議：DERP Server 使用 Headscale 的 /verify 作為驗證端點。
# 例：https://hs.<root_domain>/verify
DERP_VERIFY_CLIENT_URL=https://hs.<root_domain>/verify
