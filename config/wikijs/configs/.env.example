# Wiki.js 環境變數
#
# 檔案位置：${instance_dir}/.env
# 參考：https://docs.requarks.io/install/docker
#
# 注意：
# - 請勿加入空白
# - 變更後需重啟單元

# -----------------------------------------------------------------------------
# Wiki.js 資料庫（PostgreSQL）
# -----------------------------------------------------------------------------
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=${user_name}
DB_PASS=${pass_word}
DB_NAME=wiki

# -----------------------------------------------------------------------------
# PostgreSQL 初始化（供 postgres:15-alpine entrypoint 使用）
# -----------------------------------------------------------------------------
POSTGRES_DB=wiki
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}

# -----------------------------------------------------------------------------
# 其他可選（依需求自行開啟）
# -----------------------------------------------------------------------------
# 啟用高可用（多副本）模式（僅適用 PostgreSQL；單機通常不需要）
# HA_ACTIVE=true
#
# 若資料庫強制 SSL，可加上（不需要就留空）
# DB_SSL=true
# DB_SSL_CA=

