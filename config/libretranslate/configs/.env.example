# LibreTranslate 環境變數
#
# 檔案位置：${instance_dir}/.env
# 參考：https://docs.libretranslate.com/guides/installation/
#
# 注意：
# - 請勿加入空白
# - 變更後需重啟單元

# -----------------------------------------------------------------------------
# 基本
# -----------------------------------------------------------------------------
# 重要：容器內請綁定 0.0.0.0，才能被 Podman/Quadlet 的 PublishPort 正常轉發。
LT_HOST=0.0.0.0
LT_PORT=5000

# 執行緒數（預設 4；可視 CPU 核心調整）
# LT_THREADS=4

# -----------------------------------------------------------------------------
# 模型載入/更新（可選）
# -----------------------------------------------------------------------------
# 只載入特定語言，降低首次啟動下載量（逗號分隔）
LT_LOAD_ONLY=en,zh

# 啟動時檢查並更新語言模型（會增加啟動時間）
# LT_UPDATE_MODELS=true

# -----------------------------------------------------------------------------
# 風險控制（可選，強烈建議對外提供時啟用）
# -----------------------------------------------------------------------------
# 啟用 API Keys（可配合請求限制，避免被濫用）
# LT_API_KEYS=true
# LT_API_KEYS_DB_PATH=/app/db/api_keys.db

# 以「每個客戶端」為單位的每分鐘請求數上限（未設定則不限）
# LT_REQ_LIMIT=60

# 單次請求最大字元數（未設定則不限）
# LT_CHAR_LIMIT=2000

# 若沒有 API key，且請求來源（Origin）不符合此網域，則拒絕程式化呼叫（可用於反代到特定域名時）
# LT_REQUIRE_API_KEY_ORIGIN=translate.example.com

# under-attack 模式：沒有 API key 的請求一律拒絕（需同時啟用 LT_API_KEYS）
# LT_UNDER_ATTACK=true

