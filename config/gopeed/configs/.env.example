# Gopeed（TGDB 產生）
#
# 參考：
# - 安裝說明：https://gopeed.com/zh-TW/docs/install
# - 上游 docker-compose：https://github.com/GopeedLab/gopeed/blob/main/docker-compose.yml
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei
PUID=${user_id}
PGID=${group_id}
UMASK=022

GOPEED_ADDRESS=0.0.0.0
GOPEED_PORT=9999
GOPEED_STORAGEDIR=/app/storage
GOPEED_WHITEDOWNLOADDIRS=/app/Downloads

# ---- 選填：基本身分驗證（若經由反向代理 / 公網對外，建議務必啟用） ----
#GOPEED_USERNAME=gopeed
#GOPEED_PASSWORD=請改成強密碼
#GOPEED_APITOKEN=

# ---- 選填：偵錯 ----
#GOPEED_DEBUG=false
