[Unit]
Description=whoogle
After=network-online.target
Wants=network-online.target

[Container]
Image=ghcr.io/benbusby/whoogle-search:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=whoogle
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:5000

Volume=${instance_dir}/config:/app/config

EnvironmentFile=${instance_dir}/.env

[Service]
Restart=on-failure
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
