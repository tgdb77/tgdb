# Whoogle Search 環境變數範本
# 說明：
# - 本檔案會在部署時複製為實例目錄的 `.env`，並由 Quadlet 以 EnvironmentFile 載入。
# - 建議先在部署流程選擇「自訂 Quadlet 與 config」，再依需求取消註解/修改變數。
# - 修改後需重啟服務才會生效（systemctl --user restart <name>.service）。
#
# 參考（官方）：
# https://github.com/benbusby/whoogle-search#environment-variables

############################
# 基本（選用）
############################

# Whoogle URL 前綴（例：/whoogle）
#WHOOGLE_URL_PREFIX=

# 若你使用 whoogle.env 機制（一般不需要，TGDB 直接用 EnvironmentFile）
#WHOOGLE_DOTENV=1
#WHOOGLE_DOTENV_PATH=./whoogle.env

# 基本認證（已強制啟用；請勿留空）
WHOOGLE_USER=${user_name}
WHOOGLE_PASS=${pass_word}

############################
# Proxy（選用）
############################

#WHOOGLE_PROXY_USER=
#WHOOGLE_PROXY_PASS=
#WHOOGLE_PROXY_TYPE=   # socks5 / socks4 / http
#WHOOGLE_PROXY_LOC=    # host 或 IP

############################
# User-Agent（選用）
############################

# 設定固定 UA（留空則使用自動產生的 Opera UA）
#WHOOGLE_USER_AGENT=
#WHOOGLE_USER_AGENT_MOBILE=

# 使用瀏覽器自身 UA（預設 false）
#WHOOGLE_USE_CLIENT_USER_AGENT=false

# UA 快取設定
#WHOOGLE_UA_CACHE_PERSISTENT=1
#WHOOGLE_UA_CACHE_REFRESH_DAYS=0
#WHOOGLE_UA_LIST_FILE=

############################
# 其他功能（選用）
############################

# 自訂重新導向（逗號分隔）
#WHOOGLE_REDIRECTS=

# Whoogle 對外暴露埠（通常不需要，TGDB 由 PublishPort 控制）
#EXPOSE_PORT=

# 強制 HTTPS（若你已透過反代提供 HTTPS，可視需求啟用）
#HTTPS_ONLY=1

# Site alternatives（選用；設為空字串可停用單一替代）
#WHOOGLE_ALT_TW=
#WHOOGLE_ALT_YT=
#WHOOGLE_ALT_RD=
#WHOOGLE_ALT_TL=
#WHOOGLE_ALT_MD=
#WHOOGLE_ALT_IMG=
#WHOOGLE_ALT_WIKI=
#WHOOGLE_ALT_IMDB=
#WHOOGLE_ALT_QUORA=
#WHOOGLE_ALT_SO=

# 自動完成（預設開啟，設為 0 關閉）
#WHOOGLE_AUTOCOMPLETE=1

# 極簡模式（移除大多 UI）
#WHOOGLE_MINIMAL=0

# 設定預設 CSP header
#WHOOGLE_CSP=1

# 每頁結果數
#WHOOGLE_RESULTS_PER_PAGE=

############################
# Tor（選用）
############################

# 啟動時啟用/停用 Tor service（預設開啟，設為 0 關閉）
#WHOOGLE_TOR_SERVICE=1

# Tor control port 密碼驗證（依官方文件）
#WHOOGLE_TOR_USE_PASS=0

# Tor control 設定檔位置
#WHOOGLE_TOR_CONF=./misc/tor/control.conf

# 注意：官方文件中曾提及 WHOOGLE_TOR_PASS（可能為舊版參數），若你的版本需要可自行加入
#WHOOGLE_TOR_PASS=0

############################
# 顯示/更新（選用）
############################

# 顯示 favicon（預設開啟）
#WHOOGLE_SHOW_FAVICONS=1

# 自動檢查更新（預設開啟）
#WHOOGLE_UPDATE_CHECK=1

# 當遇到 rate-limit/錯誤時的後備搜尋引擎 URL（會把 query 接到 URL 後方）
#WHOOGLE_FALLBACK_ENGINE_URL=

# 將 CSS/JS 打包成單檔以減少請求（預設關閉）
#WHOOGLE_BUNDLE_STATIC=0

# 上游請求啟用 HTTP/2（預設開啟，設為 0 強制 HTTP/1.1）
#WHOOGLE_HTTP2=1

############################
# 預設 UI 設定（可覆寫；選用）
############################

# 這些 WHOOGLE_CONFIG_* 用來設定「預設」值，使用者仍可在首頁設定頁覆寫。

#WHOOGLE_CONFIG_DISABLE=0
#WHOOGLE_CONFIG_COUNTRY=TW
#WHOOGLE_CONFIG_LANGUAGE=zh-TW
#WHOOGLE_CONFIG_SEARCH_LANGUAGE=zh-TW
#WHOOGLE_CONFIG_BLOCK=
#WHOOGLE_CONFIG_BLOCK_TITLE=
#WHOOGLE_CONFIG_BLOCK_URL=
#WHOOGLE_CONFIG_THEME=dark      # light / dark / system
#WHOOGLE_CONFIG_SAFE=0
#WHOOGLE_CONFIG_ALTS=1
#WHOOGLE_CONFIG_NEAR=
#WHOOGLE_CONFIG_TOR=0
#WHOOGLE_CONFIG_NEW_TAB=0
#WHOOGLE_CONFIG_VIEW_IMAGE=1
#WHOOGLE_CONFIG_GET_ONLY=0
#WHOOGLE_CONFIG_URL=
#WHOOGLE_CONFIG_STYLE=
#WHOOGLE_CONFIG_PREFERENCES_ENCRYPTED=0
#WHOOGLE_CONFIG_PREFERENCES_KEY=
#WHOOGLE_CONFIG_ANON_VIEW=0
#WHOOGLE_CONFIG_SHOW_USER_AGENT=0
