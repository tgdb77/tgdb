# Domain Locker 環境變數
#
# 檔案位置：${instance_dir}/.env
# 參考：
# - https://github.com/Lissy93/domain-locker/blob/main/docker-compose.yml
# - https://domain-locker.com/about/developing/environmental-variables
# - https://domain-locker.com/about/self-hosting/general-docker-advice
#
# 注意：
# - 請勿加入空白
# - 變更後需重啟單元
# - 文件提到 DL_* 可能會被前端讀取；若你要對外公開服務，請使用反向代理驗證/VPN，並避免在 DL_* 放入高權限機密。

# -----------------------------------------------------------------------------
# Domain Locker（應用）
# -----------------------------------------------------------------------------
# 環境類型：dev / managed / selfHosted / demo
DL_ENV_TYPE=selfHosted

# 你提供服務的對外網址（建議反代後使用 https://...）
# - 預設填本機位址，方便先確認服務能啟動
DL_BASE_URL=http://127.0.0.1:${host_port}

# （可選）停用寫入 API（僅瀏覽/唯讀）
# DL_DISABLE_WRITE_METHODS=true

# （可選）錯誤追蹤（GlitchTip）
# DL_GLITCHTIP_DSN=

# （可選）分析（Plausible）
# DL_PLAUSIBLE_URL=
# DL_PLAUSIBLE_SITE=

# -----------------------------------------------------------------------------
# Domain Locker（自架 PostgreSQL 連線）
# -----------------------------------------------------------------------------
# TGDB 採 Pod 方式部署（app 與 postgres 共享網路），因此主機填 localhost 即可。
DL_PG_HOST=localhost
DL_PG_PORT=5432
DL_PG_USER=${user_name}
DL_PG_PASSWORD=${pass_word}
DL_PG_NAME=domain_locker

# -----------------------------------------------------------------------------
# PostgreSQL 初始化（供 postgres:15-alpine entrypoint 使用）
# -----------------------------------------------------------------------------
POSTGRES_DB=domain_locker
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}

