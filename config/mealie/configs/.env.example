# -----------------------------------------------------------------------------
# Mealie（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - Mealie 預設使用 SQLite（DB_ENGINE=sqlite），資料存放於 /app/data。
# - 建議搭配 Nginx 反向代理與 HTTPS 對外提供服務。
# - 若你把資料放在 NAS/網路磁碟，建議改用 PostgreSQL（SQLite 可能出現鎖/損毀）。

# 時區
TZ=Asia/Taipei

# 權限（Mealie 支援 PUID/PGID 以調整資料目錄擁有者）
PUID=${user_id}
PGID=${group_id}

# 安全設定
ALLOW_SIGNUP=false

# 資料庫（SQLite 為預設；需要時可改成 postgres 並自行佈署 DB）
DB_ENGINE=sqlite
#SQLITE_MIGRATE_JOURNAL_WAL=true

# 通知/外部連結用的公開網址（反代到域名/HTTPS 時務必設定）
#BASE_URL=https://mealie.example.com
