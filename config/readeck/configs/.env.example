# Readeck（TGDB 產生）
# 參考：
# - https://codeberg.org/readeck/readeck
#
# 官方容器範例至少會設定：
# - READECK_SERVER_HOST=0.0.0.0
# - 掛載資料卷到 /readeck

TZ=Asia/Taipei

# 讓容器內服務可被 Podman 轉發出去
READECK_SERVER_HOST=0.0.0.0
READECK_SERVER_PORT=8000

# 若反向代理到子路徑，可依官方文件調整，例如 /readeck/
READECK_SERVER_PREFIX=/

# 若之後改用域名或反向代理，可依實際需求取消註解後調整
#READECK_ALLOWED_HOSTS=127.0.0.1,localhost
#READECK_USE_X_FORWARDED=true
