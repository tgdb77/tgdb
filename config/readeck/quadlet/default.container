[Unit]
Description=Readeck
After=network-online.target
Wants=network-online.target

[Container]
Image=codeberg.org/readeck/readeck:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=readeck
#Network=tgdb.network

PublishPort=127.0.0.1:${host_port}:8000

EnvironmentFile=${instance_dir}/.env

Volume=${instance_dir}/data:/readeck

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
