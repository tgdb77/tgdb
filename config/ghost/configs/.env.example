# Ghost（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器（包含 App 與 DB 容器）
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# Ghost 對外 URL（重要）
# - 未反代時可先用本機回環測試
# - 反代/上線後請改成 https://你的域名
url=http://127.0.0.1:${host_port}

# Ghost：資料庫設定（MySQL）
database__client=mysql
database__connection__host=127.0.0.1
database__connection__user=${db_user}
database__connection__password=${db_pass}
database__connection__database=ghost

# MySQL（同一 Pod 內的 mysql 容器會使用）
MYSQL_ROOT_PASSWORD=${mysql_root_password}
MYSQL_DATABASE=ghost
MYSQL_USER=${db_user}
MYSQL_PASSWORD=${db_pass}

