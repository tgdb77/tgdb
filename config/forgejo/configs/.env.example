# Forgejo（TGDB 產生）
# 參考：
# - https://forgejo.org/docs/latest/admin/installation-docker/
#
# 本範本採用官方 rootless image：
# - image: codeberg.org/forgejo/forgejo:13-rootless
# - data: /var/lib/gitea
# - config: /etc/gitea
# - SSH: 2222

USER_UID=${user_id}
USER_GID=${group_id}

# 預設使用 PostgreSQL（同一個 Pod 內的 postgres 容器）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=forgejo

FORGEJO__database__DB_TYPE=postgres
FORGEJO__database__HOST=127.0.0.1:5432
FORGEJO__database__NAME=forgejo
FORGEJO__database__USER=${db_user}
FORGEJO__database__PASSWD=${db_pass}
FORGEJO__database__SSL_MODE=disable

# 對外存取位址（若改用域名/反代，請改成實際網址）
FORGEJO__server__ROOT_URL=http://127.0.0.1:${host_port}/
FORGEJO__server__DOMAIN=127.0.0.1

# 內建 SSH 服務（rootless image 預設容器內使用 2222）
FORGEJO__server__START_SSH_SERVER=true
FORGEJO__server__SSH_LISTEN_PORT=2222
FORGEJO__server__SSH_PORT=${ssh_port}
FORGEJO__server__SSH_DOMAIN=127.0.0.1

# 安全保守預設：關閉公開註冊
FORGEJO__service__DISABLE_REGISTRATION=true

# 其他設定可在首次初始化後改由 app.ini 管理：
# - ${instance_dir}/conf/app.ini
