# -----------------------------------------------------------------------------
# Rybbit（TGDB 版）環境變數範本
# 參考：
# - https://github.com/rybbit-io/rybbit
# - https://www.rybbit.io/docs/self-hosting-advanced
# -----------------------------------------------------------------------------

# 基本 URL / Auth
DOMAIN_NAME=127.0.0.1:${host_port}
BASE_URL=http://127.0.0.1:${host_port}
BETTER_AUTH_SECRET=${better_auth_secret}
DISABLE_SIGNUP=false
DISABLE_TELEMETRY=true

# PostgreSQL（同 Pod 服務請走 127.0.0.1）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=${pg_user}
POSTGRES_PASSWORD=${pg_pass}

# ClickHouse（同 Pod 服務請走 127.0.0.1）
CLICKHOUSE_HOST=http://127.0.0.1:8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=${clickhouse_pass}

# Client / Server 共用
NODE_ENV=production
MAPBOX_TOKEN=
