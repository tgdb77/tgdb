# Gitea（PostgreSQL）環境變數（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

# PostgreSQL（同一個 Pod 內的 postgres 容器會使用）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=gitea

# Gitea 內建設定（以環境變數提供最小 DB 連線資訊）
GITEA__database__DB_TYPE=postgres
GITEA__database__HOST=127.0.0.1:5432
GITEA__database__NAME=gitea
GITEA__database__USER=${db_user}
GITEA__database__PASSWD=${db_pass}
GITEA__database__SSL_MODE=disable

# （選用）初次安裝後你也可以改用 app.ini 管理更多設定：
# - ${instance_dir}/data/gitea/conf/app.ini

