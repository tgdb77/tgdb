# Vikunja（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei
XDG_CACHE_HOME=/tmp/.cache

# 反代到域名後請改成 https://你的域名
VIKUNJA_SERVICE_PUBLICURL=http://127.0.0.1:${host_port}

# 建議固定，避免重啟後 Token 失效
VIKUNJA_SERVICE_JWTSECRET=${jwt_secret}

# Vikunja 資料庫連線（同一 Pod 內的 PostgreSQL）
VIKUNJA_DATABASE_TYPE=postgres
VIKUNJA_DATABASE_HOST=127.0.0.1
VIKUNJA_DATABASE_PORT=5432
VIKUNJA_DATABASE_USER=${db_user}
VIKUNJA_DATABASE_PASSWORD=${db_pass}
VIKUNJA_DATABASE_DATABASE=vikunja
VIKUNJA_DATABASE_SSLMODE=disable

# PostgreSQL 初始化（同一 Pod 內的 db 容器會使用）
POSTGRES_DB=vikunja
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
