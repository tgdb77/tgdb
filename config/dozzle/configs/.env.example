# -----------------------------------------------------------------------------
# Dozzle 環境變數範本
# -----------------------------------------------------------------------------
# 上游文件：
# - 支援環境變數：https://dozzle.dev/guide/supported-env-vars
# - Podman 說明：https://dozzle.dev/guide/podman
#
# 說明：
# 1. TGDB 預設把宿主機 127.0.0.1:${host_port} 映射到容器內 8080。
# 2. Dozzle 官方支援用環境變數或 CLI 旗標設定；這裡先保留 TGDB 常用且較安全的項目。
# 3. 若之後改成反向代理子路徑，可設定 DOZZLE_BASE，例如 /dozzle。

# 監聽位址；通常維持容器內預設 0.0.0.0:8080 即可。
DOZZLE_ADDR=:8080

# 反向代理子路徑；若直接用根路徑存取，保持 / 即可。
DOZZLE_BASE=/

# 記錄層級：debug / info / warn / error
DOZZLE_LEVEL=info

# 關閉匿名分析；TGDB 預設停用。
DOZZLE_NO_ANALYTICS=true

# 版本檢查模式：automatic / daily / weekly
DOZZLE_RELEASE_CHECK_MODE=automatic

# 顯示容器過濾器；留空代表顯示全部容器。
#DOZZLE_FILTER=

# 若要信任前置驗證代理，可改成 proxy 並搭配以下標頭設定。
#DOZZLE_AUTH_PROVIDER=proxy
#DOZZLE_AUTH_HEADER_USER=Remote-User
#DOZZLE_AUTH_HEADER_EMAIL=Remote-Email
#DOZZLE_AUTH_HEADER_NAME=Remote-Name
#DOZZLE_AUTH_HEADER_FILTER=Remote-Filter
#DOZZLE_AUTH_HEADER_ROLES=Remote-Roles
#DOZZLE_AUTH_LOGOUT_URL=

# 高風險功能，預設關閉；需要時再自行開啟。
#DOZZLE_ENABLE_ACTIONS=false
#DOZZLE_ENABLE_SHELL=false
#DOZZLE_ENABLE_MCP=false

# 可選：自訂主機名稱顯示。
#DOZZLE_HOSTNAME=

# 可選：停用頭像顯示。
#DOZZLE_DISABLE_AVATARS=false

# 可選：連線遠端主機 / Agent（可用逗號分隔多個）。
#DOZZLE_REMOTE_HOST=
#DOZZLE_REMOTE_AGENT=
#DOZZLE_TIMEOUT=10s
