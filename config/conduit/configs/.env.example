# Conduit（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 若要對外提供服務，建議搭配 Nginx 反向代理與 HTTPS

TZ=Asia/Taipei

# 啟用「純環境變數」模式（不從外部讀取 conduit.toml）
CONDUIT_CONFIG=

# Matrix 伺服器名稱（例：matrix.example.com）
CONDUIT_SERVER_NAME=${server_name}

# 容器內資料庫設定（RocksDB）
CONDUIT_DATABASE_BACKEND=rocksdb
CONDUIT_DATABASE_PATH=/var/lib/matrix-conduit/

# 容器內監聽設定
CONDUIT_ADDRESS=0.0.0.0
CONDUIT_PORT=6167

# 安全預設：關閉新帳號註冊
CONDUIT_ALLOW_REGISTRATION=false

# 是否開啟 Federation（與其他 Matrix 伺服器互通）
CONDUIT_ALLOW_FEDERATION=true

# 日誌層級（trace/debug/info/warn/error）
CONDUIT_LOG=warn
