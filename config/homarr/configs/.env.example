# Homarr 環境變數
#
# 檔案位置：${instance_dir}/.env
# 官方文件：
# - 安裝：https://homarr.dev/docs/next/getting-started/installation/portainer/
# - 環境變數：https://homarr.dev/docs/1.42.0/advanced/environment-variables/
# - Docker 整合：https://homarr.dev/docs/1.41.0/integrations/docker/
#
# 注意：
# - 變更後需重新啟動單元
# - 這裡採保守預設：內建 SQLite、僅本機回環，不預設掛 docker/podman socket

# 核心加密金鑰（必填；TGDB 自動產生）
SECRET_ENCRYPTION_KEY=${secret_encryption_key}

# 一般設定
LOG_LEVEL=info
NO_EXTERNAL_CONNECTION=false
ENABLE_DNS_CACHING=false

# 內建 SQLite（官方預設）
DB_DRIVER=better-sqlite3
DB_DIALECT=sqlite
DB_URL=/appdata/db/db.sqlite

# 若要改用外部資料庫，可依官方文件改成：
#DB_DRIVER=node-postgres
#DB_DIALECT=postgresql
#DB_URL=postgresql://homarr:請改成你的密碼@127.0.0.1:5432/homarr

# 若要改用外部 Redis，可依官方文件補上：
#REDIS_IS_EXTERNAL=true
#REDIS_HOST=127.0.0.1
#REDIS_PORT=6379
#REDIS_PASSWORD=
#REDIS_DATABASE_INDEX=0

# 若要接 Docker / Podman socket proxy，可補：
#DOCKER_HOSTNAMES=socket-proxy
#DOCKER_PORTS=2375
