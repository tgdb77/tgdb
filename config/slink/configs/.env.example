# -----------------------------------------------------------------------------
# Slink 環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - 官方 Docker Compose 安裝：https://docs.slinkapp.io/installation/01-docker-compose/
# - 官方 Quick Start：https://docs.slinkapp.io/getting-started/02-quick-start/
# - 官方 GitHub：https://github.com/andrii-kryvoviaz/slink
#
# 注意：
# - 變更後需重新啟動單元
# - 本範本採 local storage，資料庫持久化於 ${instance_dir}/data
# - 上傳圖片會保存於 volume_dir（掛載到 /app/slink/images）

TZ=Asia/Taipei

# 反代到正式域名 / HTTPS 後請改成你的公開網址
ORIGIN=http://127.0.0.1:${host_port}
REQUIRE_SSL=false

# 初始管理員（首次啟動自動建立；後續可移除）
ADMIN_USERNAME=${admin_user}
ADMIN_EMAIL=${admin_email}
ADMIN_PASSWORD=${admin_password}

# 使用者安全策略
USER_ALLOW_REGISTRATION=false
USER_APPROVAL_REQUIRED=true
USER_PASSWORD_MIN_LENGTH=8
USER_PASSWORD_REQUIREMENTS=15

# 圖片處理
IMAGE_MAX_SIZE=15M
IMAGE_STRIP_EXIF_METADATA=true
IMAGE_COMPRESSION_QUALITY=80

# 儲存設定
STORAGE_PROVIDER=local
