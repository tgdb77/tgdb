# Tandoor Recipes（TGDB 產生）
#
# 參考：
# - 官方文件：https://docs.tandoor.dev/install/docker/
# - GitHub：https://github.com/TandoorRecipes/recipes
#
# 注意：
# - 變更後需重新啟動單元

TZ=Asia/Taipei

# Django 密鑰
SECRET_KEY=${secret_key}

# 站點設定
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:${host_port}
ALLAUTH_TRUSTED_PROXY_COUNT=1

# 保守預設：關閉公開註冊，改由 TGDB 於部署後建立第一個管理員
SIGNUP_OPEN=False

# 資料庫（PostgreSQL）
DB_ENGINE=django.db.backends.postgresql
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=tandoor
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# 靜態 / 媒體
GUNICORN_MEDIA=0

# 其他常用選填設定
#DEBUG=0
#FRACTION_PREF_DEFAULT=0
#COMMENT_PREF_DEFAULT=1
#SHOPPING_MIN_AUTOSYNC_INTERVAL=5

# Email（選填）
#EMAIL_HOST=
#EMAIL_PORT=587
#EMAIL_HOST_USER=
#EMAIL_HOST_PASSWORD=
#EMAIL_USE_TLS=True
