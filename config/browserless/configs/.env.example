# Browserless（Open Source）環境變數範本
#
# 檔案位置：${instance_dir}/.env
# 參考：
# - https://github.com/browserless/browserless
# - https://docs.browserless.io/enterprise/docker/config
#
# 注意：
# - 此服務預設以 Token 保護 API；請勿移除 TOKEN。
# - 變更後需重啟單元。

# -----------------------------------------------------------------------------
# 基本監聽
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=3000
TZ=Asia/Taipei

# -----------------------------------------------------------------------------
# 安全性
# -----------------------------------------------------------------------------
# 重要：請保留長隨機 Token，避免未授權呼叫遠端瀏覽器 API。
TOKEN=${token}

# -----------------------------------------------------------------------------
# 資源 / 併發（未填時採上游預設）
# -----------------------------------------------------------------------------
# 同時可執行的瀏覽器工作數
#CONCURRENT=

# 佇列長度上限
#QUEUED=

# 單次工作逾時（毫秒）
#TIMEOUT=

# -----------------------------------------------------------------------------
# 其他設定
# -----------------------------------------------------------------------------
# 如需更多 Browserless 環境變數，請參考上方官方文件後再自行加入。
