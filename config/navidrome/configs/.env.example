# -----------------------------------------------------------------------------
# Navidrome 環境變數範本
# -----------------------------------------------------------------------------
# 注意：此檔案可能包含敏感設定，建議權限設為 600。
#
# 參考：
# - https://www.navidrome.org/docs/usage/configuration-options/

ND_SCANSCHEDULE=48h
ND_LOGLEVEL=info
ND_SESSIONTIMEOUT=240h

# 反代到子路徑時可用（例：/navidrome）
ND_BASEURL=

ND_CHECKLASTMODIFIED=true
ND_SCANCONCURRENCY=8
ND_TRANSCODINGCACHESIZE=4000M
ND_IMAGECACHESIZE=1000M
ND_SUBSONIC_DEFAULTREPORTREALPATH=false
ND_ENABLEPWA=true
ND_ENABLETRANSCODINGCONFIG=false
ND_ENABLEDOWNLOADS=false
ND_ENABLESHARING=false
ND_ENABLEINSIGHTSCOLLECTOR=false
