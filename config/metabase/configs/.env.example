# Metabase（TGDB 產生）
#
# 提醒：
# - 首次部署預設採本機回環存取；完成 Nginx 反向代理後，請改成你的正式 HTTPS 網域
# - 若用於正式環境，建議固定 MB_ENCRYPTION_SECRET_KEY，避免未來密文無法解密

TZ=Asia/Taipei
JAVA_TIMEZONE=Asia/Taipei

# Metabase 對外位址（完成反向代理後請改成正式網域）
MB_SITE_URL=http://127.0.0.1:${host_port}
MB_JETTY_PORT=3000

# Metabase 應用資料庫（PostgreSQL）
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=${user_name}
MB_DB_PASS=${pass_word}
MB_DB_HOST=localhost

# Metabase 加密金鑰（請妥善保存）
MB_ENCRYPTION_SECRET_KEY=${mb_encryption_key}

# PostgreSQL（供 postgres official image 初始化）
POSTGRES_DB=metabase
POSTGRES_USER=${user_name}
POSTGRES_PASSWORD=${pass_word}
