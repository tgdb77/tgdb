# Pixelfed（jippi/docker-pixelfed）範本
# 參考：
# - 安裝指引：https://jippi.github.io/docker-pixelfed/installation/guide/
# - 設定說明：https://jippi.github.io/docker-pixelfed/customize/settings/
#
# 說明：
# - 此檔案同時作為 Pixelfed 應用程式環境變數與容器 EnvironmentFile。
# - 預設以「保守、安全」為主：關閉公開註冊、不直接對外暴露、郵件改寫到 log。

APP_NAME="${site_name}"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://${app_domain}
APP_DOMAIN=${app_domain}
ADMIN_DOMAIN=${app_domain}
APP_KEY=

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Pixelfed 安全預設：先關閉公開註冊，待你完成 HTTPS / 郵件設定後再自行開啟。
OPEN_REGISTRATION=false
ENFORCE_EMAIL_VERIFICATION=false
PF_ENABLE_CLOUD=false

# Pixelfed 官方 docker image 相關設定
DOCKER_APP_RELEASE=v0.12
DOCKER_APP_RUNTIME=apache
DOCKER_APP_PHP_VERSION=8.4
DOCKER_APP_DEBIAN_RELEASE=bookworm
DOCKER_APP_TAG=v0.12-apache-8.4-bookworm
DOCKER_APP_RUN_ONE_TIME_SETUP_TASKS=1

# 預設不要在每次升級時自動套用新 migration；建議先備份再手動評估。
DB_APPLY_NEW_MIGRATIONS_AUTOMATICALLY=0

# --- MariaDB（Pixelfed 應用使用） ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pixelfed
DB_USERNAME=${db_user}
DB_PASSWORD=${db_pass}

# --- MariaDB（資料庫容器初始化使用） ---
MARIADB_DATABASE=pixelfed
MARIADB_USER=${db_user}
MARIADB_PASSWORD=${db_pass}
MARIADB_ROOT_PASSWORD=${db_root_pass}

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=${redis_pass}
REDIS_CLIENT=phpredis

# Laravel / Pixelfed 建議把快取、Session、Queue 都交給 Redis。
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_DRIVER=redis
BROADCAST_DRIVER=log

# 預設先把寄信寫入 log；若要開放註冊或寄送驗證信，請改成 SMTP 並補齊設定。
MAIL_DRIVER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_FROM_ADDRESS=noreply@${app_domain}
MAIL_FROM_NAME="${site_name}"

# 反向代理後若有需要，可自行補上：
#TRUST_PROXIES=*
INSTANCE_CONTACT_EMAIL=admin@${app_domain}
