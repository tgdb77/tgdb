# new-api（QuantumNous/new-api）環境變數範本
# - 上游參考：.env.example
#   https://github.com/QuantumNous/new-api/blob/main/.env.example
#
# 注意：
# - 此檔案會由 systemd 讀取（EnvironmentFile），不會直接「掛載」到容器檔案系統。
# - 修改後請重啟單元（依你的容器名稱調整）：
#   systemctl --user restart ${container_name}.pod ${container_name}.container ${container_name}-postgres.container ${container_name}-redis.container

# =========================
# 基本設定（上游同名）
# =========================
PORT=3000

TZ=Asia/Taipei

# 前端網址（你若使用反向代理，請改成你的公開 URL，例如：https://api.example.com）
FRONTEND_BASE_URL=http://127.0.0.1:${host_port}

# TLS / HTTP 跳過驗證設定
TLS_INSECURE_SKIP_VERIFY=true

# 是否開啟前端（上游預設 true；若你只當 API 用可視需求調整）
ENABLE_FRONTEND=true

# Session secret（上游：SESSION_SECRET）
SESSION_SECRET=${session_secret}

# =========================
# PostgreSQL（容器初始化用）
# =========================
POSTGRES_DB=new_api
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# =========================
# SQL（上游：SQL_DSN / LOG_SQL_DSN）
# - new-api 支援 PostgreSQL（README 有提到 PostgreSQL >= 9.6）
# - 由於部署採 Pod，同 Pod 內用 127.0.0.1 連線即可
# =========================
SQL_DSN=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/new_api?sslmode=disable
#LOG_SQL_DSN=postgresql://${db_user}:${db_pass}@127.0.0.1:5432/new_api?sslmode=disable

# =========================
# Redis（上游：REDIS_CONN_STRING / CRYPTO_SECRET）
# =========================
REDIS_PASSWORD=${db_pass}
REDIS_CONN_STRING=redis://:${db_pass}@127.0.0.1:6379/0
CRYPTO_SECRET=${crypto_secret}
# 同步頻率(單位：秒)
# SYNC_FREQUENCY=60
# 記憶體緩存
# MEMORY_CACHE_ENABLED=true
# 渠道更新頻率(單位：秒)
# CHANNEL_UPDATE_FREQUENCY=30
# 批量更新
# BATCH_UPDATE_ENABLED=true
# 批量更新間隔(單位：秒)
# BATCH_UPDATE_INTERVAL=5

# 任務和功能設定
# 更新任務
# UPDATE_TASK=true

# 對話逾時設定
# 所有請求超時時間，單位秒，預設為0，表示不限制
# RELAY_TIMEOUT=0
# 流模式無反應逾時時間，單位秒，若出現空補全可以嘗試改為更大值
# STREAMING_TIMEOUT=300

# Gemini 辨識圖片 最大圖片數量
# GEMINI_VISION_MAX_IMAGE_NUM=16

# 是否自動生成預設 Token（上游：GENERATE_DEFAULT_TOKEN）
# - 若你打算自行建立/管理 Token，可關閉
#GENERATE_DEFAULT_TOKEN=true
#TOKEN_EXPIRATION_TIME=0
