# -----------------------------------------------------------------------------
# Audiobookshelf 環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - 官方文件：https://www.audiobookshelf.org/docs
# - 官方 Docker 安裝指南：https://www.audiobookshelf.org/guides/docker-install
# - 官方 compose：https://github.com/advplyr/audiobookshelf/blob/master/docker-compose.yml
#
# 注意：
# - 變更後需重新啟動單元
# - /config 與 /metadata 由 TGDB instance_dir 管理
# - 媒體資料由 volume_dir 掛載到容器內的 /library

TZ=Asia/Taipei
CONFIG_PATH=/config
METADATA_PATH=/metadata

# 如需覆寫監聽設定，可自行取消註解：
#HOST=0.0.0.0
#PORT=80
