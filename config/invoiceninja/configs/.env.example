# Invoice Ninja（TGDB 產生）
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器（包含 App/DB/Redis 容器）
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# ---- Invoice Ninja ----
APP_URL=http://127.0.0.1:${host_port}
APP_KEY=
APP_ENV=production
APP_DEBUG=false
REQUIRE_HTTPS=false

PHANTOMJS_PDF_GENERATION=false
PDF_GENERATOR=snappdf

TRUSTED_PROXIES=*

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

FILESYSTEM_DISK=debian_docker

# ---- Database ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ninja
DB_USERNAME=${db_user}
DB_PASSWORD=${db_pass}
DB_ROOT_PASSWORD=${mysql_root_password}

# 首次啟動建立管理員帳號（建立完成後可移除這兩行）
IN_USER_EMAIL=${admin_email}
IN_PASSWORD=${admin_pass}

# ---- Mail（預設僅記錄到 log）----
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=user@example.com
MAIL_FROM_NAME=SelfHostedUser

# ---- MySQL（同一 Pod 內的 mysql 容器會使用）----
MYSQL_ROOT_PASSWORD=${mysql_root_password}
MYSQL_DATABASE=ninja
MYSQL_USER=${db_user}
MYSQL_PASSWORD=${db_pass}

IS_DOCKER=true

