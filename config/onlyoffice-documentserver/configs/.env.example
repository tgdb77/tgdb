# -----------------------------------------------------------------------------
# ONLYOFFICE DocumentServer（TGDB 產生）
# -----------------------------------------------------------------------------
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - JWT secret 請與外部整合服務保持一致

TZ=Asia/Taipei

# 建議固定 JWT 設定，避免容器重啟後對端整合失效
JWT_ENABLED=true
JWT_SECRET=${jwt_secret}
JWT_HEADER=Authorization
JWT_IN_BODY=false

# 保守安全預設：停用示例頁與管理面板
EXAMPLE_ENABLED=false
ADMINPANEL_ENABLED=false

# 與內網儲存服務整合時，依需求改成 true
ALLOW_PRIVATE_IP_ADDRESS=false
ALLOW_META_IP_ADDRESS=false

# 若後續經 HTTPS 反向代理且對端使用自簽憑證，可再視需求改成 true
USE_UNAUTHORIZED_STORAGE=false

# 首次啟動可保留 true；若之後不想每次重建字型快取，可手動改成 false
GENERATE_FONTS=true
