# -----------------------------------------------------------------------------
# Gokapi 設定範本（環境變數）
# -----------------------------------------------------------------------------
# 注意：此檔案可能包含敏感資訊（例如雲端儲存金鑰），建議權限設為 600。
#
# 重要提醒（關於「持久化」）：
# - Gokapi 有一部分環境變數屬於「持久化設定」：只在首次啟動、建立 `config.json` 時寫入。
# - 若已完成初始化（已有 `config.json`），之後再改這些持久化變數通常會被忽略，需改設定檔本身。
# - 非持久化變數則需要每次啟動都提供。
#
# 本檔案依官方文件（Environment variables）整理，變數名稱請勿自行拼寫。

# 時區（通常由容器外部提供，但放在這裡方便一併管理）
TZ=Asia/Taipei

# -----------------------------------------------------------------------------
# Web / 反向代理（常用）
# -----------------------------------------------------------------------------

# Gokapi 監聽埠（持久化；預設 53842）
#GOKAPI_PORT=53842

# 信任的反向代理 IP/CIDR 清單（非持久化；逗號分隔）
# - 例：127.0.0.1,10.0.0.0/8,192.168.0.0/16
GOKAPI_TRUSTED_PROXIES=127.0.0.1

# 若你使用 Cloudflare 代理，設為 true（非持久化）
#GOKAPI_USE_CLOUDFLARE=true

# -----------------------------------------------------------------------------
# 上傳/限制（持久化）
# -----------------------------------------------------------------------------

# 上傳分塊大小（MiB；預設 45）
GOKAPI_CHUNK_SIZE_MB=45

# 上傳時允許寫入 RAM 的最大大小（MiB；預設 50）
# - 任何大於此值的 chunk/file 會寫入暫存檔
GOKAPI_MAX_MEMORY_UPLOAD=50

# 單檔最大大小（MiB；預設 102400 = 100GB）
GOKAPI_MAX_FILESIZE=102400

# 同一檔案並行上傳 chunk 數量（預設 3）
GOKAPI_MAX_PARALLEL_UPLOADS=3

# -----------------------------------------------------------------------------
# ID / Hotlink（多為持久化）
# -----------------------------------------------------------------------------

# 下載 ID 長度（非持久化；預設 15；需 >= 5）
#GOKAPI_LENGTH_ID=15

# Hotlink ID 長度（非持久化；預設 40；需 >= 8）
#GOKAPI_LENGTH_HOTLINK_ID=40

# 允許影片 hotlink（非持久化；預設 false）
# - 注意：影片播放可能因緩衝而被計為多次下載，僅建議用於「無限下載」的分享
#GOKAPI_ENABLE_HOTLINK_VIDEOS=false

# -----------------------------------------------------------------------------
# 訪客/請求（多為非持久化）
# -----------------------------------------------------------------------------

# 預設允許所有使用者建立 file request（非持久化；預設 false）
#GOKAPI_GUEST_UPLOAD_BY_DEFAULT=false

# 非管理員建立的 file request 最多可上傳檔案數（非持久化；0=不限制；預設 100）
#GOKAPI_MAX_FILES_GUESTUPLOAD=100

# 非管理員建立的 file request 單檔最大大小（MiB；非持久化；0=沿用 GOKAPI_MAX_FILESIZE；預設 10240=10GB）
#GOKAPI_MAX_SIZE_GUESTUPLOAD=10240

# -----------------------------------------------------------------------------
# 儲存/路徑（部分為持久化）
# -----------------------------------------------------------------------------

# 設定檔目錄（非持久化；預設 config）
#GOKAPI_CONFIG_DIR=config

# 設定檔檔名（非持久化；預設 config.json）
#GOKAPI_CONFIG_FILE=config.json

# 資料目錄（持久化；預設 data）
#GOKAPI_DATA_DIR=data

# 暫存目錄（非持久化）
# - 非 Docker：依 OS 預設
# - Docker：預設使用 [DATA_DIR]
#TMPDIR=

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------

# 啟動時/安裝精靈時停用 CORS 檢查（非持久化；預設 false）
#GOKAPI_DISABLE_CORS_CHECK=false

# 停用自動把 Docker 子網加入 trusted proxies（非持久化；預設 false）
#GOKAPI_DISABLE_DOCKER_TRUSTED_PROXY=false

# 也把 log 輸出到 stdout（非持久化；預設 false）
#GOKAPI_LOG_STDOUT=false

# 最小剩餘磁碟空間（MiB；非持久化；預設 400）
#GOKAPI_MIN_FREE_SPACE=400

# 最小密碼長度（非持久化；預設 8；需 >= 6）
#GOKAPI_MIN_LENGTH_PASSWORD=8

# Docker only：以非 root 執行（已 deprecated；請以文件為準）
#DOCKER_NONROOT=false

# -----------------------------------------------------------------------------
# AWS S3（或 S3 相容；非持久化：每次啟動都需提供）
# -----------------------------------------------------------------------------
#GOKAPI_AWS_BUCKET=
#GOKAPI_AWS_REGION=
#GOKAPI_AWS_KEY=
#GOKAPI_AWS_KEY_SECRET=
#
# 若你使用非 AWS 的 S3 相容服務（例如 Backblaze B2 S3 Endpoint），需要設定 endpoint
#GOKAPI_AWS_ENDPOINT=
