# Apprise API（TGDB 產生）
# 參考：
# - https://github.com/caronc/apprise-api
#
# 依官方 docker run / compose 範例整理：
# - image: caronc/apprise:latest
# - /config：儲存設定與 store
# - /plugin：自訂 plugin（可選）
# - /attach：附件

TZ=Asia/Taipei

# 依官方範例：簡單狀態模式，適合自架單機使用
APPRISE_STATEFUL_MODE=simple
APPRISE_CONFIG_LOCK=yes
APPRISE_ATTACH_SIZE=0

# 依官方範例：開啟管理功能，便於使用 Web UI 管理設定
APPRISE_ADMIN=y

# 輕量自架預設工作執行緒
APPRISE_WORKER_COUNT=2

# 可選：公開到外網時可考慮開啟嚴格模式
#STRICT_MODE=yes
