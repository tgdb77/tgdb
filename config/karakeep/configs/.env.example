# Karakeep 環境變數（最小範本）
# 參考：
# - https://docs.karakeep.app/installation/docker/
# - https://docs.karakeep.app/configuration/environment-variables/

# 對外網址（請依你的實際對外域名調整；用反代時要改為 https://...）
NEXTAUTH_URL=http://127.0.0.1:${host_port}

# 必填：密鑰（已由 TGDB 自動產生）
NEXTAUTH_SECRET=${nextauth_secret}

# Meilisearch master key（已由 TGDB 自動產生）
MEILI_MASTER_KEY=${meili_master_key}
MEILI_ADDR=http://127.0.0.1:7700
MEILI_NO_ANALYTICS=true
BROWSER_WEB_URL=http://127.0.0.1:9222

DATA_DIR=/data

#註冊好管理員帳號後須打開關閉註冊
#DISABLE_SIGNUPS=true

#（可選）OpenAI API Key（用於 AI 自動標籤）
#OPENAI_API_KEY=

