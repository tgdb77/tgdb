[Unit]
Description=karakeep meilisearch
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/getmeili/meilisearch:v1.37.0
#AutoUpdate=registry
ContainerName=${container_name}-meilisearch
Label=app=karakeep

Pod=${container_name}.pod

EnvironmentFile=${instance_dir}/.env

Volume=${instance_dir}/meili_data:/meili_data

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false

