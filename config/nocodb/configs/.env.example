# -----------------------------------------------------------------------------
# NocoDB（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - 這份檔案會被 systemd/Quadlet 讀取並注入容器（同時供 PostgreSQL 初始化使用）。
# - 預設採用「同一個 Pod」內建 PostgreSQL + Redis：
#   - NocoDB：8080
#   - PostgreSQL：5432（不對外發布）
#   - Redis：6379（不對外發布）
# - NocoDB 仍會使用 /usr/app/data 儲存附件/工具檔案（已掛載到 ${instance_dir}/data）。
#
# 文件：
# - https://docs.nocodb.com/

TZ=Asia/Taipei

# -----------------------------
# NocoDB
# -----------------------------
PORT=8080

# 建議固定 JWT secret，避免重啟後登入狀態/Token 失效
NC_AUTH_JWT_SECRET=${auth_jwt_secret}

# 建議設定，避免外部資料庫連線資訊以明文保存（變更此值可能導致既有資料源失效）
NC_CONNECTION_ENCRYPT_KEY=${connection_encrypt_key}

# 主要資料庫（預設使用 Pod 內 PostgreSQL）
NC_DB=pg://127.0.0.1:5432?u=${db_user}&p=${db_pass}&d=nocodb

# 快取（NocoDB 文件標示為 Mandatory；預設使用 Pod 內 Redis）
NC_REDIS_URL=redis://127.0.0.1:6379

# 若你透過反向代理/自訂網域對外提供服務，建議設定公開 URL（避免部分連結/回呼不正確）
# NC_PUBLIC_URL=https://nocodb.example.com

# 可選：初始化 Super Admin（需要同時設定兩個變數）
# NC_ADMIN_EMAIL=admin@example.com
# NC_ADMIN_PASSWORD=（至少 8 字元，需含大寫/數字/特殊字元）

# -----------------------------
# PostgreSQL（postgres official image 初始化）
# -----------------------------
POSTGRES_DB=nocodb
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
