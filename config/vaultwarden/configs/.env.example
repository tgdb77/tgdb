# Vaultwarden 環境變數設定檔

TZ=Asia/Taipei
DOMAIN=${domain}

# 部署時會在終端明顯顯示，請務必複製保存
ADMIN_TOKEN=

# 其他常用設定（可依需求取消註解）
# SIGNUPS_ALLOWED=false
# SHOW_PASSWORD_HINT=true
# INVITATIONS_ALLOWED=true
# ATTACHMENT_LIMIT=1000

# SMTP 設定（強烈建議設定）
# SMTP_HOST=smtp.example.com
# SMTP_FROM=vaultwarden@example.com
# SMTP_SECURITY=starttls
# SMTP_PORT=587
