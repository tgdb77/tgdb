# -----------------------------------------------------------------------------
# LibreDesk（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - PostgreSQL 與 Redis 會在同一個 Pod 內啟動，僅供 LibreDesk 容器內部連線。
# - System 帳號初始密碼只會在首次安裝建立時使用；後續若要重設，請在容器內執行
#   ./libredesk --set-system-user-password。

# 時區
TZ=Asia/Taipei

# 初始 System 帳號密碼（首次安裝時使用）
LIBREDESK_SYSTEM_USER_PASSWORD=${system_pass}

# PostgreSQL 初始化（postgres 容器使用）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=libredesk
