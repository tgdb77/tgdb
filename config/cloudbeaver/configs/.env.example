# -----------------------------------------------------------------------------
# CloudBeaver（TGDB 產生）
# -----------------------------------------------------------------------------
# 注意：此檔案包含管理員密碼，建議權限設為 600。
#
# 建議使用方式（最穩、最小暴露面）：
# - CloudBeaver 對外僅綁 127.0.0.1（透過 SSH / VS Code 埠轉發或 Nginx 反代存取）
# - 若要連 TGDB 內其他資料庫容器，請搭配 tgdb.network 與容器名稱

# 首次啟動自動完成管理員初始化
CB_SERVER_NAME=CloudBeaver
CB_SERVER_URL=http://127.0.0.1:${host_port}/
CB_ADMIN_NAME=${admin_user}
CB_ADMIN_PASSWORD=${admin_pass}

# 允許管理員建立自訂資料庫連線
CLOUDBEAVER_APP_SUPPORTS_CUSTOM_CONNECTIONS=true

# 保守安全預設：停用匿名存取
CLOUDBEAVER_APP_ANONYMOUS_ACCESS_ENABLED=false

# 若後續改成 HTTPS 反向代理，可改成 true
CLOUDBEAVER_FORCE_HTTPS=false
