# Ackee（TGDB 產生）
#
# 參考：
# - GitHub：https://github.com/electerious/Ackee
# - 官方 docker-compose.yml：https://raw.githubusercontent.com/electerious/Ackee/master/docker-compose.yml
# - 官方 app.json：https://raw.githubusercontent.com/electerious/Ackee/master/app.json
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器（包含 Ackee 與 MongoDB 容器）
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# Ackee 管理介面帳號
ACKEE_USERNAME=${admin_user}
ACKEE_PASSWORD=${admin_pass}

# MongoDB（同一 Pod 內直連）
ACKEE_MONGODB=mongodb://127.0.0.1:27017/ackee
WAIT_HOSTS=127.0.0.1:27017

# CORS / Tracker
# - 官方 app.json 將 ACKEE_ALLOW_ORIGIN 列為 required
# - 這裡先保守只允許本機回環；正式上線請改成實際被追蹤網站來源
ACKEE_ALLOW_ORIGIN=http://127.0.0.1:${host_port}
ACKEE_AUTO_ORIGIN=true

# ---- 其他選填設定 ----
#ACKEE_TTL=86400000
#ACKEE_TRACKER=tracker.js
