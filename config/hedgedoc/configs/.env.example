# HedgeDoc 環境變數
#
# 檔案位置：${instance_dir}/.env
# 官方文件：https://docs.hedgedoc.org/setup/docker/
#
# 注意：
# - 變更後需重新啟動單元
# - 若改成正式域名 / HTTPS，請同步調整下方網域與反代相關設定

# -----------------------------------------------------------------------------
# HedgeDoc 基本設定
# -----------------------------------------------------------------------------
CMD_DOMAIN=127.0.0.1
CMD_PORT=${host_port}
CMD_URL_ADDPORT=true
CMD_ALLOW_ORIGIN=127.0.0.1,localhost
CMD_PROTOCOL_USESSL=false
CMD_HSTS_ENABLE=false
CMD_SESSION_SECRET=${SESSION_SECRET}

# -----------------------------------------------------------------------------
# 登入 / 權限 / 安全預設
# -----------------------------------------------------------------------------
CMD_EMAIL=true
CMD_ALLOW_EMAIL_REGISTER=true
CMD_ALLOW_ANONYMOUS=false
CMD_ALLOW_ANONYMOUS_EDITS=false
CMD_ALLOW_FREEURL=false
CMD_REQUIRE_FREEURL_AUTHENTICATION=true
CMD_DEFAULT_PERMISSION=limited
CMD_ENABLE_UPLOADS=registered

# -----------------------------------------------------------------------------
# 資料庫（PostgreSQL）
# -----------------------------------------------------------------------------
CMD_DB_URL=postgres://${db_user}:${db_pass}@localhost:5432/hedgedoc
POSTGRES_DB=hedgedoc
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}

# -----------------------------------------------------------------------------
# 上傳檔案
# -----------------------------------------------------------------------------
CMD_IMAGE_UPLOAD_TYPE=filesystem

# 若要改成正式網址，可參考下列範例：
# CMD_DOMAIN=notes.example.com
# CMD_PORT=443
# CMD_URL_ADDPORT=false
# CMD_ALLOW_ORIGIN=notes.example.com
# CMD_PROTOCOL_USESSL=true
# CMD_HSTS_ENABLE=true
