# Umami（PostgreSQL）環境變數
#
# 注意：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 不要在值內包含空白，避免 EnvironmentFile 解析問題

# Umami 需要的最小設定
DATABASE_URL=postgresql://${db_user}:${db_pass}@localhost:5432/umami
APP_SECRET=${app_secret}
HASH_SALT=${hash_salt}

# （選用）明確指定資料庫類型（部分部署情境便於除錯）
DATABASE_TYPE=postgresql

# PostgreSQL（同一個 Pod 內的 postgres 容器會使用）
POSTGRES_USER=${db_user}
POSTGRES_PASSWORD=${db_pass}
POSTGRES_DB=umami

TZ=Asia/Taipei

# （選用）若你使用 Nginx 反向代理到域名，可依官方文件設定公開網址（不同版本命名可能不同）
#BASE_URL=https://analytics.example.com
#APP_URL=https://analytics.example.com
