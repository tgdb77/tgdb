# -----------------------------------------------------------------------------
# Termix（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - 目前這份範本預設停用遠程桌面功能，不部署 guacd。
# - 持久化資料會寫入 ${instance_dir}/data，包含資料庫、憑證與自動產生的秘密。
# - 若你放在反向代理後方，請依實際情況調整 HTTPS / Base Path / OIDC 設定。

# 服務連接埠（容器內固定 4090；若你手動修改，請同步調整 Quadlet）
PORT=8080

# 基本執行環境
NODE_ENV=production
DATA_DIR=/app/data
TZ=Asia/Taipei
PUID=${user_id}
PGID=${group_id}

# 停用遠程桌面支援（不連 guacd）
ENABLE_GUACAMOLE=false
#GUACD_HOST=localhost
#GUACD_PORT=4822

# SSL / HTTPS
SSL_ENABLED=false
#SSL_PORT=8443
#SSL_DOMAIN=termix.example.com
#SSL_CERT_PATH=/app/data/ssl/termix.crt
#SSL_KEY_PATH=/app/data/ssl/termix.key

# 反向代理 / 前端路徑
VITE_BASE_PATH=/
#OIDC_FORCE_HTTPS=true

# OIDC（需要時再填）
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_ISSUER_URL=
#OIDC_AUTHORIZATION_URL=
#OIDC_TOKEN_URL=
#OIDC_USERINFO_URL=
#OIDC_IDENTIFIER_PATH=sub
#OIDC_NAME_PATH=name
#OIDC_SCOPES=openid email profile
#OIDC_ALLOWED_USERS=

# 其他說明：
# - JWT_SECRET、DATABASE_KEY、INTERNAL_AUTH_TOKEN 會在首次啟動時自動產生並保存到資料目錄。
