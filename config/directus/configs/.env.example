# Directus（TGDB 產生）
#
# 參考：
# - Self-Hosting Quickstart：https://docs.directus.io/self-hosted/quickstart
# - Docker Guide：https://docs.directus.io/self-hosted/docker-guide
# - Configuration：https://docs.directus.io/docs/configuration/general
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# 基本設定
HOST=0.0.0.0
PORT=8055
SECRET=${secret}

# 初始管理員（首次 bootstrap 時使用）
ADMIN_EMAIL=${admin_email}
ADMIN_PASSWORD=${admin_pass}

# SQLite（官方 Quickstart 預設）
DB_CLIENT=sqlite3
DB_FILENAME=/directus/database/data.db

# 建議功能
WEBSOCKETS_ENABLED=true
ACCEPT_TERMS=true
TELEMETRY=false

# 若之後改成正式域名 / HTTPS / 反向代理，請改成你的公開網址
#PUBLIC_URL=https://directus.example.com

# ---- 快取 / Redis（選填）----
#CACHE_ENABLED=true
#CACHE_AUTO_PURGE=true
#CACHE_STORE=redis
#REDIS=redis://127.0.0.1:6379

# ---- Extensions（選填）----
#EXTENSIONS_AUTO_RELOAD=true

# ---- 檔案儲存（選填；若未設定，預設使用 /directus/uploads）----
#STORAGE_LOCATIONS=local
#STORAGE_LOCAL_DRIVER=local
#STORAGE_LOCAL_ROOT=/directus/uploads
