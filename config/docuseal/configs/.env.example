# DocuSeal（TGDB 產生）
#
# 參考：
# - GitHub：https://github.com/docusealco/docuseal
# - Environment Variables：https://www.docuseal.com/docs/configuring-docuseal-via-environment-variables
#
# 提醒：
# - 這份檔案會被 systemd/Quadlet 讀取並注入到容器
# - 值內請避免空白，避免 EnvironmentFile 解析問題

TZ=Asia/Taipei

# 安全與反向代理
SECRET_KEY_BASE=${secret_key_base}
FORCE_SSL=false

# 若之後改成正式域名 / HTTPS，請改成你的網域（不要含 http:// 或 https://）
#HOST=sign.example.com

# ---- SMTP（選填）----
#SMTP_USERNAME=
#SMTP_ADDRESS=
#SMTP_PORT=587
#SMTP_DOMAIN=
#SMTP_PASSWORD=
#SMTP_AUTHENTICATION=plain
#SMTP_FROM=noreply@example.com
#SMTP_ENABLE_STARTTLS=true
#SMTP_SSL_VERIFY=true

# ---- AWS S3（選填）----
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_REGION=
#S3_ATTACHMENTS_BUCKET=

# ---- GCS（選填）----
#GCS_CREDENTIALS=
#GCS_PROJECT=
#GCS_BUCKET=

# ---- Azure Blob（選填）----
#AZURE_STORAGE_ACCOUNT_NAME=
#AZURE_STORAGE_ACCESS_KEY=
#AZURE_CONTAINER=

# ---- 其他（選填）----
#SESSION_REMEMBER_DAYS=730
#PRESIGNED_URLS_EXPIRE_MINUTES=240
#WEB_CONCURRENCY=1
