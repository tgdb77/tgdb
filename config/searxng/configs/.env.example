# -----------------------------------------------------------------------------
# SearXNG（TGDB 產生）
# -----------------------------------------------------------------------------
# 說明：
# - 本檔案會由 Quadlet 以 EnvironmentFile 載入。
# - 若已使用反向代理並綁定域名，請把 SEARXNG_BASE_URL 改為正式網址（建議 HTTPS）。

# SearXNG 對外基底網址（注意結尾要有 /）
SEARXNG_BASE_URL=http://127.0.0.1:${host_port}/

# 可選：自訂顯示名稱
# SEARXNG_INSTANCE_NAME=SearXNG

# 可選：自訂綁定位址（預設為 [::]:8080，通常不需調整）
# SEARXNG_BIND_ADDRESS=0.0.0.0:8080
