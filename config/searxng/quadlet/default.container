[Unit]
Description=searxng
After=network-online.target
Wants=network-online.target

[Container]
Image=docker.io/searxng/searxng:latest
#AutoUpdate=registry
ContainerName=${container_name}
Label=app=searxng

Pod=${container_name}.pod

Volume=${instance_dir}/searxng:/etc/searxng
Volume=${instance_dir}/data:/var/cache/searxng

EnvironmentFile=${instance_dir}/.env

[Service]
Restart=always
RestartSec=15s
StartLimitBurst=3

[Install]
WantedBy=default.target

[Quadlet]
DefaultDependencies=false
