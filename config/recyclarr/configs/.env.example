# -----------------------------------------------------------------------------
# Recyclarr 環境變數範本
# -----------------------------------------------------------------------------
# 參考：
# - https://recyclarr.dev/guide/installation/docker/

TZ=Asia/Taipei

# 依官方容器做法，透過排程定期執行 sync。
# 可改成每天、每 6 小時等，格式與 cron 相同。
CRON_SCHEDULE=0 */6 * * *
